try {
/* module-key = 'com.atlassian.confluence.ext.newcode-macro-plugin:code-macro-editor', location = '/scripts/code-macro-languages.js' */
/**
 * Provides custom behaviour in the macro browser for the code macro.
 */
(function($) {

    var CodeMacroConfig = function() {};

    CodeMacroConfig.prototype.fields = {
        "string" : {
            "language" : function(param, options) {

                var paramDiv = $(Confluence.Templates.MacroBrowser.macroParameterSelect());
                var input = $("select", paramDiv);

                // we need to do some trickery when the value is first set, and when the value is subsequently changed,
                // so set this up.
                if (options == null)
                    options = {};
                options.setValue = function(value) {

                    var targetOption = input.find("option[value='" + value + "']");
                    if (targetOption.length == 0) {
                        var option = $("<option/>");
                        option.val(value);
                        option.text(value);
                        input.append(option);
                    }
                };

                bindAsyncDropDown(input);
                return new AJS.MacroBrowser.Field(paramDiv, input, options);
            }
        }
    };

    AJS.MacroBrowser.Macros["code"] = new CodeMacroConfig();

    /**
     * Populates an HTML Select element with the list of configured syntax highlighters.
     * @param dropDown JQuery selector for the HTML select element to be populated.
     */
    function bindAsyncDropDown(dropDown) {
        // Load the languages from Confluence
        getLanguagesAsync(function(languages) {
                    if (!languages.length)
                    {
                        AJS.log("Configured code macro languages result was not in the expected format.");
                        return;
                    }

                    var currentValue = dropDown.val();

                    dropDown.empty();
                    dropDown.append($("<option/>").attr("value", ""));

                    $.each(languages, function(index, lang) {
                        var option = $("<option />");
                        option.val(lang.aliases[0]);
                        option.text(lang.friendlyName);

                        dropDown.append(option);
                    });

                    // restore the currently selected value.
                    dropDown.val(currentValue);
                },
                function(xhr, textStatus, errorThrown) {
                    AJS.log("Failed to retrieve syntax highlighters from Confluence " + textStatus + " - " + errorThrown);
                });
    }

    /**
     * Asynchronously retrieves the current set of syntax highlighters currently installed for the Code macro.
     *
     * @param successHandler Callback to invoke if the retrieval is successful
     * @param errorHandler Callback to invoke if the retrieval fails.
     */
    function getLanguagesAsync(successHandler, errorHandler) {
        AJS.$.ajax({
            async: true,
            url: AJS.contextPath() + "/plugins/newcode/getlanguages.action",
            dataType: "json",
            timeout: 10000, // 10 seconds,
            error: function(xhr, textStatus, errorThrown) {
                if (errorHandler && typeof(errorHandler) == "function") {
                    errorHandler(xhr, textStatus, errorThrown);
                }
            },
            success: function(data) {
                if (successHandler && typeof(successHandler) == "function") {
                    successHandler(data);
                }
            }
        });
    }
})(AJS.$);
}catch(e){WRMCB(e)};
;
try {
/* module-key = 'com.adaptavist.confluence.forums:genericColumnMacro', location = 'forum/js/macro-editor/genericColumnMacro.js' */
/*global jQuery, AJS, Option */

/* genericColumnMacro.js
 *
 * Add customisations to the default Macro Browser to make editing of {forum-generic-column} macro easier.
 *
 */
AJS.toInit(function ($) {

    var data = {"columns":{"creationdate":{"displayName":"Creation Date","heading":"Creation Date","formatters":{"confluence-date":"Confluence Date","mmddyyyy-date":"US Date","friendly":"Friendly Date","local-date":"Local Date","ddmmyyyy-date":"UK Date"}},"replies":{"displayName":"Replies","heading":"# of Replies","formatters":{"plaintext":"Plain Text"}},"createdby":{"displayName":"Created By","heading":"Author","formatters":{"link":"Link","plaintext":"Plain Text","userpicture":"User Picture"}},"lastactivitydate":{"displayName":"Last Activity Date","heading":"Last Activity Date","formatters":{"confluence-date":"Confluence Date","mmddyyyy-date":"US Date","friendly":"Friendly Date","local-date":"Local Date","ddmmyyyy-date":"UK Date"}},"title":{"displayName":"Topic Title","heading":"Topic","formatters":{"link":"Link","plaintext":"Plain Text"}},"activityscore":{"displayName":"Activity Score","heading":"Activity Score","formatters":{"plaintext":"Plain Text"}},"lastcommentby":{"displayName":"lastcommentby","heading":"Last Comment By","formatters":{"userpicture":"User Picture"}},"views":{"displayName":"Views","heading":"# of Views","formatters":{"plaintext":"Plain Text"}},"status":{"displayName":"Status","heading":"Status","formatters":{"image":"Image"}}}};

    function dropDown(multiple) {
        var paramDiv = $(Confluence.Templates.MacroBrowser.macroParameterSelect()),
            select = $("select", paramDiv),
            input = $('<input type="hidden"/>').appendTo(paramDiv);

        select
            .attr('multiple', multiple)
            .bind('change', function () {
                if (multiple) {
                    input.val((select.val() || []).join(" ")).change();
                } else {
                    input.val(select.val()).change();
                }
            });

        var options = {
            setValue: function (value) {
                var val = $.trim(value);
                input.val(val);
                select.val(val.split(/\s+/));
            }
        };

        return AJS.MacroBrowser.Field(paramDiv, input, options);
    }

    function removeAllOptions(select) {
        select.options.length = 0;
    }

    function addOption(select, value, label) {
        select.options[select.options.length] = new Option(label, value);
    }

    var columnSelect, formatSelect, headingInput, columnDiv;

    function selectColumn(column) {
        updateFormatSelect(column);
        updateHeadingInput(column);
    }

    function updateFormatSelect(column) {
        if (formatSelect) {
            removeAllOptions(formatSelect);
            if (column && data.columns[column]) {
                $.each(data.columns[column].formatters, function (index, element) {
                    addOption(formatSelect, index, element);
                });
            }
            $(formatSelect).change();
        }
    }

    function updateHeadingInput(column) {
        if (headingInput) {
            $(headingInput).val((column && data.columns[column]) ? data.columns[column].heading : "");
            $(headingInput).change();
        }
    }

    var overrides = {
        "fields": {
            "string": {
                "column": function () {
                    var field = dropDown(false);
                    columnDiv = $("select", field.paramDiv);
                    var select = columnDiv[0];

                    columnSelect = select;
                    $.each(data.columns, function (index, element) {
                        addOption(select, index, element.displayName);
                    });
                    columnDiv.on("change", function (e) {
                        selectColumn($(e.target).val());
                    });
                    return field;
                },
                "format": function () {
                    var field = dropDown(false),
                        select = $("select", field.paramDiv)[0];

                    formatSelect = select;

                    return field;
                },
                "heading": function (param, options) {
                    var field = AJS.MacroBrowser.ParameterFields.string(param, options),
                        input = $("input", field.paramDiv)[0];

                    headingInput = input;

                    return field;
                }
            }
        },
        "beforeParamsSet": function (selectedParams) {
            updateFormatSelect(selectedParams.column);
            columnDiv.change();
            return selectedParams;
        }
    };

    AJS.MacroBrowser.setMacroJsOverride("rest-forum-column-generic", overrides);
});

}catch(e){WRMCB(e)};
;
try {
/* module-key = 'ch.mibex.confluence.ipython-notebook:ipython-for-confluence-macro-browser', location = '/js/macrobrowser.js' */
(function($) {

    function setOptionHandler(options, input) {
        options.setValue = function(value) {
            const targetOption = input.find("option[value='" + value + "']");
            if (targetOption.length === 0) {
                const option = $("<option/>");
                option.val(value);
                option.text(value);
                input.append(option);
            }
        };
    }

    function getInitialParameterValues() {
        const meta = {};
        const selection = AJS.Rte.getEditor().selection.getNode();
        const params = $(selection).attr("data-macro-parameters");
        if (params && params.length > 0) {
            params.split("|").forEach(function (paramStr) {
                const [name, content] = paramStr.split("=");
                meta[name] = content;
            });
        }
        return meta;
    }

    const IPythonNotebookMacroConfig = function () {
    };
    IPythonNotebookMacroConfig.prototype.fields = {
        "string" : {
            "attachmentPageId" : function(param, options) {
                const paramDiv = $(Confluence.Templates.MacroBrowser.macroParameter());
                const input = $("input", paramDiv);

                // inject html to add section separator between the different include options in the input form
                paramDiv.prepend(`
                    <div class="form-section-title" style="border-top: 1px solid; padding: 5px 0px; font-weight: 600">
                        Option 1: Confluence page attachment<br>
                    </div>`);

                initAttachmentPageChooser(input);

                input.change(function() {
                    $('select#macro-param-attachment').val('');
                    fillAttachmentsList($('select#macro-param-attachment'), cleanInput(input.val()));
                });

                setTimeout(() => input.focus(), 1);

                return new AJS.MacroBrowser.Field(paramDiv, input, options);
            },
            "attachment" : function(param, options) {
                const paramDiv = $(Confluence.Templates.MacroBrowser.macroParameterSelect());
                const input = $("select", paramDiv);
                if (options == null) {
                    options = {};
                }
                setOptionHandler(options, input);

                const initialAttachmentPageId = getInitialParameterValues()['attachmentPageId'] ?? '';
                fillAttachmentsList(input, cleanInput(initialAttachmentPageId));

                return new AJS.MacroBrowser.Field(paramDiv, input, options);
            },
            "applicationLink" : function(param, options) {
                const paramDiv = $(Confluence.Templates.MacroBrowser.macroParameterSelect());
                const input = $("select", paramDiv);
                if (options == null) {
                    options = {};
                }

                paramDiv.prepend(`
                    <div class="form-section-title" style="border-top: 1px solid; padding: 5px 0px; font-weight: 600">
                        Option 3: File from Bitbucket Data Center Repository<br>
                    </div>`);

                setOptionHandler(options, input);
                fillApplicationLinkList(input);

                return new AJS.MacroBrowser.Field(paramDiv, input, options);
            },
            "projectKey" : function(param, options) {
                const paramDiv = $(Confluence.Templates.MacroBrowser.macroParameterSelect());
                const input = $("select", paramDiv);
                if (options == null) {
                    options = {};
                }
                setOptionHandler(options, input);

                $('select#macro-param-applicationLink').change(function() {
                    const appLinkId = this.value;
                    fillProjectsList(input, appLinkId);
                });

                return new AJS.MacroBrowser.Field(paramDiv, input, options);
            },
            "repoSlug" : function(param, options) {
                const paramDiv = $(Confluence.Templates.MacroBrowser.macroParameterSelect());
                const input = $("select", paramDiv);
                if (options == null) {
                    options = {};
                }
                setOptionHandler(options, input);

                $('select#macro-param-projectKey').change(function() {
                    const projectKey = this.value;
                    fillRepositoryList(input, $('select#macro-param-applicationLink').val(), projectKey);
                });

                return new AJS.MacroBrowser.Field(paramDiv, input, options);
            },
            "notebookUrl" : function(param, options) {
                const paramDiv = $(Confluence.Templates.MacroBrowser.macroParameter());
                const input = $("input", paramDiv);

                paramDiv.prepend(`
                    <div class="form-section-title" style="border-top: 1px solid; padding: 5px 0px; font-weight: 600">
                        Option 2: Notebook URL<br>
                    </div>`);

                initAutoPreview(input);

                return new AJS.MacroBrowser.Field(paramDiv, input, options);
            }
        }
    };

    // because these two fields are handled with select2, we need to remember their initial state
    let initialFilePath;
    let initialBranch;
    IPythonNotebookMacroConfig.prototype.beforeParamsSet = function(selectedParams, macroSelected) {
        initialFilePath = selectedParams['filepath'];
        initialBranch = selectedParams['branchId'];

        // this is necessary because it is a mandatory parameter that was added later to the plug-in; without setting
        // this manually, users not having this parameter configured will not see the preview when they open the macro dialog
        if (selectedParams['applicationLink'] === undefined) {
            getStashEntities("getapplinks.action?pageId=" + AJS.params.pageId, function (appLinks) {
                    if (appLinks.status === 'ERROR') {
                        showError(appLinks);
                        return;
                    }
                    $.each(appLinks, function (index, appLink) {
                        if (appLink.primary) {
                            selectedParams['applicationLink'] = appLink.id;
                        }
                    });
                },
                function (response) {
                    showError(response);
                },
                false
            );
        }
        return selectedParams;
    };

    AJS.MacroBrowser.Macros["ipython"] = new IPythonNotebookMacroConfig();

    function fillAttachmentsList(dropDown, attachmentPageId) {
        function autoPreview() {
            $('#macro-browser-preview-link').click();
            return true;
        }

        function constructUrl(attachmentPageId) {
            const baseUrl = "getAttachments.action?pageId=" + AJS.params.pageId + "&draftId=" + AJS.params.draftId;
            const attachmentIdParam = attachmentPageId !== undefined && attachmentPageId !== '' ?
                validateAndFormatIdParam(attachmentPageId, "attachmentPageId") : '';
            return baseUrl + attachmentIdParam;
        }

        getStashEntities(constructUrl(attachmentPageId), function(attachments) {
            const currentValue = dropDown.val();
            dropDown.empty().append($("<option>(None)</option>").attr("value", ""));

            if (!attachments.length) {
                AJS.log("No attachments found.");
                autoPreview();
                return;
            }

            attachments.forEach(attachment => {
                $("<option />", {
                    val: attachment.name,
                    text: attachment.name
                }).appendTo(dropDown);
            });

            dropDown.val(currentValue);
            autoPreview();
            dropDown.off('change').on('change', autoPreview);

        }, function(response) {
            dropDown.empty();
            showError(response);
        });
    }

    function fillApplicationLinkList(dropDown) {
        getStashEntities("getapplinks.action?pageId=" + AJS.params.pageId,
            function(appLinks) {
                const currentValue = dropDown.val();
                dropDown.empty();
                dropDown.append($("<option>(Choose application link)</option>").attr("value", ""));

                if (!appLinks.length) {
                    AJS.log("No application links found.");
                    return;
                }

                $.each(appLinks, function(index, appLink) {
                    const option = $("<option />");
                    option.val(appLink.id);
                    option.text(appLink.name);
                    dropDown.append(option);
                });

                dropDown.val(currentValue);
                fillProjectsList($('select#macro-param-projectKey'), dropDown.val());
            },
            function(response) {
                dropDown.empty();
                showError(response);
            }, true
        );
    }

    function fillProjectsList(dropDown, appLink) {
        getStashEntities("getprojects.action?appLink=" + appLink + "&pageId=" + AJS.params.pageId, function(projects) {
                const currentValue = dropDown.val();
                dropDown.empty();
                dropDown.append($("<option>(Choose project)</option>").attr("value", ""));

                if (!projects.length) {
                    AJS.log("No projects found.");
                    return;
                }

                $.each(projects, function(index, proj) {
                    const option = $("<option />");
                    option.val(proj.key);
                    option.text(proj.name);
                    dropDown.append(option);
                });

                dropDown.val(currentValue);
                fillRepositoryList($('select#macro-param-repoSlug'), appLink, dropDown.val());
            },
            function(response) {
                dropDown.empty();
                showError(response);
            }, true);
    }

    function fillRepositoryList(dropDown, appLink, projectKey) {
        if (!projectKey) return;

        const repoUrl = "getrepos.action?appLink=" + appLink + "&projectKey=" + projectKey + "&pageId=" + AJS.params.pageId;
        getStashEntities(repoUrl, function(repos) {
                const currentValue = dropDown.val();
                dropDown.empty();
                dropDown.append($("<option>(Choose repository)</option>").attr("value", ""));

                if (!repos.length) {
                    AJS.log("No repositories found.");
                    return;
                }

                $.each(repos, function(index, proj) {
                    const option = $("<option />");
                    option.val(proj.slug);
                    option.text(proj.name);
                    dropDown.append(option);
                });

                dropDown.val(currentValue);

                initBranchChooser(appLink, projectKey, currentValue, initialBranch);
                dropDown.change(function() {
                    initBranchChooser(appLink, projectKey, $(this).val(), '');
                });
            },
            function(response) {
                dropDown.empty();
                showError(response);
            }, true);
    }


    function formatFilePathEntry(obj, maxNumCharsToShow) {
        if (!obj.text) return;
        const display = document.createElement('div')
        if (obj.text.length <= maxNumCharsToShow) {
            display.textContent = obj.text;
        } else if (obj.abbreviation) {
            display.textContent = obj.abbreviation;
            display.setAttribute('title', obj.text)
        } else {
            display.textContent = obj.text.slice(-maxNumCharsToShow + '...'.length + 1)
            display.setAttribute('title', obj.text)
        }
        return display;
    }


    function initFileChooser(appLink, projectKey, repoSlug, branchId, initialFile) {
        if (!branchId) return;

        const maxNumCharsToShow = 28;
        let cache = [];

        const $filePath = $('input#macro-param-filepath');
        $filePath.auiSelect2({
            placeholder: 'Select a file',
            allowClear: true,
            width: '100%',
            adaptContainerCssClass: function(klass) {
                return $.trim(klass) === 'macro-param-input' ? null : klass;
            },
            formatNoMatches: function(query) {
                return 'No matching files found';
            },
            formatResult: function(obj, container, query) {
                return formatFilePathEntry(obj, maxNumCharsToShow);
            },
            formatSelection: function(obj, container) {
                return formatFilePathEntry(obj, maxNumCharsToShow);
            },
            initSelection : function(element, callback) {
                callback({id: initialFile, text: initialFile});
            },
            sortResults: function(results, container, query) {
                return _.sortBy(results, function(path) {
                    return path.text;
                });
            },
            query: function(query) {
                const term = cleanInput(query.term.toLowerCase());

                if (cache.length) {
                    const results = _.filter(cache, function (path) {
                        return path.text.toLowerCase().indexOf(term) >= 0;
                    });
                    query.callback({results : results});
                    return;
                }

                const getFilePathsUrl = "getfiles.action?appLink=" + appLink + "&projectKey=" + projectKey +
                    "&repoSlug=" + repoSlug + "&branchId=" + branchId + "&pageId=" + AJS.params.pageId + "&filePath=";
                getStashEntities(getFilePathsUrl, function(filePaths) {
                    const results = [{id: '', text: '(Choose file)'}];
                    for (let i = 0; i < filePaths.length; i++) {
                        if (i % 2 === 0) { // file paths and their appreviation always come after each other
                            const path = filePaths[i];
                            if (path.toLowerCase().indexOf(term) >= 0) {
                                results.push({id: path, text: path, abbreviation: filePaths[i + 1]});
                            }
                        }
                    }
                    cache = results;
                    query.callback({results: results});
                }, function(error) {
                    query.callback({results: []});
                }, true);
            }
        });
        initAutoPreview($filePath);
    }

    function initAutoPreview($filePath) {
        const autoPreview = function () {
            // AJS.MacroBrowser.previewMacro();
            if (($(this).val() && $('input#macro-param-filepath').val()) || ($(this).val() && $('input#macro-param-notebookUrl').val())) {
                AJS.log("auto-preview triggered for " + $(this).val());
                $('#macro-browser-preview-link').click();
            }
            return true;
        };
        $filePath.on('change', autoPreview);
    }

    function initBranchChooser(appLink, projectKey, repoSlug, initialBranch) {
        if (!repoSlug) return;

        const $branchChooser = $('input#macro-param-branchId');
        $branchChooser.auiSelect2({
            placeholder: 'Select a branch or tag',
            width: '100%',
            adaptContainerCssClass: function(klass) {
                return $.trim(klass) === 'macro-param-input' ? null : klass;
            },
            formatNoMatches: function(query) {
                return 'No matching branches or tags found';
            },
            initSelection : function(element, callback) {
                callback({id: initialBranch, text: initialBranch});
            },
            sortResults: function(results, container, query) {
                return _.sortBy(results, function(path) {
                    return path.text;
                });
            },
            formatSelection: function(obj, container) {
                if (!obj.text) return;
                let selection = obj.text;
                if (selection.lastIndexOf('refs/heads/', 0) === 0) {
                    selection = selection.slice('refs/heads/'.length);
                }
                if (selection.lastIndexOf('refs/tags/', 0) === 0) {
                    selection = selection.slice('refs/tags/'.length);
                }
                let span = document.createElement('span')
                span.textContent = selection
                return span;
            },
            query: function(query) {
                const term = cleanInput(query.term.toLowerCase());
                const branchesUrl = "getbranches.action?appLink=" + appLink + "&projectKey=" + projectKey +
                    "&repoSlug=" + repoSlug + "&pageId=" + AJS.params.pageId;
                getStashEntities(branchesUrl, function(branches) {
                    let results = {};

                    for (let i = 0; i < branches.length; i++) {
                        if (results['branches'] === undefined) {
                            results['branches'] = {text:'branches', children:[]};
                        }
                        if (branches[i].displayId.toLowerCase().indexOf(term) >= 0) {
                            results['branches'].children.push({id: branches[i].id, text: branches[i].displayId});
                        }
                    }
                    const tagsUrl = "gettags.action?appLink=" + appLink + "&projectKey=" + projectKey + "&repoSlug=" + repoSlug + "&pageId=" + AJS.params.pageId;
                    getStashEntities(tagsUrl, function(tags) {
                        for (let i = 0; i < tags.length; i++) {
                            if (results['tags'] === undefined) {
                                results['tags'] = {text:'tags', children:[]};
                            }
                            if (tags[i].displayId.toLowerCase().indexOf(term) >= 0) {
                                results['tags'].children.push({id: tags[i].id, text: tags[i].displayId});
                            }
                        }
                        query.callback({results: results});
                    }, function(error) {
                        query.callback({results: []});
                    }, true);
                }, function(error) {
                    query.callback({results: []});
                }, true);
            }
        });
        initFileChooser(appLink, projectKey, repoSlug, initialBranch, initialFilePath);
        $branchChooser.change(function() {
            initFileChooser(appLink, projectKey, repoSlug, this.value, '');
        });
    }

    function initAttachmentPageChooser(input) {
        input.auiSelect2({
            allowClear: true,
            width: '100%',
            formatNoMatches: function(query) {
                return `No matches for "${query}". To search, provide at least one word in the page title.`;
            },
            initSelection : function(element, callback) {
                const initialAttachmentPageId = getInitialParameterValues()['attachmentPageId'];
                const sanitizedInitialAttachmentPageId = cleanInput(initialAttachmentPageId);
                if(initialAttachmentPageId) {
                    callback({id: sanitizedInitialAttachmentPageId, text: pageTitleFromId(sanitizedInitialAttachmentPageId)});
                } else {
                    callback();
                }
            },
            query: function(query) {
                const maxResults = 10;
                const minTermLength = 3;

                const term = cleanInput(query.term.toLowerCase());

                if (term.length >= minTermLength) {
                    const pageSearchQuery = `title~"${term}"`;
                    const cqlString = encodeURIComponent(`type=page and (${pageSearchQuery})`);
                    const pages = [];
                    AJS.$.ajax({
                        url: `${AJS.params.contextPath}/rest/api/search?cql=${cqlString}&limit=${maxResults}`,
                        type: 'GET',
                        dataType: 'json',
                        success: function (response) {
                            const queryResults = response.results;
                            if (queryResults && queryResults.length > 0) {
                                for (let i = 0; i < queryResults.length; i++) {
                                    pages.push({id: queryResults[i].content.id, text: queryResults[i].content.title});
                                }
                            }
                            query.callback({results: pages});
                        },
                        error: function(error) {
                            showError(error);
                            query.callback({results: pages});
                        }
                    });
                } else {
                    query.callback({results: [{id: '', text: '(Current page)'}]});
                }

            },
        });
    }

    function pageTitleFromId(id) {
        let title = '';
        AJS.$.ajax({
            url: `${AJS.params.contextPath}/rest/api/content/${id}?privacyMode=true`,
            type: 'GET',
            dataType: 'json',
            success: function (response) {
                if (response.title) {
                    title = response.title;
                }
            },
            error: function(response) {
                showError(response);
            },
            async: false,
        });
        return title;
    }

    function getStashEntities(entityUrl, successHandler, errorHandler, async) {
        AJS.$.ajax({
            async: async,
            url: AJS.params.contextPath + "/plugins/ipython/" + entityUrl,
            dataType: 'json',
            timeout: 30000,
            error: function(xhr, textStatus, errorThrown) {
                errorHandler(errorThrown);
            },
            success: function(response) {
                if (response.status === 'OK' && successHandler && typeof(successHandler) === 'function') {
                    successHandler(response.body);
                } else if (errorHandler && typeof(errorHandler) === 'function') {
                    errorHandler(response);
                }
            }
        });
    }

    function responseMessage(response) {
        if (response.url) {
            const pElem = document.createElement('p')
            pElem.appendChild(document.createTextNode(response.leadingText))
            const link = document.createElement('a')
            link.setAttribute('target', '_blank')
            link.setAttribute('href', response.url)
            link.appendChild(document.createTextNode(response.linkedText))
            pElem.appendChild(link)
            pElem.appendChild(document.createTextNode(response.endText))
            return pElem.outerHTML;
        } else {
            // Create a message as HTML via DOM to avoid XSSS
            const pElem = document.createElement('p')
            const message = document.createTextNode(response.body)
            pElem.appendChild(message)
            return pElem.outerHTML
        }
    }

    function showError(response) {
        const formattedMsg = responseMessage(response)
        // we have to show the error messages right below the macro description because newer Confluence versions
        // use an iFrame for the macro content which we cannot access with AJS.messages, see IPYTHON-29
        if (response.status === "ERROR") {
            AJS.messages.error('div#macro-param-div-applicationLink', {
               title: "An error occurred",
               body: formattedMsg,
               closeable: false
            });
        } else if (response.status === "INFO") {
            AJS.messages.info('div#macro-param-div-applicationLink', {
               title: "An action is required",
               body: formattedMsg,
               closeable: false
            });
        } else {
            AJS.messages.error('div#macro-param-div-applicationLink', {
                title: "An unknown error occurred",
                body: formattedMsg,
                closeable: false
            });
        }
    }

})(AJS.$);

}catch(e){WRMCB(e)};
;
try {
/* module-key = 'ch.mibex.confluence.ipython-notebook:ipython-for-confluence-macro-browser', location = '/js/notebookutils.js' */
function renderIPythonNotebook(uniqueId) {
    const $spinner = AJS.$('.ipython-spinner');
    $spinner.html('<aui-spinner size="medium"></aui-spinner>');

    const $el = AJS.$(`#ipython-rendered-${uniqueId}`);
    const ipynbContent = AJS.$(`#ipython-content-${uniqueId}`).val();

    try {
        // Decode the Base64 string
        const decodedContent = atob(ipynbContent);

        const json = JSON.parse(decodedContent);
        renderNotebook(json, $el);
    } catch (e) {
        const errorMsg = errorMessage(`Failed to parse the Jupyter notebook content. ${e.message}`);
        AJS.$(errorMsg).insertBefore($el);
        console.error(e);
    } finally {
        $spinner.empty();
    }
}

function renderNotebook(ipynb, $el) {
    try {
        const notebook = nb.parse(ipynb);
        $el.empty();
        $el.append(notebook.render());
        Prism.highlightAll();
    } catch (e) {
        // sometimes this error is reported although the notebook is properly rendered; we therefore do not display this error
        if (e.message !== "IPython is not defined") {
            const errorMsg = errorMessage(e.message);
            AJS.$(errorMsg).insertBefore($el);
        }
        console.error(e);
    }
}

function errorMessage(message) {
    const sanitizedMessage = DOMPurify.sanitize(message);
    return '<div class="aui-message error">' +
        '<p class="title"><strong>' + 'Failed to render Jupyter notebook' + '</strong></p>' +
        '<p>' + sanitizedMessage + '</p>' +
        '</div>';
}

function cleanInput(input) {
    if (input === undefined || input === '') {
        return input;
    }

    return input
        .replace(/<\/?[^>]+(>|$)/g, "") // Remove HTML tags
        .replace(/(\.\.\/?)+/g, "") // Remove potential path traversal patterns
        .trim(); // Trim whitespace
}

function validateAndFormatIdParam(id, idParamName) {
    const parsedId = parseInt(id, 10);
    if (!isNaN(parsedId) && parsedId.toString() === id) {
        return `&${idParamName}=` + parsedId;
    } else {
        AJS.log(`Invalid ${idParamName}: must be an integer.`);
        return "";
    }
}


if (typeof exports !== 'undefined') {
    exports.cleanInput = cleanInput;
    exports.validateAndFormatIdParam = validateAndFormatIdParam;
}
}catch(e){WRMCB(e)};
;
try {
/* module-key = 'ch.mibex.confluence.ipython-notebook:ipython-for-confluence-macro-browser', location = '/js/themeHandler.js' */
document.addEventListener('DOMContentLoaded', function() {

    function updatePrismStyles() {
        const colorMode = document.documentElement.getAttribute('data-color-mode');
        const isDarkMode = colorMode === 'dark';
        const cssFile = isDarkMode ? 'prism-dark.css' : 'prism.css';
        const resourceKey = isDarkMode ? 'prism-syntax-highlighter-dark' : 'prism-syntax-highlighter-light';
        const cssPath = AJS.contextPath() + '/download/resources/ch.mibex.confluence.ipython-notebook:' + resourceKey + '/' + cssFile;

        AJS.$('link[data-prism-theme]').remove();

        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = cssPath;
        link.setAttribute('data-prism-theme', colorMode);
        document.head.appendChild(link);
    }

    updatePrismStyles();

    // Watch for changes in the 'data-color-mode' attribute
    const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            if (mutation.attributeName === 'data-color-mode') {
                updatePrismStyles();
            }
        });
    });

    observer.observe(document.documentElement, { attributes: true });
});
}catch(e){WRMCB(e)};
;
try {
/* module-key = 'com.adaptavist.confluence.formMailNG:responses-table-resources', location = 'js/forms/config/response-table.js' */
AJS.toInit(function ($) {

    var storageKey = "responseColumns";
    var pageId = AJS.params.pageId;
    var $tables = $(".responsesTableDiv table");
    var formId = "formid";
    //first reorder the table
    //reorder all responseTable in the page

    $tables.each(function () {
        reorderTableColumn($(this));
    });

    //enable dragging feature
    $tables.each(function () {
        $(this).enableDragTable({pageId: pageId, table: $(this), formId: $(this).attr(formId)});
    });

    //enable sorting for column with date
    $tables.find("time[data-sort-value]").each(function () {
        var parentTd = $(this).parent();
        var timeAttrValue = $(this).attr("data-sort-value");
        $(parentTd).attr("data-sort-value", timeAttrValue);
    });

    /**
     * Get local storage value for a given key
     * @param item
     */
    function getStorageItem(item) {
        if (typeof(Storage) !== "undefined") {
            return JSON.parse(localStorage.getItem(item));
        }
    }

    /**
     * Call storage item function to return stored columns order.
     * @returns {*}
     */
    function getStoredResponseTableColumnsOrder(formId) {
        var key = pageId + "_" + formId + "_" + storageKey;
        return getStorageItem(key);
    }

    /**
     * Get the current column name and position
     * @returns {Array}
     */
    function getColumnsSequence(table) {
        var columns = [];
        $.each(table.find("thead th[data-header]"), function (index, th) {
            columns.push($(th).attr("data-header"));
        });
        return columns;
    }

    /**
     * Reorder table columns according to stored columns order.
     */
    function reorderTableColumn(table) {
        var storedColumnPosition = getStoredResponseTableColumnsOrder(table.attr(formId));

        if (storedColumnPosition == null) {
            return;
        }

        var defaultColumnPosition = getColumnsSequence(table);
        for (var index = 0; index < defaultColumnPosition.length; index++) {
            /**
             * The following line is important. From column sequence it retrieve index
             * of the stored column. getColumnsSequence function must be called each iteration.
             */
            var storedIndex = getColumnsSequence(table).indexOf(storedColumnPosition[index]);
            if (storedIndex > -1 && index != storedIndex) {
                $.each(table.find("tr"), function () {
                    $(this).children(":eq(" + index + ")").before($(this).children(":eq(" + storedIndex + ")"));
                });
            }
        }
    }

    AJS.$('.downloadAttachmentsLink').on('click', function () {
        var emailId = $(this).attr('id');
        var restUrl = AJS.contextPath()
            + '/rest/formservice/1.0/inbox/downloadAttachments/email/'
            + emailId + "/?"
            + "spaceKey=" + AJS.params.spaceKey;
        $(this).attr("href", restUrl);
    });
});


}catch(e){WRMCB(e)};
;
try {
/* module-key = 'com.adaptavist.confluence.formMailNG:responses-table-resources', location = 'js/forms/config/jquery.dragtable.js' */
/*!
 * The original implementation is available in :
 * https://github.com/akottr/dragtable - Andres Koetter akottr@gmail.com and 
 * https://github.com/jebaird/dragtable
 * The implementation has been modified according to our need  
 */

(function ($) {
    $.widget("adaptavist.enableDragTable", {
        widgetEventPrefix: 'enableDragTable',
        options: {
            dataHeader: 'data-header',
            handle: 'dragtable-drag-handle',
            boundary: 'dragtable-drag-boundary',
            placeholder: 'dragtable-col-placeholder',
            appendTarget: ':parent',
            scroll: true,
            storageKey: "responseColumns",
            pageId: null,
            table: null,
            formId: null,
            timer: 0,
            isDragging: false
        },
        // when a col is dragged use this to find the semantic elements, for speed
        tableElemIndex: {
            head: '0',
            body: '1',
            foot: '2'
        },
        tbodyRegex: /(tbody|TBODY)/,
        theadRegex: /(thead|THEAD)/,
        tfootRegex: /(tfoot|TFOOT)/,

        _create: function () {
            this.startIndex = null;
            this.endIndex = null;
            this.currentColumnCollection = [];
            this.currentColumnCollectionOffset = {};
            this.dragDisplay = $([]);

            var self = this,
                o = self.options,
                el = self.element;

            o.appendTarget = ( o.appendTarget === ':parent' ) ? this.element.parent() : $(o.appendTarget);
            //grab the ths and the handles and bind them
            el.find("thead th").on('mousedown.' + self.widgetEventPrefix, function (e) {

                var $handle = $(this);
                /**
                 * timer is required to keep atlassian sortable plugin functionality working as expected.
                 * @type {number}
                 */
                self.options.timer = setTimeout(function () {
                    if (o.timer >= 30 && o.isDragging == false) {
                        o.isDragging = true;
                        var elementOffsetTop = self.element.position().top;
                        //make sure we are working with a th instead of a handle
                        if ($handle.hasClass(o.handle)) {
                            $handle = $handle.closest('th');
                            //change the target to the th, so the handler can pick up the offsetleft
                            e.currentTarget = $handle.closest('th')[0]
                        }

                        self.getCol($handle.index())
                            .attr('tabindex', -1)
                            .focus()
                            .css({
                                top: elementOffsetTop,
                                //need to account for the scroll left of the append target, other wise the display will be off by that many pix
                                left: ( self.currentColumnCollectionOffset.left)
                            })
                            .appendTo(o.appendTarget);

                        self._mousemoveHandler(e);
                    }
                }, 150);
            });

            $(document).on('mouseup.' + self.widgetEventPrefix, function (e) {
                clearTimeout(o.timer);
                o.isDragging = false;
                self._stop(e);
                self._storeResponseTableColumnOrder();
            });
        },

        /**
         * e.currentTarget is used for figuring out offsetLeft
         * getCol must be called before this is
