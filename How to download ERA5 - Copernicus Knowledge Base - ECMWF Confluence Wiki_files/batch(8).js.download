        }
    }

    function registerConditionalSelect2Field(fieldClassName, values, groupRowIndex) {
        var field = $('#groupRow' + groupRowIndex).find(fieldClassName);

        if (fieldClassName === "input.conditionalInputFieldToTrigger") {
            var tr = AJS.$(AJS.$(field).closest("tr"));
            var conditionalInputFieldValue = AJS.$(tr.find(".conditionalInputField")[0]).select2("val");
            var index = values.indexOf(conditionalInputFieldValue);
            if (index > -1) {
                values.splice(index, 1);
            }
        }

        var data = [];
        for (var i = 0; i < values.length; i++) {
            data.push({
                id: values[i],
                text: values[i]
            });
        }

        for (var _i = 0; _i < field.length; _i++) {
            var conditionalField = AJS.$(field[_i]);
            conditionalField.auiSelect2({
                minimumResultsForSearch: Infinity,
                data: data,
                placeholder: 'Select an option'
            });
        }

        field.on('select2-close', function (event) {
            focusOutsideTheSelect2(event);
        });

        field.on('select2-open', function (event) {
            focusOutsideTheSelect2(event);
            var options = AJS.$.find('.select2-result');
            AJS.$.each(options, function () {
                $(this).attr("title", $(this).text());
                $(this).tooltip({
                    show: { effect: "blind", duration: 800 }
                });
            });
        });

        field.on('select2-focus', function (event) {
            focusOutsideTheSelect2(event);
        });

        field.on('select2-blur', function (event) {
            focusOutsideTheSelect2(event);
        });

        if (fieldClassName === "input.conditionalInputField" || fieldClassName === "input.conditionalInputWhatHappens") {
            field.on('change', function (event) {
                var tr = AJS.$(AJS.$(event.target).closest("tr"));
                var trId = AJS.$(AJS.$(event.target).closest("tr"))[0].id;
                var index = trId.substr(trId.length - 1);

                var conditionalInputFieldToTrigger = AJS.$(tr.find(".conditionalInputFieldToTrigger")[0]);
                conditionalInputFieldToTrigger.select2("val", "");

                if (fieldClassName === "input.conditionalInputWhatHappens") {
                    conditionalInputFieldToTrigger.select2('enable');
                }
                loadProperTargets(AJS.$(tr.find(".conditionalInputWhatHappens")[1]).val(), conditionalInputFieldToTrigger, index, false);
            });
        }
    }

    function loadProperTargets(action, conditionalInputFieldToTrigger, index, showingFirstTime) {

        switch (action) {
            case "Show":
                registerConditionalSelect2Field("input.conditionalInputFieldToTrigger", (0, _common.loadAvailableFields)(), index);
                break;
            case "Hide":
                registerConditionalSelect2Field("input.conditionalInputFieldToTrigger", (0, _common.loadAvailableFields)(), index);
                break;
            case "Finish":
                if (showingFirstTime) {
                    registerConditionalSelect2Field("input.conditionalInputFieldToTrigger", [], index);
                }
                // conditionalInputFieldToTrigger.select2('data', {id: 0, text: ''});
                conditionalInputFieldToTrigger.select2('disable');
                break;
            case "Go to page":
                registerConditionalSelect2Field("input.conditionalInputFieldToTrigger", (0, _common.loadAvailableFormPages)(), index);
                break;
            default:
                if (showingFirstTime) {
                    registerConditionalSelect2Field("input.conditionalInputFieldToTrigger", [], index);
                    var field = $('#groupRow' + index).find("input.conditionalInputFieldToTrigger");
                    field.select2('disable');
                }
                registerConditionalSelect2Field("input.conditionalInputFieldToTrigger", (0, _common.loadAvailableFields)().concat((0, _common.loadAvailableFormPages)()), index);
        }
    }

    function focusOutsideTheSelect2(event) {
        var conditionalHeader = AJS.$(AJS.$(event.target).closest("td"));
        var newElementToFocus = AJS.$(conditionalHeader.next().find("input")[0]);
        setTimeout(function () {
            AJS.$('#cancelButtonGroup').focus();
            newElementToFocus.focus();
        }, 0);
    }

    // Group Row Actions
    // Must pass event variable because it is not treated as global in Firefox
    function addGroupRow(event) {
        var rowIndex = AJS.$(event.target).data("row-index");
        var maxIndex = (0, _common.getMaxIndex)();

        AJS.$('#dataTable > tbody > tr#groupRow' + rowIndex).after(Forms.Macros.ConditionalFields.addConditionalRow({
            rowIndex: maxIndex,
            field: '',
            fieldValue: '',
            whatHappens: '',
            fieldToTrigger: ''
        }));
        AJS.$('.removeGroupRowInput')[0].disabled = false;

        (0, _common.registerGroupRowButtons)(addGroupRow, maxIndex);
        registerConditionalSelect2Field("input.conditionalInputField", (0, _common.loadAvailableFields)(), maxIndex);
        registerConditionalSelect2Field("input.conditionalInputWhatHappens", getAvailableActions(), maxIndex);

        var field = $('#groupRow' + maxIndex).find("input.conditionalInputFieldToTrigger");
        loadProperTargets("", AJS.$(field), maxIndex, true);
    }

    function getAvailableActions() {
        var availableActions = ["Show", "Hide"];

        var formPages = (0, _common.loadAvailableFormPages)();
        if (formPages.length > 0) {
            availableActions.push("Go to page");
            availableActions.push("Finish");
        }

        return availableActions;
    }
});

