  }
  output += '</tbody></table></div></div></fieldset></div><div aria-hidden="true" role="tabpanel" class="tabs-pane" id="tabs-advanced"><fieldset class="advanced"><legend>' + soy.$$escapeHtml('Advanced Options') + '</legend><div class="field-group group-class"><label for="group-class">' + soy.$$escapeHtml('CSS Class') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Optional CSS Class to help with styling') + '" ></span><input type="text" title="Css Class" name="group-class" id="group-class" value="' + soy.$$escapeHtml(opt_data.cssClass) + '" class="text"/></div><div class="field-group group-style"><label for="group-style">' + soy.$$escapeHtml('CSS Style') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Optional CSS styling') + '" ></span><input type="text" title="Css Style" name="group-style" id="group-style" value="' + soy.$$escapeHtml(opt_data.cssStyle) + '" class="text"/></div><div class="field-group group-label-length"><label for="label-length">' + soy.$$escapeHtml('Group label width') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Change the width of the main group label using a pixel or % width') + '" ></span><input type="text" title="Label Length" name="label-length" id="label-length" value="' + soy.$$escapeHtml(opt_data.labelLength) + '" class="text"/></div>' + Forms.Macros.Common.fieldWidth(opt_data) + '</fieldset></div></div><button class="hiddenButton" id="hiddenButton" type="submit"></button></form></div>';
