    AJS.$('#macro-param-div-who').show();
    AJS.$('#macro-param-div-extras').show();

    extras4Label = 'Set revision as invisible timestamp';
    standardExtras4Text = 'By default revision is set as a visible timestamp formatted using your Confluence datetime formatting pattern';
    AJS.$('#macro-param-div-extras4').show();
  }
  if ('Update JIRA Issue' === choice) {
    titleLabel = 'Jira issue summary';
    whoLabel = 'Watchers';
    extrasLabel = 'Jira server to use';
    standardExtrasText = '';
    extras2Label = 'Jira Issue key';
    standardExtras2Text = 'You can reference field value using [entry.field_name]';

    AJS.$('#macro-param-div-title').hide();
    AJS.$('#macro-param-div-extras').show();
    AJS.$('#macro-param-div-extras2').show();
  }
  if ('Audit' === choice) {
    AJS.$('#macro-param-div-who').hide();
    AJS.$('#macro-param-div-title').hide();
    AJS.$('#macro-param-div-extras').hide();
    AJS.$('#macro-param-div-extras2').hide();
  }
  if ('AppLink service' === choice) {
    titleLabel = '';
    whoLabel = 'Method';
    standardWhoText = 'Should be one of valid HTTP methods: GET, POST, PUT, HEAD, DELETE';
    extrasLabel = 'AppLink to use';
    standardExtrasText = '';
    extras2Label = 'Service url';
    standardExtras2Text = 'You can reference field values using [entry.field_name] to create dynamic URLs';

    AJS.$('#macro-param-div-title').hide();
    AJS.$('#macro-param-div-extras').show();
    AJS.$('#macro-param-div-extras2').show();
  }

  if (('Create JIRA Issue' === choice) || 'Update JIRA Issue' === choice || 'AppLink service' === choice || 'Create Insight Object' === choice) {
    var paramsDivHtml = '';
    var allServices = false;
    if ('AppLink service' === choice) {
      allServices = true;
    }

    AJS.$.ajax({
      type: "POST",
      async: false,
      url: AJS.Meta.get('context-path') + "/plugins/servlet/confiform/ifttt",
      success: function (data) {
        paramsDivHtml = data;
        AJS.$('#macro-param-extras').hide();
        AJS.$(paramsDivHtml).insertAfter('#macro-param-extras');
      },
      data: jQuery.param({
        selectedJAL: AJS.$('#macro-param-extras').val(),
        allServices: allServices,
        fieldName: 'extras',
        pageId: AJS.Meta.get("page-id")
      })
    });
  }

  if ('Run JavaScript' === choice) {
    AJS.$('#macro-param-div-title').hide();
    AJS.$('#macro-param-div-who').hide();
    AJS.$('#macro-param-div-extras').hide();
    AJS.$('#macro-param-div-extras2').hide();
  }

  AJS.$('#macro-param-div-title').find('label').html(titleLabel);
  AJS.$('#macro-param-div-title').find('.macro-param-desc').html(standardTitleText);
  AJS.$('#macro-param-div-who').find('label').html(whoLabel);
  AJS.$('#macro-param-div-who').find('.macro-param-desc').html(standardWhoText);
  AJS.$('#macro-param-div-extras').find('label').html(extrasLabel);
  AJS.$('#macro-param-div-extras').find('.macro-param-desc').html(standardExtrasText);
  AJS.$('#macro-param-div-extras2').find('label').html(extras2Label);
  AJS.$('#macro-param-div-extras2').find('.macro-param-desc').html(standardExtras2Text);
  AJS.$('#macro-param-div-extras3').find('label').html(extras3Label);
  AJS.$('#macro-param-div-extras3').find('.macro-param-desc').html(standardExtras3Text);
  AJS.$('#macro-param-div-extras4').find('label').html(extras4Label);
  AJS.$('#macro-param-div-extras4').find('.macro-param-desc').html(standardExtras4Text);
  AJS.$('#macro-param-div-extras5').find('label').html(extras5Label);
  AJS.$('#macro-param-div-extras5').find('.macro-param-desc').html(standardExtras5Text);
  AJS.$('#macro-param-div-additionalContext').find('label').html(additionalContextLabel);
  AJS.$('#macro-param-div-additionalContext').find('.macro-param-desc').html(additionalContextText);
}

AJS.MacroBrowser.setMacroJsOverride("confiform-field-definition-rules", {
  fields: {
    "string": function (param, options) {
      if (param.name === "action") {
        var paramDiv = AJS.$(Confluence.Templates.MacroBrowser.macroParameterSelect());
        var select = AJS.$("select", paramDiv);
        select.append(AJS.$("<option/>").attr("value", '').html(''));
        select.append(AJS.$("<option/>").attr("value", 'Apply CSS on a field').html('Apply CSS on a field'));
        select.append(AJS.$("<option/>").attr("value", 'Apply Filter on a field').html('Apply Filter on a field'));
        select.append(AJS.$("<option/>").attr("value", 'Apply Filter based on matching criteria').html('Apply Filter based on matching criteria'));
        select.append(AJS.$("<option/>").attr("value", 'Hide field').html('Hide field'));
        select.append(AJS.$("<option/>").attr("value", 'Hide container').html('Hide container'));
        select.append(AJS.$("<option/>").attr("value", 'Lookup and set DB value').html('Lookup and set DB value'));
        select.append(AJS.$("<option/>").attr("value", 'Lookup and set WS value').html('Lookup and set WS value'));
        select.append(AJS.$("<option/>").attr("value", 'Lookup and set JIRA issue data').html('Lookup and set JIRA issue data'));
        select.append(AJS.$("<option/>").attr("value", 'Lookup and set Insight object data').html('Lookup and set Insight object data'));
        select.append(AJS.$("<option/>").attr("value", 'Lookup and set value').html('Lookup and set value'));
        select.append(AJS.$("<option/>").attr("value", 'Run custom JavaScript').html('Run custom JavaScript'));
        select.append(AJS.$("<option/>").attr("value", 'Set expression').html('Set expression'));
        select.append(AJS.$("<option/>").attr("value", 'Set field label').html('Set field label'));
        select.append(AJS.$("<option/>").attr("value", 'Set field readonly').html('Set field readonly'));
        select.append(AJS.$("<option/>").attr("value", 'Set form title').html('Set form title'));
        select.append(AJS.$("<option/>").attr("value", 'Set value').html('Set value'));
        select.append(AJS.$("<option/>").attr("value", 'Set value if empty').html('Set value if empty'));
        select.append(AJS.$("<option/>").attr("value", 'Set submit button label').html('Set submit button label'));
        select.append(AJS.$("<option/>").attr("value", 'Show field').html('Show field'));
        select.append(AJS.$("<option/>").attr("value", 'Show container').html('Show container'));
        select.append(AJS.$("<option/>").attr("value", 'Reset value').html('Reset value'));
        select.append(AJS.$("<option/>").attr("value", 'Validate if exists in other Form').html('Validate if exists in other Form'));
        select.append(AJS.$("<option/>").attr("value", 'Validate uniqueness').html('Validate uniqueness'));
        select.append(AJS.$("<option/>").attr("value", 'Validate on delete').html('Validate on delete'));
        select.append(AJS.$("<option/>").attr("value", 'Validation rule').html('Validation rule'));
        select.append(AJS.$("<option/>").attr("value", 'Validation rule dataset').html('Validation rule (dataset)'));

        select.change(function () {
          showHideParams(AJS.$(this).val());
        });

        select.css('width', '100%');
        return AJS.MacroBrowser.FieldRulesMacroField(paramDiv, select, options);
      } else if (param.name === "values2") {
        var paramDiv = AJS.$(Confluence.Templates.MacroBrowser.macroParameter());
        var input = AJS.$("input", paramDiv);
        return AJS.MacroBrowser.FieldRulesMacroField(paramDiv, input, options);
      } else {
        var paramDiv = $(Confluence.Templates.MacroBrowser.macroParameter());
        var input = $("input", paramDiv);
        if (param.required) {
          input.keyup(AJS.MacroBrowser.processRequiredParameters);
        }
        return AJS.MacroBrowser.Field(paramDiv, input, options);
      }
    }
  }
});

AJS.MacroBrowser.FieldRulesMacroField = function (paramDiv, input, options) {
  options = options || {};

  var setValue = options.setValue || function (value) {
      input.val(value);
      showHideParams(AJS.$('#macro-param-action').val());
    };

  var getValue = options.getValue || function () {
      return input.val();
    };

  input.change(options.onchange || AJS.MacroBrowser.paramChanged);

  return {
    paramDiv: paramDiv,
    input: input,
    setValue: setValue,
    getValue: getValue
  };
};

function showHideParams(choice) {
  AJS.$('#macro-param-div-values2').hide();
  AJS.$('#macro-param-div-values3').hide();
  AJS.$('#macro-param-div-withReverseRule').hide();
  AJS.$('#macro-param-div-noPropagation').hide();
  AJS.$('#extraDetails').remove();

  AJS.$('#macro-param-div-fieldName').find('label').html('Actionable field name');
  AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('Could be list of field names (comma separated) you want the action to be performed on');
  AJS.$('#macro-param-div-values').find('label').html('Values to set');
  AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Set values as key=value pairs, separated by & (as request parameters). Where "key" is field name and "value" is the value you want to set. You can use reference to other fields, via [entry.field_name] as usual');

  AJS.$('#macro-param-div-withReverseRule').find('label').html('With a reverse rule (for \'Set field readonly\' rule checking this option will unset the readonly state)');
  AJS.$('#macro-param-div-withReverseRule').find('.macro-param-desc').html('When enabled, ConfiForms will try to create a reverse rule for given rule (works with Show/Hide field/container, \'Set field readonly\' and \'Validate if exists in other Form\' rules ONLY)');

  AJS.$('#macro-param-div-noPropagation').find('label').html('No event propagation on value change');
  AJS.$('#macro-param-div-noPropagation').find('.macro-param-desc').html('You can skip propagation of change events, when a field\'\'s value has changed as a result of this action');

  if (choice == null || '' === choice) {
    AJS.$('#macro-param-div-withReverseRule').hide();
    AJS.$('#macro-param-div-noPropagation').hide();
    AJS.$('#macro-param-div-values').hide();
    AJS.$('#macro-param-div-values2').hide();
    AJS.$('#macro-param-div-fieldName').hide();
  }

  if ('Set value' === choice || 'Set value if empty' === choice || 'Set expression' === choice) {
    AJS.$('#macro-param-div-fieldName').hide();
    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-noPropagation').show();
  } else {
    if ('Show field' === choice || 'Hide field' === choice) {
      AJS.$('#macro-param-div-withReverseRule').show();

      AJS.$('#macro-param-div-values').find('label').html('Value to match');
      AJS.$('#macro-param-div-values').find('.macro-param-desc').html('If set, then only a field option holding this value is taken into action (Useful for radio/checkbox groups). You can use reference to other fields, via [entry.field_name] as usual');
      AJS.$('#macro-param-div-values').show();

      AJS.$('#macro-param-div-values2').find('label').html('Container element');
      AJS.$('#macro-param-div-values2').find('.macro-param-desc').html('CSS selector for a "container" element that shall be hidden/shown together with the field. When you are using custom layouts, you, most probably, have fields inside some HTML elements. Here you can specify a containing element (via CSS selector) which should be hidden/shown together with this field');
      AJS.$('#macro-param-div-values2').show();
    } else {
      AJS.$('#macro-param-div-values').hide();
    }
    AJS.$('#macro-param-div-fieldName').show();
  }

  if ('Hide field' === choice) {
    AJS.$('#macro-param-div-values3').find('label').html('Reset value');
    AJS.$('#macro-param-div-values3').find('.macro-param-desc').html('List of fields (comma separated) to reset the values when this rule triggers');
    AJS.$('#macro-param-div-values3').show();
    AJS.$('#macro-param-div-noPropagation').show();
  }

  if ('Show container' === choice || 'Hide container' === choice) {
    AJS.$('#macro-param-div-withReverseRule').show();

    AJS.$('#macro-param-div-fieldName').hide();
    AJS.$('#macro-param-div-values').hide();
    AJS.$('#macro-param-div-noPropagation').hide();

    AJS.$('#macro-param-div-values2').find('label').html('Container HTML element');
    AJS.$('#macro-param-div-values2').find('.macro-param-desc').html('CSS selector (or selectors as comma separated list) for a "container" HTML element that shall be hidden/shown.');
    AJS.$('#macro-param-div-values2').show();
  }

  if ('Reset value' === choice) {
    AJS.$('#macro-param-div-fieldName').show();
    AJS.$('#macro-param-div-values').hide();
    AJS.$('#macro-param-div-noPropagation').show();
  }

  if ('Validation rule' === choice || 'Validation rule dataset' === choice || 'Validate on delete' === choice) {
    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-fieldName').show();
    AJS.$('#macro-param-div-fieldName').find('label').html('Message to show when validation rule matches');
    AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('');
    AJS.$('#macro-param-div-values').find('label').html('Validation rule');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Regular Expression to use for fields input validation (when expression matches (or is EMPTY) a message will be shown)');
  }

  if ('Set submit button label' === choice) {
    AJS.$('#macro-param-div-values').hide();
    AJS.$('#macro-param-div-fieldName').show();
    AJS.$('#macro-param-div-fieldName').find('label').html('Submit button Label text');
    AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('');
  }

  if ('Set form title' === choice) {
    AJS.$('#macro-param-div-values').hide();
    AJS.$('#macro-param-div-fieldName').show();
    AJS.$('#macro-param-div-fieldName').find('label').html('Form title to set');
    AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('');
  }

  if ('Set field label' === choice) {
    AJS.$('#macro-param-div-values').find('label').html('Field label to set');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('');
    AJS.$('#macro-param-div-values').show();

    AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('');
    AJS.$('#macro-param-div-fieldName').show();

    AJS.$('#macro-param-div-noPropagation').find('label').html('Set required attribute');
    AJS.$('#macro-param-div-noPropagation').find('.macro-param-desc').html('You can set required attribute for field label');

    AJS.$('#macro-param-div-noPropagation').show();
  }

  if ('Run custom JavaScript' === choice) {
    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-fieldName').hide();
    AJS.$('#macro-param-div-values').find('label').html('JavaScript to run');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Put a valid Javascript here, which will be executed when condition is matched. You can put references to field values using [entry.field_name] and have access to variables: formName and formId (which means you can call your function, for example, like this myfunction(formName, formId))');
  }

  if ('Apply CSS on a field' === choice) {
    AJS.$('#macro-param-div-values').find('label').html('CSS styles or CSS class to apply');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Use property:value to set CSS properties, and ; as separator. To set CSS class the name of the property should be class. Example: class:myCSSClass;color:green');
    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-fieldName').show();
  }

  if ('Apply Filter on a field' === choice) {
    AJS.$('#macro-param-div-values').find('label').html('Filter to apply on a field');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Use this to filter dropdown (simple, smart or db) field choices. Filter is applied on a referenced form and dataset (or in case of DB fields on the dataset provided by SQL defined in this choices field on your form)! You can use [entry.field_name] references which are evaluated against the current record');
    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-fieldName').show();
  }

  if ('Set field readonly' === choice) {
    AJS.$('#macro-param-div-values').hide();
    AJS.$('#macro-param-div-fieldName').show();
    AJS.$('#macro-param-div-withReverseRule').show();
  }

  if ('Apply Filter based on matching criteria' === choice) {
    AJS.$('#macro-param-div-values').find('label').html('Filter to apply on a field');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Filter is applied on the form dataset below');
    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-fieldName').show();

    AJS.$('#macro-param-div-values2').find('label').html('Form and page ID separated by ":" (Example: formName:pageId)');
    AJS.$('#macro-param-div-values2').find('.macro-param-desc').html('To use for forms dataset and apply the filter on. Current form will be used as the source when left empty');
    AJS.$('#macro-param-div-values2').show();

    AJS.$('#macro-param-div-values3').find('label').html('Field to use for matching');
    AJS.$('#macro-param-div-values3').find('.macro-param-desc').html('Only the choices matching this field value will be retained in the actionable field');
    AJS.$('#macro-param-div-values3').show();

    AJS.$('#macro-param-div-noPropagation').find('label').html('Retain only unique rows on the target form');
    AJS.$('#macro-param-div-noPropagation').find('.macro-param-desc').html('When set, the automatic filter to retain only the records that don\'t exist in the current form will be applied');

    AJS.$('#macro-param-div-noPropagation').show();
  }

  if ('Lookup and set value' === choice) {
    AJS.$('#macro-param-div-values2').find('label').html('Source form name and page');
    AJS.$('#macro-param-div-values2').find('.macro-param-desc').html('Form and page ID separated by ":" (Example: formName:pageId). When left empty, current form and page will be automatically used');
    AJS.$('#macro-param-div-values').find('label').html('Lookup filter (to apply on source form)');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Context is CURRENT record. You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name]');
    AJS.$('#macro-param-div-fieldName').find('label').html('Values to set');
    AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('Context is the record you have LOOKED UP. As key=value pairs, separated by &. Where key is the field name in the form where this entry should be created/updated and value is the value to be set.  You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name]');

    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-values2').show();
    AJS.$('#macro-param-div-values3').show();
    AJS.$('#macro-param-div-fieldName').show();

    AJS.$('#macro-param-div-noPropagation').show();

    AJS.$('#macro-param-div-values2').find('label').html('Source form name and page');
    AJS.$('#macro-param-div-values2').find('.macro-param-desc').html('Form and page ID separated by ":" (Example: formName:pageId). When left empty, current form and page will be automatically used');

    AJS.$('#macro-param-div-withReverseRule').show();
    AJS.$('#macro-param-div-withReverseRule').find('label').html('Do not set \'empty\' values when lookup resulted in no results');
    AJS.$('#macro-param-div-withReverseRule').find('.macro-param-desc').html('By default, if the lookup has resulted in no results (no match) then the rule will still trigger and set the empty values');
  }

  if ('Validate uniqueness' === choice) {
    AJS.$('#macro-param-div-values').find('label').html('Field names to be used to construct unique key');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Comma separated list of field names when multiple fields should participate in the construction of a unique key');
    AJS.$('#macro-param-div-fieldName').find('label').html('Error message to show when another record with the same values exists');
    AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('');

    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-values2').hide();
    AJS.$('#macro-param-div-fieldName').show();

    AJS.$('#macro-param-div-noPropagation').find('label').html('Case insensitive search');
    AJS.$('#macro-param-div-noPropagation').find('.macro-param-desc').html('By default the search is case sensitive, as everywhere else in ConfiForms. You can force it to be case insensitive');

    AJS.$('#macro-param-div-noPropagation').show();
  }

  if ('Validate if exists in other Form' === choice) {
    AJS.$('#macro-param-div-values2').find('label').html('Source form name and page');
    AJS.$('#macro-param-div-values2').find('.macro-param-desc').html('Form and page ID separated by ":" (Example: formName:pageId). When left empty, current form and page will be automatically used');
    AJS.$('#macro-param-div-values').find('label').html('Lookup filter to use for checking (on source form)');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Context is CURRENT record. You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name]');
    AJS.$('#macro-param-div-fieldName').find('label').html('Error message to show when the record you are checking in another form DOES EXIST (or does NOT when reverse setting is on)');
    AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('Please note that if this check returns true then the record will not be saved and error message will be shown');

    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-values2').show();
    AJS.$('#macro-param-div-fieldName').show();
    AJS.$('#macro-param-div-withReverseRule').show();
  }

  if ('Lookup and set DB value' === choice) {
    AJS.$('#macro-param-div-values2').find('label').html('Datasource/connection name');
    AJS.$('#macro-param-div-values2').find('.macro-param-desc').html('');

    AJS.$.ajax({
      type: "POST",
      async: false,
      url: AJS.Meta.get('context-path') + "/plugins/servlet/confiform/dbconfig",
      success: function (data) {
        paramsDivHtml = data;
        AJS.$('#macro-param-values2').hide();
        AJS.$(paramsDivHtml).insertAfter('#macro-param-values2');
      },
      data: jQuery.param({
        selectedDBConfig: AJS.$('#macro-param-values2').val(),
        pageId: AJS.Meta.get("page-id"), fieldName: 'macro-param-values2'
      })
    });

    AJS.$('#macro-param-div-values').find('label').html('SQL SELECT query');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Context is CURRENT record. You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name]');
    AJS.$('#macro-param-div-fieldName').find('label').html('Values to set');
    AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('Context is the record you have LOOKED UP. As key=value pairs, separated by &. Where key is the field name in the form where this entry should be created/updated and value is the value to be set.  You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name]');

    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-values2').show();
    AJS.$('#macro-param-div-fieldName').show();
    AJS.$('#macro-param-div-noPropagation').show();

    AJS.$('#macro-param-div-withReverseRule').show();
    AJS.$('#macro-param-div-withReverseRule').find('label').html('Do not set \'empty\' values when lookup resulted in no results');
    AJS.$('#macro-param-div-withReverseRule').find('.macro-param-desc').html('By default, if the lookup has resulted in no results (no match) then the rule will still trigger and set the empty values');
  }

  if ('Lookup and set WS value' === choice) {
    AJS.$('#macro-param-div-values2').find('label').html('Connection name');
    AJS.$('#macro-param-div-values2').find('.macro-param-desc').html('');

    AJS.$.ajax({
      type: "POST",
      async: false,
      url: AJS.Meta.get('context-path') + "/plugins/servlet/confiform/wsconfig",
      success: function (data) {
        paramsDivHtml = data;
        AJS.$('#macro-param-values2').hide();
        AJS.$(paramsDivHtml).insertAfter('#macro-param-values2');
      },
      data: jQuery.param({
        selectedWSConfig: AJS.$('#macro-param-values2').val(),
        pageId: AJS.Meta.get("page-id"), fieldName: 'macro-param-values2'
      })
    });

    AJS.$('#macro-param-div-values').find('label').html('Service URL');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Context is CURRENT record. You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name]');
    AJS.$('#macro-param-div-fieldName').find('label').html('Values to set');
    AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('Context is the record you have LOOKED UP. As key=value pairs, separated by &. Where key is the field name in the form where this entry should be created/updated and value is the value to be set.  You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name]');

    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-values2').show();
    AJS.$('#macro-param-div-fieldName').show();
    AJS.$('#macro-param-div-noPropagation').show();

    AJS.$('#macro-param-div-withReverseRule').show();
    AJS.$('#macro-param-div-withReverseRule').find('label').html('Do not set \'empty\' values when lookup resulted in no results');
    AJS.$('#macro-param-div-withReverseRule').find('.macro-param-desc').html('By default, if the lookup has resulted in no results (no match) then the rule will still trigger and set the empty values');
  }

  if ('Lookup and set JIRA issue data' === choice) {
    AJS.$('#macro-param-div-values2').find('label').html('Application link');
    AJS.$('#macro-param-div-values2').find('.macro-param-desc').html('');

    AJS.$.ajax({
      type: "POST",
      async: false,
      url: AJS.Meta.get('context-path') + "/plugins/servlet/confiform/ifttt",
      success: function (data) {
        paramsDivHtml = data;
        AJS.$('#macro-param-values2').hide();
        AJS.$(paramsDivHtml).insertAfter('#macro-param-values2');
      },
      data: jQuery.param({
        selectedJAL: AJS.$('#macro-param-values2').val(),
        allServices: false,
        fieldName: 'values2',
        pageId: AJS.Meta.get("page-id")
      })
    });

    AJS.$('#macro-param-div-values').find('label').html('JIRA Issue Key');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Context is CURRENT record. You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name]');
    AJS.$('#macro-param-div-fieldName').find('label').html('Values to set');
    AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('Context is the JIRA issue you have LOOKED UP. As key=value pairs, separated by &. Where key is the field name in the form where this entry should be created/updated and value is the value to be set.  You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name]');

    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-values2').show();
    AJS.$('#macro-param-div-fieldName').show();
    AJS.$('#macro-param-div-noPropagation').show();
  }

  if ('Lookup and set Insight object data' === choice) {
    AJS.$('#macro-param-div-values2').find('label').html('Application link');
    AJS.$('#macro-param-div-values2').find('.macro-param-desc').html('');

    AJS.$.ajax({
      type: "POST",
      async: false,
      url: AJS.Meta.get('context-path') + "/plugins/servlet/confiform/ifttt",
      success: function (data) {
        paramsDivHtml = data;
        AJS.$('#macro-param-values2').hide();
        AJS.$(paramsDivHtml).insertAfter('#macro-param-values2');
      },
      data: jQuery.param({
        selectedJAL: AJS.$('#macro-param-values2').val(),
        allServices: false,
        fieldName: 'values2',
        pageId: AJS.Meta.get("page-id")
      })
    });

    AJS.$('#macro-param-div-values').find('label').html('Insight Object ID');
    AJS.$('#macro-param-div-values').find('.macro-param-desc').html('Context is CURRENT record. You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name]');
    AJS.$('#macro-param-div-fieldName').find('label').html('Values to set');
    AJS.$('#macro-param-div-fieldName').find('.macro-param-desc').html('Context is the Insight Object you have LOOKED UP. As key=value pairs, separated by &. Where key is the field name in the form where this entry should be created/updated and value is the value to be set.  You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name]');

    AJS.$('#macro-param-div-values').show();
    AJS.$('#macro-param-div-values2').show();
    AJS.$('#macro-param-div-fieldName').show();
    AJS.$('#macro-param-div-noPropagation').show();
  }
}

function encodeHTML1(value) {
  if (value == null) {
    return "";
  }
  return value.replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&apos;');
}


}catch(e){WRMCB(e)};
;
try {
/* module-key = 'ch.mibex.confluence.include:include-for-confluence-macro-browser', location = '/js/include.js' */
(function($) {
    function setOptionHandler(options, input) {
        options.setValue = function(value) {
            const targetOption = input.find("option[value='" + value + "']");
            if (targetOption.length === 0) {
                const option = $("<option/>");
                option.val(value);
                option.text(value);
                input.append(option);
            }
        };
    }

    var StashIncludeMacroConfig = function(args) {
        this.supportCloud = !args || args.supportCloud;
    };

    StashIncludeMacroConfig.prototype.fields = {
        "string" : {
            "applicationLink" : function(param, options) {
                const paramDiv = $(Confluence.Templates.MacroBrowser.macroParameterSelect());
                const input = $("select", paramDiv);
                if (options == null) {
                    options = {};
                }
                setOptionHandler(options, input);
                fillApplicationLinkList(input, this.supportCloud);
                return new AJS.MacroBrowser.Field(paramDiv, input, options);
            },
            "progLang" : function(param, options) {
                const paramDiv = $(Confluence.Templates.MacroBrowser.macroParameterSelect());
                const input = $("select", paramDiv);
                if (options == null) {
                    options = {};
                }
                setOptionHandler(options, input);

                $('input#macro-param-filepath').change(function() {
                    input.empty();
                    fillProgLangList(input, this.value);
                });

                return new AJS.MacroBrowser.Field(paramDiv, input, options);
            }
        }
    };

    // because these fields are handled with select2, we need to remember their initial state
    let initialProjectKey;
    let initialRepoSlug;
    let initialFilePath;
    let initialBranch;

    StashIncludeMacroConfig.prototype.beforeParamsSet = function(selectedParams, macroSelected) {
        initialFilePath = selectedParams['filepath'];
        initialBranch = selectedParams['branchId'];
        initialRepoSlug = selectedParams['repoSlug'];
        initialProjectKey = selectedParams['projectKey'];

        // this is necessary because it is a mandatory parameter that was added later to the plug-in; without setting
        // this manually, users not having this parameter configured will not see the preview when they open the macro dialog
        if (selectedParams['applicationLink'] === undefined) {
            getStashEntities("getapplinks.action?pageId=" + AJS.params.pageId, function (appLinks) {
                    if (appLinks.status === 'ERROR') {
                        showError(appLinks);
                        return;
                    }
                    $.each(appLinks, function (index, appLink) {
                        if (appLink.primary) {
                            selectedParams['applicationLink'] = appLink.id;
                        }
                    });
                },
                function (response) {
                    showError(response);
                },
                false
            );
        }
        return selectedParams;
    };

    AJS.MacroBrowser.Macros["stashincludebyfilepath"] = new StashIncludeMacroConfig();
    AJS.MacroBrowser.Macros["stashincludebyantglob"] = new StashIncludeMacroConfig({supportCloud: false});
    AJS.MacroBrowser.Macros["stashopenpullrequests"] = new StashIncludeMacroConfig();
    AJS.MacroBrowser.Macros["stashbranches"] = new StashIncludeMacroConfig();
    AJS.MacroBrowser.Macros["stashcommits"] = new StashIncludeMacroConfig();
    AJS.MacroBrowser.Macros["stashtags"] = new StashIncludeMacroConfig();
    
    function fillApplicationLinkList(dropDown, supportCloud) {
        getStashEntities("getapplinks.action?pageId=" + AJS.params.pageId, function(appLinks) {
                var currentValue = dropDown.val();
                dropDown.empty();
                dropDown.append($("<option>", {
                    value: "",
                    text: `(${"Choose application link"})`
                }));

                if (!appLinks.length) {
                    AJS.log("No Bitbucket connections found.");
                    return;
                }

                $.each(appLinks, function(index, appLink) {
                    if(supportCloud || !appLink.cloud){
                        var option = $("<option />");
                        option.val(appLink.id);
                        option.text(appLink.name);
                        dropDown.append(option);

                        if (!currentValue && appLink.primary) {
                            currentValue = appLink.id;
                        }
                    }
                });

                dropDown.val(currentValue);
                fillProjectsList($('select#macro-param-projectKey'), dropDown.val());
            },
            function(response) {
                dropDown.empty();
                showError(response);
            }, true
        );
        dropDown.off('change')
        dropDown.change(function() {
            fillProjectsList($('select#macro-param-projectKey'), dropDown.val());
        });
    }

    function fillProjectsList(dropDown, appLink) {
        const $projectKey = $('input#macro-param-projectKey');
        const getProjectsUrl = "getprojects.action?appLink=" + appLink + "&spaceKey=" + AJS.params.spaceKey + "&pageId=" + AJS.params.pageId;

        getStashEntities(getProjectsUrl, function(projects) {
            $projectKey.auiSelect2({
                placeholder: "Select a project",
                width: '100%',
                adaptContainerCssClass: function (klass) {
                    return $.trim(klass) === 'macro-param-input' ? null : klass;
                },
                formatNoMatches: function (query) {
                    return "No matching projects found";
                },
                initSelection: function (element, callback) {
                    const initialProject = _.find(projects, function (project) {
                        if (project.key === initialProjectKey) return project;
                        else return null;
                    });
                    callback({
                        id: initialProjectKey,
                        text: initialProject ? initialProject.name : null
                    });
                },
                sortResults: function (results, container, query) {
                    return _.sortBy(results, function (path) {
                        return path.text;
                    });
                },
                query: function (query) {
                    const term = cleanInput(query.term.toLowerCase());
                    const results = [];
                    for (let i = 0; i < projects.length; i++) {
                        const project = projects[i];
                        if (project.name.toLowerCase().indexOf(term) >= 0) {
                            results.push({id: project.key, text: project.name});
                        }
                    }
                    query.callback({results: results});
                }
            });
        }, function(error) {
            showError(error);
        });

        fillRepositoryList(appLink, $projectKey.val());
        $projectKey.off('change')
        $projectKey.change(function() {
            fillRepositoryList(appLink, $projectKey.val());
        });
    }

    function initAutoPreviewMacro(macroParameter) {
        const filePathParameter = document.getElementById("macro-param-filepath");
        const filePathParameterExists = document.body.contains(filePathParameter);
        const autoPreview = function () {
            if ($(this).val() || $(macroParameter).val()) {
                AJS.log("auto-preview triggered for " + $(this).val());
                $('#macro-browser-preview-link').click();
            }
            return true;
        };
        if (filePathParameterExists) {
            $('#macro-param-lineStart, #macro-param-lineEnd, #macro-param-regexMatchStart, #macro-param-regexMatchEnd, #macro-param-numMatches').blur(autoPreview);
            $('#macro-param-fileEncoding, #macro-param-progLang, #macro-param-showLineNumbers, #macro-param-collapsible, #macro-param-theme, #macro-param-hideHeader, #macro-param-antGlob').on('change', autoPreview);
            macroParameter.on('change', autoPreview);
        } else {
            $('#macro-param-numMatches').blur(autoPreview);
            macroParameter.on('change', autoPreview);
        };
    }

    function fillRepositoryList(appLink, projectKey) {
        if (!projectKey) return;
        const $repoSlug = $('input#macro-param-repoSlug');
        const repoUrl = "getrepos.action?appLink=" + appLink + "&projectKey=" + projectKey + "&pageId=" + AJS.params.pageId;
        const filePathParameter = document.getElementById("macro-param-filepath");
        const filePathParameterExists = document.body.contains(filePathParameter);
        const fileAntGlobPathParameter = document.getElementById("macro-param-antGlob");
        const fileAntGlobPathParameterExists = document.body.contains(fileAntGlobPathParameter);

        getStashEntities(repoUrl, function(repos) {
            $repoSlug.auiSelect2({
                placeholder: "Select a repository",
                width: '100%',
                adaptContainerCssClass: function(klass) {
                    return $.trim(klass) === 'macro-param-input' ? null : klass;
                },
                formatNoMatches: function(query) {
                    return "No matching repositories found";
                },
                initSelection : function(element, callback) {
                    const initialRepo = _.find(repos, function(repo) {
                        if (repo.slug === initialRepoSlug) return repo;
                        else return null;
                    });
                    callback({
                        id: initialRepoSlug,
                        text: initialRepo ? initialRepo.name : null
                    });
                },
                sortResults: function(results, container, query) {
                    return _.sortBy(results, function(path) {
                        return path.text;
                    });
                },
                query: function(query) {
                    const term = cleanInput(query.term.toLowerCase());
                    const results = [];
                    for (let i = 0; i < repos.length; i++) {
                        var repo = repos[i];
                        if (repo.name.toLowerCase().indexOf(term) >= 0) {
                            results.push({id: repo.slug, text: repo.name});
                        }
                    }
                    query.callback({results: results});
                }
            });
        }, function(error) {
            showError(error);
        });

        if (filePathParameterExists || fileAntGlobPathParameterExists){
            initBranchChooserFileMacro(appLink, projectKey, $repoSlug.val(), initialBranch);
            $repoSlug.off('change');
            $repoSlug.change(function() {
                initBranchChooserFileMacro(appLink, projectKey, $repoSlug.val(), '');
            });
        } else {
            initBranchChooserAllOtherMacros(appLink, projectKey, $repoSlug.val(), initialBranch);
            $repoSlug.change(function() {
                initBranchChooserAllOtherMacros(appLink, projectKey, $repoSlug.val(), '');
            });
            initAutoPreviewMacro($repoSlug);
        }
    }

    function formatFilePathEntry(obj) {
        if (!obj.text) return;
        const textValue = obj.text;
        const maxNumCharsToShow = 28;
        const display = document.createElement('div')
        if (textValue.length <= maxNumCharsToShow) {
            display.textContent = textValue;
        } else if (obj.abbreviation) {
            display.textContent = obj.abbreviation;
            display.setAttribute('title', obj.text)
        } else {
            display.textContent = textValue.slice(-maxNumCharsToShow + '...'.length + 1)
            display.setAttribute('title', obj.text)
        }
        return display;
    }


    function initFileChooser(appLink, projectKey, repoSlug, branchId, initialFile) {
        if (!branchId) return;

        let cache = [];
        const $filePath = $('input#macro-param-filepath');
        const $antGlobFilePath = $('input#fileAntGlobPathParameter')

        $filePath.auiSelect2({
            placeholder: "Select a file",
            width: '100%',
            adaptContainerCssClass: function(klass) {
                return $.trim(klass) === 'macro-param-input' ? null : klass;
            },
            formatNoMatches: function(query) {
                return "No matching files found";
            },
            formatResult: function(obj, container, query) {
                return formatFilePathEntry(obj);
            },
            formatSelection: function(obj, container) {
                return formatFilePathEntry(obj);
            },
            initSelection : function(element, callback) {
                callback({id: initialFile, text: initialFile});
            },
            sortResults: function(results, container, query) {
                return _.sortBy(results, function(path) {
                    return path.text;
                });
            },
            query: function(query) {
                const term = cleanInput(query.term.toLowerCase());

                if (cache.length) {
                    const results = _.filter(cache, function(path) {
                        return path.text.toLowerCase().indexOf(term) >= 0;
                    });
                    query.callback({results : results});
                    return;
                }

                var getFilePathsUrl = "getfiles.action?appLink=" + appLink + "&projectKey=" + projectKey +
                    "&repoSlug=" + repoSlug + "&branchId=" + branchId + "&pageId=" + AJS.params.pageId + "&filePath=";
                getStashEntities(getFilePathsUrl, function(filePaths) {
                    const results = [];
                    for (let i = 0; i < filePaths.length; i++) {
                        if (i % 2 === 0) { // file paths and their appreviation always come after each other
                            const path = filePaths[i];
                            if (path.toLowerCase().indexOf(term) >= 0) {
                                results.push({id: path, text: path, abbreviation: filePaths[i + 1]});
                            }
                        }
                    }
                    cache = results;
                    query.callback({results: results});
                }, function(error) {
                    // in case of timeouts, we just switch back to plain text field without showing an error
                    if (error.body && error.body.includes("Timeout") && error.body.includes("Bitbucket")) {
                        $filePath.select2('destroy');
                    } else {
                        showError(error);
                    }
                }, true);
            }
        });

        initAutoPreviewMacro($filePath);
        initAutoPreviewMacro($antGlobFilePath);
        fillProgLangList($('select#macro-param-progLang'), initialFile);
    }

    function initBranchChooserAllOtherMacros(appLink, projectKey, repoSlug, initialBranch) {
        if (!repoSlug) return;

        const branchesUrl = "getbranches.action?appLink=" + appLink + "&projectKey=" + projectKey +
            "&repoSlug=" + repoSlug + "&pageId=" + AJS.params.pageId;
        let cachedBranches = null;
        let cachedTags = null;

        // this is necessary when the default branch was different to the main branch when we didn't yet have
        // the branch correction in the URL paste logic in place; in that case, the branch is null, so we need to
        // look the default branch up here
        if (!initialBranch) {
            getStashEntities(branchesUrl, function (branches) {
                cachedBranches = branches;
                for (let i = 0; i < branches.length; i++) {
                    if (branches[i].defaultBranch) {
                        initialBranch = branches[i].id;
                        break;
                    }
                }
            }, function() {
                console.error("Failed to fetch branches");
            }, false);
        }

        const $branchChooser = $('input#macro-param-branchId');

        $branchChooser.val(initialBranch).change();

        $branchChooser.auiSelect2({
            placeholder: "Select a branch or tag",
            width: '100%',
            adaptContainerCssClass: function(klass) {
                return $.trim(klass) === 'macro-param-input' ? null : klass;
            },
            formatNoMatches: function(query) {
                return "No matching branches or tags found";
            },
            initSelection : function(element, callback) {
                callback({id: initialBranch, text: initialBranch});
            },
            sortResults: function(results, container, query) {
                return _.sortBy(results, function(path) {
                    return path.text;
                });
            },
            formatSelection: function(obj, container) {
                if (!obj.text) return;
                let selection = obj.text;
                if (selection.lastIndexOf('refs/heads/', 0) === 0) {
                    selection = selection.slice('refs/heads/'.length);
                }
                if (selection.lastIndexOf('refs/tags/', 0) === 0) {
                    selection = selection.slice('refs/tags/'.length);
                }
                let span = document.createElement('span')
                span.textContent = selection
                return span;
            },
            query: function(query) {
                const term = cleanInput(query.term.toLowerCase());
                function continueWithTags(results, tags){
                    for (let i = 0; i < tags.length; i++) {
                        if (results['tags'] === undefined) {
                            results['tags'] = {text: "tags", children:[]};
                        }
                        if (tags[i].displayId.toLowerCase().indexOf(term) >= 0) {
                            results['tags'].children.push({id: tags[i].id, text: tags[i].displayId});
                        }
                    }
                    query.callback({results: results});
                }
                function continueWithBranches(branches){
                    const results = {}
                    for (let i = 0; i < branches.length; i++) {
                        if (results['branches'] === undefined) {
                            results['branches'] = {text: "branches", children:[]};
                        }
                        if (branches[i].displayId.toLowerCase().indexOf(term) >= 0) {
                            results['branches'].children.push({id: branches[i].id, text: branches[i].displayId});
                        }
                    }
                    const tagsUrl = "gettags.action?appLink=" + appLink + "&projectKey=" + projectKey + "&repoSlug=" + repoSlug + "&pageId=" + AJS.params.pageId;

                    if(cachedTags){
                        continueWithTags(results, cachedTags)
                    } else{
                        getStashEntities(tagsUrl, function(tags) {
                            cachedTags = tags;
                            continueWithTags(results, tags)
                        }, function(error) {
                            query.callback({results: []});
                        }, true);
                    }
                }
                if(cachedBranches){
                    continueWithBranches(cachedBranches)
                } else{
                    getStashEntities(branchesUrl, function(branches) {
                        cachedBranches = branches;
                        continueWithBranches(branches);
                    }, function(error) {
                        query.callback({results: []});
                    }, true);
                }
            }
        });
        initAutoPreviewMacro($branchChooser);
    }

    function initBranchChooserFileMacro(appLink, projectKey, repoSlug, initialBranch) {
        if (!repoSlug) return;

        const branchesUrl = "getbranches.action?appLink=" + appLink + "&projectKey=" + projectKey +
            "&repoSlug=" + repoSlug + "&pageId=" + AJS.params.pageId;
        let cachedBranches = null;
        let cachedTags = null;

        // this is necessary when the default branch was different to the main branch when we didn't yet have
        // the branch correction in the URL paste logic in place; in that case, the branch is null, so we need to
        // look the default branch up here
        if (!initialBranch) {
            getStashEntities(branchesUrl, function (branches) {
                cachedBranches = branches;
                for (let i = 0; i < branches.length; i++) {
                    if (branches[i].defaultBranch) {
                        initialBranch = branches[i].id;
                        break;
                    }
                }
            }, function() {
                console.error("Failed to fetch branches");
            }, false);
        }

        const $branchChooser = $('input#macro-param-branchId');
        $branchChooser.val(initialBranch);

        $branchChooser.auiSelect2({
            placeholder: "Select a branch or tag",
            width: '100%',
            adaptContainerCssClass: function(klass) {
                return $.trim(klass) === 'macro-param-input' ? null : klass;
            },
            formatNoMatches: function(query) {
                return "No matching branches or tags found";
            },
            initSelection : function(element, callback) {
                callback({id: initialBranch, text: initialBranch});
            },
            sortResults: function(results, container, query) {
                return _.sortBy(results, function(path) {
                    return path.text;
                });
            },
            formatSelection: function(obj, container) {
                if (!obj.text) return;
                let selection = obj.text;
                if (selection.lastIndexOf('refs/heads/', 0) === 0) {
                    selection = selection.slice('refs/heads/'.length);
                }
                if (selection.lastIndexOf('refs/tags/', 0) === 0) {
                    selection = selection.slice('refs/tags/'.length);
                }
                let span = document.createElement('span')
                span.textContent = selection
                return span;
            },
            query: function(query) {
                const term = cleanInput(query.term.toLowerCase());
                function continueWithTags(results, tags){
                    for (let i = 0; i < tags.length; i++) {
                        if (results['tags'] === undefined) {
                            results['tags'] = {text:'tags', children:[]};
                        }
                        if (tags[i].displayId.toLowerCase().indexOf(term) >= 0) {
                            results['tags'].children.push({id: tags[i].id, text: tags[i].displayId});
                        }
                    }
                    query.callback({results: results});
                }
                function continueWithBranches(branches){
                    const results = {}
                    for (let i = 0; i < branches.length; i++) {
                        if (results['branches'] === undefined) {
                            results['branches'] = {text:'branches', children:[]};
                        }
                        if (branches[i].displayId.toLowerCase().indexOf(term) >= 0) {
                            results['branches'].children.push({id: branches[i].id, text: branches[i].displayId});
                        }
                    }
                    const tagsUrl = "gettags.action?appLink=" + appLink + "&projectKey=" + projectKey + "&repoSlug=" + repoSlug + "&pageId=" + AJS.params.pageId;

                    if(cachedTags){
                        continueWithTags(results, cachedTags)
                    } else{
                        getStashEntities(tagsUrl, function(tags) {
                            cachedTags = tags;
                            continueWithTags(results, tags)
                        }, function(error) {
                            query.callback({results: []});
                        }, true);
                    }
                }
                if(cachedBranches){
                    continueWithBranches(cachedBranches)
                } else{
                    getStashEntities(branchesUrl, function(branches) {
                        cachedBranches = branches;
                        continueWithBranches(branches);
                    }, function(error) {
                        query.callback({results: []});
                    }, true);
                }
            }
        });
        initFileChooser(appLink, projectKey, repoSlug, $branchChooser.val(), initialFilePath);
        $branchChooser.change(function() {
            initFileChooser(appLink, projectKey, repoSlug, $branchChooser.val(), '');
        });
    }

    function getStashEntities(entityUrl, successHandler, errorHandler, async) {
        AJS.$.ajax({
            async: async,
            url: AJS.params.contextPath + "/plugins/includeforconfluence/" + entityUrl,
            dataType: 'json',
            timeout: 10000,
            error: function(xhr, textStatus, errorThrown) {
                errorHandler(errorThrown);
            },
            success: function(response) {
                if (response.status === 'OK' && successHandler && typeof(successHandler) == 'function') {
                    successHandler(response.body);
                } else if (errorHandler && typeof(errorHandler) == 'function') {
                    errorHandler(response);
                }
            }
        });
    }

    function showError(response) {
        // Work around for Firefox. If you remove the timeout, retest with Firefox. Was implemented when Firefox is at version 100.
        // Firefox doesn't show the message this code runs directly. When running with the debugger on,
        // it tends to crash the tab. As soon as the message is shown later with a timer, it does work again
        setTimeout(function () {
            // remove old messages first
            $('#macro-browser-preview div.aui-message').remove();
            if (response.status === "ERROR") {
                AJS.messages.error('div#macro-browser-preview', {
                    title: "An error occured", body: `<p>${response.body}</p>`, closeable: false
                });
            } else if (response.status === "INFO") {
                AJS.messages.info('div#macro-browser-preview', {
                    title: "Action required", body: `<p>${response.body}</p>`, closeable: false
                });
            } else {
                AJS.messages.error('div#macro-browser-preview', {
                    title: "An error occured", body: `<p>${response.body}</p>`, closeable: false
                });
            }
        }, 16)
    }

    function fillProgLangList(dropDown, currentFile) {
        const currentValue = dropDown.val();
        dropDown.empty();
        dropDown.append($("<option>(Choose programming language)</option>").attr("value", ""));
        const progLangUrl = "getproglang.action?pageId=" + AJS.params.pageId;
        getStashEntities(progLangUrl, function(progLanguages) {
            $.each(progLanguages, function(index, progLang) {
                const option = $("<option />");
                option.val(progLang.key);
                option.text(progLang.name);
                dropDown.append(option);
            });

            if (!currentFile) return;

            if(!currentValue || currentValue === "") {
                const progLangTikaUrl = "getproglangtika.action?filePath=" + currentFile;
                getStashEntities(progLangTikaUrl, function(detectedLanguage) {
                    dropDown.val(detectedLanguage);
                });
            } else { // language has already been set
                dropDown.val(currentValue);
            }
        });
    }

})(AJS.$);

}catch(e){WRMCB(e)};
;
