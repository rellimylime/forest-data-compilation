function getRadioChoiceForStatus(id, stId) {
  var chec = '';
  if (stId == id) {
    chec = ' checked="checked" ';
  }
  return '<input style="max-width: 20px" value="' + stId + '" type="radio" class="redef_status_cl" name="redef_status"' + chec + " onclick='setStatusId(this)'/>"
}

function addOrModifyStatusEntry(id, value, whereTo) {
  var html = '<tr class="macro-param-row confluenceTr"><td class="confluenceTd">' +
    '<div><table style="width: 100%"><tr>' + getStatusChoices(id) + '</tr></table></div>' +
    '<input type="text" name="i_macro-value-input" class="text macro-param-input i_macro-value-input" size="10" style="width: 75%" value="' + myDefaultEscapeMarkup(value) + '"/>&nbsp;' +
    '<button type="button" class="aui aui-button" onclick="saveStatusEntry(this);"><span class="aui-icon aui-icon-small aui-iconfont-success cf_saveEntry" title="Save"></span></button>' +
    '</td></tr>';

  if (whereTo == null) {
    AJS.$("#i_addbox_div").before(html);
  } else {
    AJS.$(whereTo).replaceWith(html);
  }
  AJS.MacroBrowser.processRequiredParameters();
}

function addOrModifyClassifierEntry(value, whereTo) {
  var html = '<tr class="values_toStore confluenceTr"><td class="confluenceTd" colspan="2">' + myDefaultEscapeMarkup(value) + '<input type="hidden" name="i_macro-id-input" class="macro-param-input i_macro-id-input" value="' + myDefaultEscapeMarkup(value) + '"/>' +
    '<input type="hidden" name="i_macro-value-input" class="macro-param-input i_macro-value-input" value="' + myDefaultEscapeMarkup(value) + '"/>&nbsp;' +
    '<button type="button" class="aui aui-button" onclick="removeClassifierEntry(this);"><span class="aui-icon aui-icon-small aui-iconfont-remove" title="Remove"></span></button>' +
    '</td></tr>';

  if (whereTo == null) {
    AJS.$("#i_addbox_div").before(html);
  } else {
    AJS.$(whereTo).replaceWith(html);
  }
  setClassifierValues();
}

function setClassifierValues() {
  var params = '[' + AJS.$('#pageIdParamInput').val() + ':' + AJS.$('#formNameParamInput').val() + ']';
  AJS.$("#paramTable tr.values_toStore").each(function () {
    params = params + AJS.$(this).find('.i_macro-value-input').val() + ',';
  });
  AJS.$('#macro-param-values').val(params);
  AJS.MacroBrowser.processRequiredParameters();
}

function addOrModifyEntry(id, value, whereTo) {
  var html = '<tr class="macro-param-row confluenceTr"><td class="confluenceTd" style="vertical-align: top">' +
    '<input type="text" name="i_macro-id-input" class="text macro-param-input i_macro-id-input" maxlength="50" size="5" style="width:100%" value="' + id + '"/>' +
    '</td><td class="">' +
    '<input type="text" name="i_macro-value-input" class="text macro-param-input i_macro-value-input" size="10" style="width: 100%" value="' + value + '"/>' +
    '<button type="button" class="aui aui-button" onclick="saveEntry(this);"><span class="aui-icon aui-icon-small aui-iconfont-success cf_saveEntry" title="Save"></span></button>' +
    '</td></tr>';

  if (whereTo == null) {
    AJS.$("#i_addbox_div").before(html);
  } else {
    AJS.$(whereTo).replaceWith(html);
  }
  AJS.MacroBrowser.processRequiredParameters();
}

