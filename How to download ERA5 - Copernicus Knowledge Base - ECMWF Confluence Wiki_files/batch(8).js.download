try {
/* module-key = 'ch.mibex.confluence.ipython-notebook:autoconvert-ipython-bitbucket-links', location = 'js/ipython-bitbucket-link-paste-support.js' */
define('mibexsoftware/paste-ipython-bitbucket-link', [
    'ajs',
    'tinymce'
], function(
    AJS,
    tinymce
) {
    'use strict';

    var IpynbUrlPasteLink = {
        pasteHandler: function(uri, node, done) {
            var urlDecoded = decodeURIComponent(uri.source);
            var bitbucketFileDetails = parseBitbucketFileUrl(urlDecoded);
            if (bitbucketFileDetails) {
                var appLinkId = IpynbUrlPasteLink.lookUpApplicationLinkId(urlDecoded);
                var macro = {
                    name: 'ipython',
                    params: {
                        applicationLink: appLinkId,
                        projectKey: bitbucketFileDetails.projectKey,
                        repoSlug: bitbucketFileDetails.repoSlug,
                        filepath: bitbucketFileDetails.filepath,
                        branchId: bitbucketFileDetails.branchId ? bitbucketFileDetails.branchId
                            : IpynbUrlPasteLink.lookUpDefaultBranch(appLinkId, bitbucketFileDetails.projectKey, bitbucketFileDetails.repoSlug),
                        lineStart: bitbucketFileDetails.lineStart,
                        lineEnd: bitbucketFileDetails.lineEnd
                    }
                };
                tinymce.plugins.Autoconvert.convertMacroToDom(macro, done);
            } else if (isIPythonFileUrl(urlDecoded)) {
                var macro = {
                    name: 'ipython',
                    params: {
                        notebookUrl: urlDecoded
                    }
                }
                tinymce.plugins.Autoconvert.convertMacroToDom(macro, done);
            } else {
                done();
            }
        },

        lookUpDefaultBranch: function(appLink, projectKey, repoSlug) {
            var branchesUrl = "getbranches.action?appLink=" + appLink + "&projectKey=" + projectKey +
                "&repoSlug=" + repoSlug + "&pageId=" + AJS.params.pageId;
            var defaultBranch = null;
            AJS.$.ajax({
                async: false,
                url: AJS.params.contextPath + '/plugins/ipython/' + branchesUrl,
                dataType: 'json',
                timeout: 5000,
                error: function(xhr, textStatus, errorThrown) {
                    console.error(errorThrown);
                    defaultBranch = 'master';
                },
                success: function(response) {
                    if (response.status === 'OK') {
                        for (var i = 0; i < response.body.length; i++) {
                            if (response.body[i].defaultBranch) {
                                defaultBranch = response.body[i].id;
                            }
                        }
                    }
                }
            });
            return defaultBranch;
        },

        lookUpApplicationLinkId: function(url) {
            var applicationLinkId = null;
            AJS.$.ajax({
                async: false,
                url: AJS.params.contextPath + '/plugins/ipython/getapplinkbyurl.action?url=' + encodeURIComponent(url),
                dataType: 'json',
                timeout: 5000,
                error: function(xhr, textStatus, errorThrown) {
                    console.error(errorThrown);
                },
                success: function(response) {
                    if (response.status === 'OK') {
                        applicationLinkId = response.body;
                    }
                }
            });
            return applicationLinkId;
        }
    };

    return IpynbUrlPasteLink;
});

require('confluence/module-exporter').safeRequire('mibexsoftware/paste-ipython-bitbucket-link', function(IpynbUrlPasteLink) {
    var tinymce = require('tinymce');
    var AJS = require('ajs');

    AJS.bind('init.rte', function() {
        tinymce.plugins.Autoconvert.autoConvert.addHandler(IpynbUrlPasteLink.pasteHandler);
    });
});

function isIPythonFileUrl(url) {
    var ipythonFileUrlEx = /^https:\/\/[-a-zA-Z0-9@:%._+~#=]{1,256}\.[a-zA-Z0-9()]{1,6}\b([-a-zA-Z0-9()@:%_+.~#?&//=]*)[.](ipynb)/g;
    var ipythonFileUrl = ipythonFileUrlEx.exec(url);
    return ipythonFileUrl !== null;
}

function parseBitbucketFileUrl(url) {
    // BITBUCKET_HOST/projects/PROJECT_KEY/repos/REPO_SLUG/browse/FILEPATH?at=BRANCH#LINE_START-LINE_END
    var bitbucketUrlEx = /.*?\/projects\/([^/]+)\/repos\/([^/]+)\/(?:browse|raw)\/(.*?)(\?at=.*?)?#?(\d+)?-?(\d+)?$/;
    var parts = bitbucketUrlEx.exec(url);
    if (!parts) {
        return null;
    }
    return {
        projectKey: parts[1],
        repoSlug: parts[2],
        filepath: parts[3],
        branchId: parts[4] ? parts[4].substring("?at=".length) : null,
        lineStart: parts[5],
        lineEnd: parts[6] ? parts[6] : parts[5]
    };
}

// outside the browser, export functions for testing
const isBrowser = typeof window !== 'undefined' && typeof window.document !== 'undefined';
if(!isBrowser){
    exports.parseBitbucketFileUrl = parseBitbucketFileUrl;
    exports.isIPythonFileUrl = isIPythonFileUrl;
}
}catch(e){WRMCB(e)};
;
