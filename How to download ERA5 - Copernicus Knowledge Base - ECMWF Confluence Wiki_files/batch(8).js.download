try {
/* module-key = 'com.adaptavist.confluence.formMailNG:responses-table-config-resource', location = 'js/forms/config/responses-table-config.js' */
AJS.toInit(function ($) {

    function setformIdFromSelect2Value(formId) {
        if (formId) {
            AJS.$("#macro-param-formId").val(formId).trigger("change");
        }
    }

    AJS.MacroBrowser.setMacroJsOverride("responses-table", {
        "fields": {
            "string": {
                "formId": function () {
                    var paramDiv = $(Confluence.Templates.MacroBrowser.macroParameter()),
                        $select = $('<input/>').appendTo(paramDiv);

                    $select.attr("id", "macro-param-formId").attr("multiple", true);

                    var $input = $('<input type="hidden"/>').appendTo(paramDiv);

                    $select.on("change", function () {
                        $input.val($(this).val());
                        $input.trigger("change");
                    });
                    return AJS.MacroBrowser.Field(paramDiv, $input, {});
                }
            }
        },
        "beforeParamsSet": function (selectedParams) {
            AJS.$("#macro-param-div-formId input").first().hide();
            AJS.$("#macro-param-formId").auiSelect2({
                placeholder: "Please enter a Form ID",
                maximumSelectionSize: 1,
                tags: true,

                initSelection: function (element, callback) {
                    callback({
                        id: element.val(),
                        text: element.val()
                    });
                },

                ajax: {
                    url: AJS.Meta.get("context-path") + '/rest/formservice/1.0/configs/formmail/searchformconfigs/?spaceKey=' + AJS.params.spaceKey,
                    dataType: 'json',
                    type: "GET",
                    quietMillis: 250,
                    data: function (term) {
                        return {
                            queryName: term
                        };
                    },
                    results: function (data) {
                        return {
                            results: $.map(data, function (item) {
                                return {
                                    id: item.idAsString,
                                    name: item.name,
                                    text: item.name
                                };
                            })
                        };
                    }
                }
            });
            setformIdFromSelect2Value(selectedParams.formId);
            return selectedParams;
        },
        "beforeParamsRetrieved": function (selectedParams) {

            $(".select2-search-choice-close").each(function () {
                var events = $(this).data("events");
                if (events) {
                    events.click.splice(1, 1);
                }
            });

            return selectedParams;
        }
    });
});
}catch(e){WRMCB(e)};
;
