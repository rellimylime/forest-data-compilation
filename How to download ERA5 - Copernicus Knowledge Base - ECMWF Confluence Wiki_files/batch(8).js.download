'use strict';

(function($) {
    
    //constants
    const DELIMITER = ",";
    const QUOTE = "'";
    
    AJS.bind("init.rte", function(evt) {
        
        //This is default param list for run-now macro
        const runNowDefaultParameters = {
            id: "",
            replace: [],
            dateFormat: "",
            requestPrefix: "@default",
            requestAction: "",
            keepRequestParameters: false,
            keepRequestIds: ""
        };
        
        appcme.setMacroJsOverride('run-now', runNowDefaultParameters, function(macroDetails) {
            
            // merge specific ones with runNowDefaultParameters.
            var parms = appcme.parametersToObj(runNowDefaultParameters, macroDetails.params, DELIMITER, QUOTE);
            
            // Remove empty replace elements from the list.
            parms.replace = appfire.run.removeEmptyFields(parms.replace);
            
            $.extend(parms, { macroName: macroDetails.name, contextPath: AJS.contextPath() }); 
            
            return {
                icon: appcme.absolutePath("/download/resources/org.swift.confluence.run/img/get-started.png"),
                title: "Run Self-Service Reports - Run-now Macro",
                showPreview: true,
                navigation: {
                    primary: [
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.run/img/icon-field-settings-48-wht-on-clr.png"),
                            name: "Field settings",
                            panel: org.swift.confluence.run.editor.fieldSettingsPanel(parms)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.run/img/icon-run-settings-48-wht-on-clr.png"),
                            name: "Run settings",
                            panel: org.swift.confluence.run.editor.runSettingsPanel(parms)
                        }
                    ],
                    secondary: [
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/editor/img/icon-nav-guide-48-wht-on-clr.png"),
                            name: "Run Self-Service Reports User Guide",
                            url: "https://bobswift.atlassian.net/wiki/x/dwBNAQ"
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/editor/img/icon-nav-docs-48-wht-on-clr.png"),
                            name: "Run Self-Service Reports Documentation",
                            url: "https://bobswift.atlassian.net/wiki/x/D4CB"
                        }
                    ]
                },
                /**
                 * Validate form fields. 
                 * Input Parameters:
                 *      dialog - The jQuery editor dialog 
                 *      form - The jQuery form from the dialog 
                 * Return Parameters:
                 *      errors - This is a property array.  Each array element contains the message and an optinal jQuery element for the error.  
                 * Return: 
                 *      True if the form validates correctly and can be saved. False if there are any errors. The form will not be allowed to close in that case. 
                 */
                validator: function (dialog, form, errors) {
                    return validateFormFields(errors, form);
                }
            };
        });

        //This is default param list for run macro
        const runDefaultParameters = {
            autoRun: false,
            autoExport: false,
            hideParameters: false,
            hideColumnHeadings: false,
            hideRun: false,
            hideExport: true,
            showReset: false,
            showClear: false,
            showKey: false,
            showMore: false,
            help: "",
            anchor: "",
            focus: "",
            heading: "",
            prompt: "",
            titleRun: "",
            titleReset: "",
            titleClear: "",
            titleExport: "",
            titleExportFile: "",
            titleAttachmentComment: "",
            attachmentComment: "",
            exportFile: "",
            exportVersion: "new",
            encoding: "",
            width: "",
            inputSize: "",
            buttonPadding: 4,
            suppressQuote: false,
            parameterInput: "",
            disableAntiXss: false
        };
    
        $.extend(runDefaultParameters, runNowDefaultParameters);
        
        appcme.setMacroJsOverride('run', runDefaultParameters, function(macroDetails) {
    
            // merge specific ones with runDefaultParameters.
            var parms = appcme.parametersToObj(runDefaultParameters, macroDetails.params, DELIMITER, QUOTE);
            
            // Remove empty replace elements from the list.
            parms.replace = appfire.run.removeEmptyFields(parms.replace);
            
            $.extend(parms, { macroName: macroDetails.name, contextPath: AJS.contextPath() }); 
            
            return {
                icon: appcme.absolutePath("/download/resources/org.swift.confluence.run/img/get-started.png"),
                title: "Run Self-Service Reports - Run Macro",
                showPreview: true,
                navigation: {
                    primary: [
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.run/img/icon-field-settings-48-wht-on-clr.png"),
                            name: "Field settings",
                            panel: org.swift.confluence.run.editor.fieldSettingsPanel(parms)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.run/img/icon-display-settings-48-wht-on-clr.png"),
                            name: "Display settings",
                            panel: org.swift.confluence.run.editor.displaySettingsPanel(parms)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.run/img/icon-run-settings-48-wht-on-clr.png"),
                            name: "Run settings",
                            panel: org.swift.confluence.run.editor.runSettingsPanel(parms)
                        }
                    ],
                    secondary: [
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/editor/img/icon-nav-guide-48-wht-on-clr.png"),
                            name: "Run Self-Service Reports User Guide",
                            url: "https://bobswift.atlassian.net/wiki/x/dwBNAQ"
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/editor/img/icon-nav-docs-48-wht-on-clr.png"),
                            name: "Run Self-Service Reports Documentation",
                            url: "https://bobswift.atlassian.net/wiki/x/D4CB"
                        }
                    ]
                },
                /**
                 * Validate form fields. 
                 * Input Parameters:
                 *      dialog - The jQuery editor dialog 
                 *      form - The jQuery form from the dialog 
                 * Return Parameters:
                 *      errors - This is a property array.  Each array element contains the message and an optinal jQuery element for the error.  
                 * Return: 
                 *      True if the form validates correctly and can be saved. False if there are any errors. The form will not be allowed to close in that case. 
                 */
                validator: function (dialog, form, errors) {
                    return validateFormFields(errors, form);
                }
            };
        });
    });
    
    //Handler code
    $(document).on('appfireEditorBeforeSave appfireEditorBeforePreview', "[data-appfire-macro-name='run'], [data-appfire-macro-name='run-now']", function(evt, parms, dialog, form, defaultParms) {
        //delete the "non-macro" parameters from your form
        for (var key in parms) {
            if (key.startsWith("field-") && !defaultParms.hasOwnProperty(key)) {
                delete parms[key];
            }
        }
        
        //RUN-294: Reverse values of parameters which prompt is changed from "hide" to "show" without changing underlying parameter name.
        var hideParamsList = ["hideParameters", "hideColumnHeadings", "hideRun", "hideExport"];
        AJS.$.each(hideParamsList, function (index, paramName) {
            appfire.run.invertBooleanParamValue(parms, defaultParms[paramName], paramName);
        });
    });    
    
    $(document).on('appfireEditorBeforeSerialize appfireEditorBeforePreviewSerialize', "[data-appfire-macro-name='run'], [data-appfire-macro-name='run-now']", 
        function(evt, dialog, form, defaultParms, errors) {
        
        $("#run-form-fields").find(".appfire-row").each(function(index, row) {
            var rowData = $(row).find(".row-data");
            
            var fieldType = rowData.find("select[name='field-type']").val();
            var fieldName = rowData.find("input[name='field-name']").val();
            var fieldValue = rowData.find("input[name='field-value']").val();
            var fieldDescr = rowData.find("input[name='field-description']").val();
            
            var isRequired = rowData.find("aui-toggle[name='field-required']").prop('checked');
            
            var isDisabled = rowData.find("aui-toggle[name='field-disabled']").prop('checked');
            var isMore = rowData.find("aui-toggle[name='field-more']").prop('checked');
            var isEnd = rowData.find("aui-toggle[name='field-groupend']").prop('checked');
            var validateFlag = rowData.find("aui-toggle[name='field-validate']").prop('checked');
            var regex = rowData.find("input[name='field-regex']").val();
            var errorMsg = rowData.find("input[name='field-errormsg']").val();
            var helpText = rowData.find("input[name='field-helptext']").val();
            
            regex = encodeURIComponent(regex);
            
            if (fieldType) {
                var fieldTypeWithQualifier = appfire.run.prepareFieldType(fieldType, isRequired, isDisabled, isEnd, isMore);
                var moreParams = [];
                switch (fieldType) {
                    case '' : 
                    case 'text' : 
                    case 'password' : 
                        var inputSize = rowData.find("input[name='field-inputsize']").val();
                        if (inputSize) {
                            moreParams.push(inputSize);
                        }
                        if (validateFlag || regex || errorMsg || helpText ) {
                            if (!inputSize) {
                                moreParams.push("");
                            }
                            pushValidationParams(moreParams, validateFlag, regex, errorMsg, helpText);
                        }
                        break;
                    case 'textarea' : 
                        var numberOfRows = rowData.find("input[name='field-rows']").val();
                        var numberOfColumns = rowData.find("input[name='field-columns']").val();
                        if (numberOfRows) {
                            moreParams.push(numberOfRows);
                        }
                        if (numberOfColumns) {
                            if (!numberOfRows) {
                                moreParams.push("");
                            }
                            moreParams.push(numberOfColumns);
                        }
                        
                        if (validateFlag || regex || errorMsg || helpText ) {
                            if (!numberOfColumns) {
                                moreParams.push("");
                                if (!numberOfRows) {
                                    moreParams.push("");
                                }
                            }
                            pushValidationParams(moreParams, validateFlag, regex, errorMsg, helpText);
                        }
                        break;
                    case 'radio' : 
                    case 'checkbox' : 
                    case 'select' : 
                    case 'select-multi' :
                        var numberOfRows;
                        if (fieldType == 'radio' || fieldType == 'checkbox') {
                            numberOfRows = rowData.find("input[name='field-non-select-options-display']").val();
                        } else {
                            numberOfRows = rowData.find("input[name='field-select-options-display']").val();
                        }
                        
                        var selectOptions = rowData.find(".value-text-table").children();
                        if (numberOfRows) {
                            moreParams.push(numberOfRows);
                        }
                        //Checking whether there are any options added for radio/checkbox/select/select-multi
                        //Considering only non-empty values if there is one value-text row to avoid additional colons in replace parameter. 
                        //if there are more than one, continue to add options without checking anything.
                        
                        if (selectOptions.length > 1 || isFirstOptionNotEmpty(selectOptions)) {
                            if (!numberOfRows) {
                                moreParams.push("");
                            }
                            selectOptions.each(function(index, row) {
                                moreParams.push($(row).find("input[name='field-option-value']").val());
                                moreParams.push($(row).find("input[name='field-option-text']").val());
                            });
                        }
                        break;
                    case 'dynamic-select' :
                    case 'dynamic-selectmulti' :
                        var numberOfRows = rowData.find("input[name='field-select-options-display']").val();
                        
                        if (numberOfRows) {
                            moreParams.push(numberOfRows);
                        }else{
                        moreParams.push("");//no of rows as empty
                        }
                        var sqlDS = rowData.find("input[name='field-dynamic-select-ds']").val();
                        var query = rowData.find("textarea[name='field-dynamic-select-query']").val();
                        moreParams.push(encodeURIComponent(sqlDS));
                        moreParams.push(encodeURIComponent(query));
                        break;
                    case 'float' : 
                    case 'integer' :
                        var lowerbound = rowData.find("input[name='field-lowerbound']").val();
                        var upperbound = rowData.find("input[name='field-upperbound']").val();
                        if (lowerbound) {
                            moreParams.push(lowerbound);
                        }
                        if (upperbound) {
                            if (!lowerbound) {
                                moreParams.push("");
                            }
                            moreParams.push(upperbound);
                        }
                        if (validateFlag || regex || errorMsg || helpText ) {
                            if (!upperbound) {
                                moreParams.push("");
                                if (!lowerbound) {
                                    moreParams.push("");
                                }
                            }
                            pushValidationParams(moreParams, validateFlag, regex, errorMsg, helpText);
                        }
                        break;
                    case 'integer-select' : 
                        var lowerbound = rowData.find("input[name='field-lowerbound']").val();
                        var upperbound = null;
                        if (fieldType == 'integer-select')  {
                            upperbound = rowData.find("input[name='field-intselect-upperbound']").val();
                        } else {
                            upperbound = rowData.find("input[name='field-upperbound']").val();
                        }
                        if (lowerbound) {
                            moreParams.push(lowerbound);
                        }
                        if (upperbound) {
                            if (!lowerbound) {
                                moreParams.push("");
                            }
                            moreParams.push(upperbound);
                        }
                        break;
                    case 'date' : 
                        var lowerbound = rowData.find("input[name='field-lowerbound']").val();
                        var upperbound = rowData.find("input[name='field-upperbound']").val();
                        var dateformat = rowData.find("input[name='field-dateformat']").val();
                        if (lowerbound) {
                            moreParams.push(lowerbound);
                        }
                        if (upperbound) {
                            if (!lowerbound) {
                                moreParams.push("");
                            }
                            moreParams.push(upperbound);
                        }
                        if (dateformat) {
                            if (!upperbound) {
                                if (!lowerbound) {
                                    moreParams.push("");
                                }
                                moreParams.push("");
                            }
                            moreParams.push(dateformat);
                        }
                        if (validateFlag || regex || errorMsg || helpText ) {
                            if (!dateformat) {
                                moreParams.push("");
                                if (!upperbound) {
                                    moreParams.push("");
                                    if (!lowerbound) {
                                        moreParams.push("");
                                    }
                                }
                            }
                            pushValidationParams(moreParams, validateFlag, regex, errorMsg, helpText);
                        }
                        break;
                    case 'output' : 
                    case 'hidden' : 
                        break;
                    case 'group' : 
                        var width = rowData.find("input[name='field-width']").val();
                        if (width) {
                            moreParams.push(width);
                        }
                        break;
                    default:
                }
    
                var replaceFieldValue = appfire.run.prepareReplace(fieldTypeWithQualifier, fieldName, fieldValue, fieldDescr, moreParams);
                
                //Each row has an input element named replace, to hold entire replace field before splitting into multiple parts and assign them to separate input fields.
                rowData.find("input[name='replace']").val(replaceFieldValue);
            }
        });
    });
    
    
    // this is how we'd listen for events to hook up interactions on each panel
    $(document).on('appfireEditorBeforeShow', "[data-appfire-macro-name='run'], [data-appfire-macro-name='run-now']", function(evt, editor) {

         // Add template row for fields row grid
         var $row = $(org.swift.confluence.run.editor.fieldSettingsRow({position: 0, replace: "", contextPath: AJS.contextPath() }));
         $("#run-form-fields").data("masterGridRow", $row);
         
         //Split replace fields list and set it to different controls
         $("#run-form-fields").find(".appfire-row").each(function(index, row) {
             
             var rowData = $(row).find(".row-data");
             var replaceValue = rowData.find("input[name='replace']").val();
             
             //Refer below doc link for more details on each position in replace string.
             //https://bobswift.atlassian.net/wiki/spaces/RUN/pages/58950143/Field+types
             
             //A comma separated list of field descriptions. Any entry containing a comma (,) or colon (\:) must be enclosed in single quotes (') - example: x:1:'It''s an example: 1, 2, or 3'.
             var fieldsList = appcme.split(replaceValue, ":", "'");
             var replaceObject = appfire.run.replaceStringToObject(fieldsList);
             
             var fieldType = replaceObject.fieldType;
             rowData.find("input[name='field-name']").val(replaceObject.fieldName);
             rowData.find("input[name='field-value']").val(replaceObject.fieldValue);
             rowData.find("input[name='field-description']").val(replaceObject.fieldDesc);
             
             var typeQualifier = replaceObject.typeQualifier;
             
             if (typeQualifier.includes("-required")) {
                 rowData.find("aui-toggle[name='field-required']").attr('checked', true);
             }
             
             if (typeQualifier.includes("-disabled")) {
                 rowData.find("aui-toggle[name='field-disabled']").attr('checked', true);
             }
             
             if (typeQualifier.includes("-more")) {
                 rowData.find("aui-toggle[name='field-more']").attr('checked', true);
             }
             
             if (typeQualifier.includes("-end")) {
                 rowData.find("aui-toggle[name='field-groupend']").attr('checked', true);
             }
             
             //First 4 positions are fixed in replace string.
             //Switch statement is used to consider different settings based on fieldType from 5th position.
             switch (fieldType) {
                 //if fieldType is "text" or "password", inputSize can be found in 5th position.
                 //Note: Empty fieldType is equivalent to "text"
                 case '' :
                 case 'text' : 
                 case 'password' : 
                     if (fieldsList.length > 4) {
                         rowData.find("input[name='field-inputsize']").val(fieldsList[4]);
                         //Set the validation row elements
                         setValidationRowElements(rowData, fieldsList, 5);
                     }
                     break;
                 //if fieldType is "textarea", number of rows and columns can be found in 5th and 6th positions.
                 case 'textarea' : 
                     if (fieldsList.length > 4) {
                         rowData.find("input[name='field-rows']").val(fieldsList[4]);
                     }
                     if (fieldsList.length > 5) {
                         rowData.find("input[name='field-columns']").val(fieldsList[5]);
                     }
                     //Set the validation row elements
                     setValidationRowElements(rowData, fieldsList, 6);
                     break;
                 case 'radio' : 
                 case 'checkbox' : 
                 case 'select' : 
                 case 'select-multi' :
                     if (fieldsList.length > 4) {
                         if (fieldType == 'radio' || fieldType == 'checkbox') {
                             rowData.find("input[name='field-non-select-options-display']").val(fieldsList[4]);
                         } else {
                             rowData.find("input[name='field-select-options-display']").val(fieldsList[4]);
                         }
                     }
                     
                     if (fieldsList.length > 5) {
                         var optionsTable = rowData.find(".value-text-table");
                         var firstRow = optionsTable.children(':first');
                         firstRow.find("input[name='field-option-value']").val(appfire.run.removeEnclosedQuotes(fieldsList[5]));
                         firstRow.find("input[name='field-option-text']").val(appfire.run.removeEnclosedQuotes(fieldsList[6]));
                         for (var i = 7; i < fieldsList.length; i++) {
                             addSelectOptionsRow(optionsTable, appfire.run.removeEnclosedQuotes(fieldsList[i]), appfire.run.removeEnclosedQuotes(fieldsList[++i]));
                         }
                     }
                     break;
                 case 'dynamic-select' :
                 case 'dynamic-selectmulti' :
                     if (fieldsList.length > 4) {
                             rowData.find("input[name='field-select-options-display']").val(fieldsList[4]);
                     }
                     
                   //fieldsList[5] = DSProfie 
                   //fieldsList[6] = SQL query 
                     rowData.find("input[name='field-dynamic-select-ds']").val(decodeURIComponent(fieldsList[5]));
                     rowData.find("textarea[name='field-dynamic-select-query']").val(decodeURIComponent(fieldsList[6])); 
                     
                     // load datasource profiles
                     getDataSourceProfiles(rowData, decodeURIComponent(fieldsList[5]));
                     break;
                 case 'float' : 
                 case 'integer' : 
                     if (fieldsList.length > 4) {
                         rowData.find("input[name='field-lowerbound']").val(fieldsList[4]);
                     }
                     if (fieldsList.length > 5) {
                         rowData.find("input[name='field-upperbound']").val(fieldsList[5]);
                     }
                     //Set the validation row elements
                     setValidationRowElements(rowData, fieldsList, 6);
                     break;
                 case 'integer-select' : 
                     if (fieldsList.length > 4) {
                         rowData.find("input[name='field-lowerbound']").val(fieldsList[4]);
                     }
                     if (fieldsList.length > 5) {
                         if (fieldType == 'integer-select')  {
                             rowData.find("input[name='field-intselect-upperbound']").val(fieldsList[5]);
                         } else {
                             rowData.find("input[name='field-upperbound']").val(fieldsList[5]);
                         }
                     }
                     break;
                 case 'date' : 
                     if (fieldsList.length > 4) {
                         rowData.find("input[name='field-lowerbound']").val(appfire.run.removeEnclosedQuotes(fieldsList[4]));
                     }
                     if (fieldsList.length > 5) {
                         rowData.find("input[name='field-upperbound']").val(appfire.run.removeEnclosedQuotes(fieldsList[5]));
                     }
                     if (fieldsList.length > 6) {
                         rowData.find("input[name='field-dateformat']").val(appfire.run.removeEnclosedQuotes(fieldsList[6]));
                     }
                     //Set the validation row elements
                     setValidationRowElements(rowData, fieldsList, 7);
                     break;
                 case 'output' : 
                 case 'hidden' : 
                     break;
                 case 'group' : 
                     updateFieldRowToGroupRow($(row));
                     if (fieldsList.length > 4) {
                         rowData.find("input[name='field-width']").val(fieldsList[4]);
                     }
                     break;
                 default:
                     //setting back to default type.
                     fieldType = 'text';
                     break;
             }
             rowData.find("select[name='field-type']").val(fieldType);
             
             //To show images for field type select
             convertFieldTypeToSelect2(rowData);
             
             //show or hide dynamic elements based on field type.
             updateFieldRowByFieldType(fieldType, rowData);
         });
         //update group sequences
         updateFieldGroupSequence();
    });
    
    $(document).on('appfireEditorGridAddRowBeforeShow', "[data-appfire-macro-name='run'], [data-appfire-macro-name='run-now']", function(evt, newRow) {

        var rowData = newRow.find(".row-data");
        
        //To show images for field type select
        convertFieldTypeToSelect2(rowData);
        
        //Update unique ids of help icon inline dialog
        updateInlineDialogUniqueId(rowData);
        
        //Show required elements based on type.
        var fieldType = rowData.find("select[name='field-type']").val();
        updateFieldRowByFieldType(fieldType, rowData);
    });
    
    $(document).on('appfireEditorGridAddRowAfterShow', "[data-appfire-macro-name='run'], [data-appfire-macro-name='run-now']", function(evt, newRow) {

        var $grid = $("#run-form-fields");
        $grid.siblings(".fields-grid-bar-buttons").show();
        $grid.find(".fields-grid-empty-state").hide(); 
        
        //update group sequence.
        updateFieldGroupSequence();
        
        //scroll to newly added row and focus on first input element.
        appcme.scrollAndFocusToNewRow($grid, newRow);
    });
    
    $(document).on('appfireEditorGridDeleteRow', "[data-appfire-macro-name='run'], [data-appfire-macro-name='run-now']", function(evt, deletedRow) {
        //update group sequence.
        updateFieldGroupSequence();
    });
    
    $(document).on('appfireEditorGridMoveRowUp appfireEditorGridMoveRowDown', "[data-appfire-macro-name='run'], [data-appfire-macro-name='run-now']", function(evt, currentRow) {
        //update group sequence.
        updateFieldGroupSequence();
    });

    $(document).on("change", "aui-toggle[name='field-validate']", function(event) {
        //disable validate row elements.
        setVisibilityValidateRowElements($(this));
    });
    
    //To update field/group sequence when end group is changed.
    $(document).on("change", "aui-toggle[name='field-groupend']", function(event) {
        //update group sequence.
        updateFieldGroupSequence();
    });
    
    //To add group field
    $(document).on("click", ".add-group-row", function(event) {
        var $grid = $("#run-form-fields");
        addGroupField($grid);
        return false;
    });
    
    $(document).on("click", ".add-first-field", function(event) {
        var $grid = $("#run-form-fields");
        addGroupField($grid);
        $(".add-grid-row").trigger('click');
        appcme.scrollAndFocusToFirstRow($grid);
        return false;
    });
    
    $(document).on("change", "select[name='field-type']", function(event) {
        var rowData = $(this).closest(".row-data");
        updateFieldRowByFieldType(this.value, rowData);
        if(this.value.includes('dynamic')){
            getDataSourceProfiles(rowData, '');
        }
    });
    
    $(document).on("click", ".add-option-btn", function (event) {
        var optionsTable = $(this).closest(".fields-row-options").find(".value-text-table");
        addSelectOptionsRow(optionsTable);
        return false;
    });
    
    $(document).on("click", ".remove-option-btn", function (event) {
        var optionsRow = $(this).closest(".value-text-row");
        var optionsTable = optionsRow.closest(".value-text-table");
        if (optionsTable.children().length > 1) {
            optionsRow.remove();
        }
        return false;
    });
    
    
    //private methods.
    var setValidationRowElements = function (rowData, fieldsList, fieldIndex){
        var validateToggleVal = fieldsList[fieldIndex];
        var regexVal = fieldsList[fieldIndex+1];
        var errorMsgVal = fieldsList[fieldIndex+2];
        var helpTextVal = fieldsList[fieldIndex+3];
        errorMsgVal = appfire.run.removeEnclosedQuotes(errorMsgVal);
        helpTextVal = appfire.run.removeEnclosedQuotes(helpTextVal);
        if(validateToggleVal || regexVal || errorMsgVal || helpTextVal){
            var validateToggle = rowData.find("aui-toggle[name='field-validate']");
            if(validateToggleVal){
                validateToggle.attr('checked', true);
                setVisibilityValidateRowElements(validateToggle);
            }
            else{
                setVisibilityValidateRowElements(validateToggle);
            }
            rowData.find("input[name='field-regex']").val(decodeURIComponent(regexVal));
            rowData.find("input[name='field-errormsg']").val(errorMsgVal);
            rowData.find("input[name='field-helptext']").val(helpTextVal);
        }
    }
    
    var setVisibilityValidateRowElements = function(toggleElement){
        var validationRow = toggleElement.closest(".fields-row-validation");
        if(!toggleElement.attr('checked')){
            validationRow.find('input.text').attr('disabled', true);
        }
        else{
            validationRow.find('input.text').attr('disabled', false);
        }
    }
    var pushValidationParams = function(moreParams, validateFlag, regex, errorMsg, helpText) {
        moreParams.push(validateFlag);
        if (regex) {
            //if its not a valid regex, it may break the macro rendering, so pass the regex only if its valid one
            moreParams.push(isValidRegex(regex) ?  regex : '');
        }else{
            moreParams.push(""); 
        }
        if (errorMsg) {
            moreParams.push(appfire.run.addEnclosedQuotes(errorMsg));
        }else{
            moreParams.push(""); 
        }
        if (helpText) {
            moreParams.push(appfire.run.addEnclosedQuotes(helpText));
        }else{
            moreParams.push(""); 
        }
    }
    
    var addGroupField = function($grid) {
        var $row = $(org.swift.confluence.run.editor.fieldSettingsRow({position: 0, replace: "", contextPath: AJS.contextPath() }));
        updateFieldRowToGroupRow($row);
        appcme.addGridRow($grid, $row);
    }
    
    var updateFieldGroupSequence = function () {
        var previousSequence = 0;
        var inGroup = false;
        //updates field sequence with respective to groups.
        $("#run-form-fields").find(".appfire-row").each(function(index, row) {
            var groupSequence;
            var rowData = $(row).find(".row-data");
            
            //Reset side bar notch and add if required for group child elements.
            $(row).find(".group-child-sidebar-notch").hide();
            $(row).find(".row-header").removeClass("group-child-element");
            $(row).removeClass("individual-form-element-newgroup");
            
            var fieldType = rowData.find("select[name='field-type']").val();
            var group = false;
            if (fieldType === "group") {
                group = true;
                inGroup = true;
            }
            if (previousSequence == 0) {
                groupSequence = 1;
            } else {
                if (inGroup & !group) {
                    groupSequence = Math.round((previousSequence + 0.1) * 1e12) / 1e12;
                    $(row).find(".group-child-sidebar-notch").show();
                    $(row).find(".row-header").addClass("group-child-element");
                } else {
                    groupSequence = Math.floor(previousSequence) + 1;
                    $(row).addClass("individual-form-element-newgroup");
                }
            }
            var isEnd = rowData.find("aui-toggle[name='field-groupend']").prop('checked');
            if (isEnd) {
                inGroup = false;
            }
            $(row).find(".field-row-sequence").text(groupSequence);
            previousSequence = groupSequence;
            
            //update the inline dialog id 
            updateHelpDialogs($(row), $(row).find("a[id^='sql-profile-help']"), groupSequence);
            updateHelpDialogs($(row), $(row).find("a[id^='sql-query-help']"), groupSequence);
        });
    }
    
    var updateHelpDialogs = function(row, helpLink, sequence){
        if(helpLink.length){
            var helpLinkId = helpLink.attr('id');
            helpLink.attr('id', sequence+helpLinkId);
            var helpDialogId = helpLink.attr('aria-controls');
            helpLink.attr('aria-controls', helpLinkId+sequence);
            var linkedHelpDialog = row.find('aui-inline-dialog[id="'+helpDialogId+'"]');
            if(linkedHelpDialog.length){
                linkedHelpDialog.attr('id', helpLinkId+sequence)
            }
        } 
    }
    var updateFieldRowToGroupRow = function ($row) {
        var rowData = $row.find(".row-data");
        
        //Hide fields not related to group.
        rowData.find(".group-hide-element").hide();
        
        //Remove all options and add group option in select.
        //Hide select for holding field type and add image with label.
        var $selectElement = rowData.find("select[name='field-type']").parent();
        var $groupSelect = $(org.swift.confluence.run.editor.groupFieldSelectElement({ contextPath: AJS.contextPath() }));
        $selectElement.replaceWith($groupSelect);
        
        //update field name label to Group key for group 
        var $fieldNameLabel = rowData.find("label[for='field-name']");
        var $groupFieldLabel = $(org.swift.confluence.run.editor.groupFieldNameLabelElement());
        $fieldNameLabel.replaceWith($groupFieldLabel);
        
        //update styles for group row.
        $row.find(".row-header").addClass("group-row-sidebar");
        $row.find(".row-actions").addClass("group-row-actions");
        rowData.addClass("group-row-body");
    }
    
    var updateFieldRowByFieldType = function (fieldType, rowData) {
        //Dynamic grid - hide all first
        rowData.find(".show-hide-element").hide();
        //This should be called for valid field types.
        if (fieldType) {
            rowData.find(".field-type-" + fieldType).show();
        }
        //RUN 6.2.0 release - field-type-text,field-type-password, field-type-textarea, field-type-float, field-type-integer,  field-type-date
        if(fieldType === "text" || fieldType === "password" || fieldType === "textarea" || fieldType === "float" || fieldType === "integer" || fieldType === "date"){
            rowData.find(".fields-row-validation").show();
        }
        else{
            rowData.find(".fields-row-validation").hide(); 
        }
    }
    
    //converts select element to select2 element.
    var convertFieldTypeToSelect2 = function (rowData) {
        var fieldTypeSelectElm = rowData.find("select[name='field-type']");
        if (fieldTypeSelectElm != null && fieldTypeSelectElm.val() != 'group') {
            
            //When trying to add cloned rows, found converted select2 element (in case of copy-paste row action)
            //remove select2 nature if it was already converted to select2.
            if (fieldTypeSelectElm.hasClass("select2-offscreen")) {
                fieldTypeSelectElm.siblings(".select2-container").remove();
                fieldTypeSelectElm.removeClass("select2-offscreen");
            }
            
            //convert select to select2 to show image for options.
            fieldTypeSelectElm.auiSelect2({
                //set this to -1 to hide search in select2
                minimumResultsForSearch: -1,
                formatResult: formatFieldTypeSelect,
                formatSelection: formatFieldTypeSelect,
                escapeMarkup : function(markup){
                    return markup;
                }
            });
        }
    }
    var getDataSourceProfiles = function(rowData, currentProfileName){
        var dsEle = rowData.find('input[name="field-dynamic-select-ds"]');
        var thisPageId = (AJS.params.pageId != 0 ? AJS.params.pageId : AJS.params.parentPageId);
        //Get the profiles and once fetched, add to datasourceprofile select2
        $.getJSON(AJS.contextPath() + '/rest/bobswift/sql/1.0/profiles?keysOnly=true&macroName=sql-query&pageId='+thisPageId +'&profileName=' + currentProfileName).done(
            function( data ) {
                dsEle.data('SQL_APP_STATUS',true)
                var profileData = $.map(data, function(item) {
                    return { id: item, text: item }; 
                });
                dsEle.auiSelect2({
                    placeholder: "Select a profile...",
                    allowClear: true,
                    multiple: false,
                    data: profileData,
                    initSelection: function(element, callback) {
                        callback({
                             id: element.val(),
                             text: element.val() ? element.val() : "Select a profile..."
                         }); 
                    },
                    createSearchChoice:function(term, data) {
                        //This creates search choice with query/search term
                        if(!appsqlutil.isExpress) {
                            return {id:term, text:term};
                        }
                        else { 
                            return null; 
                        } //for express, only profiles configured in the profile config section will be allowed
                    },
                    formatNoMatches: function (term) {
                        return "No profiles found.";
                    },
                });
                
            }).fail(function (message) {
                if(message.status == 404){
                    dsEle.data('SQL_APP_STATUS',false)
                }
                console.log('Unable to fetch data source profiles: '+message.status)
            }); //end of ajax.done
        
    }
    var formatFieldTypeSelect = function (state) {
        var imageUrl = AJS.$(state.element).data('imagename');
        if (state.id && imageUrl) {
            imageUrl = AJS.contextPath() + '/download/resources/org.swift.confluence.run/img/' + imageUrl;
            return '<span title="'+state.text.trim()+'"><img class="icon field-type-select2-icon" src="' + imageUrl + '" height="20px" width="20px" align="top" /> ' + state.text + '</span>';
        }
        return state.text;
    }
    
    //To update unique ids for inline dialogs
    var updateInlineDialogUniqueId = function (rowData) {
        rowData.find(".label-with-help-icon").each(function () {
            var uniqueId = appcme.uniqueId();
            //RUN-337: Remove the inline dialog and add it through JS to fix the issue.
            var helpContent = $(this).find("aui-inline-dialog").find(".aui-inline-dialog-contents").text();
            $(this).find("a[aria-controls]").remove();
            $(this).find("aui-inline-dialog").remove();
            var $helpLink = $(org.swift.confluence.table.editor.addHelpContent({id: uniqueId, helpContent: helpContent }));
            $(this).append($helpLink);
        });
    }
    
    var addSelectOptionsRow = function (optionsTable, value, text) {
        var firstRow = optionsTable.children(':first');
        var newRow = firstRow.clone(true, true); // be sure to clone all handlers and data as well
        newRow.find(".remove-option-btn").show();
        newRow.find("input[name='field-option-value']").val(value ? value : "");
        newRow.find("input[name='field-option-text']").val(text ? text : "");
        
        optionsTable.append(newRow);
    }
    
    //Method to check whether only one row exist which is non-empty.
    var isFirstOptionNotEmpty = function (selectOptions) {
        if (selectOptions.length == 1) {
            var firstOptionValue = selectOptions.first().find("input[name='field-option-value']").val();
            var firstOptionText = selectOptions.first().find("input[name='field-option-text']").val();
            return firstOptionValue || firstOptionText;
        }
        return false;
    }
    
    var isValidRegex = function(regExp){
        try {
            new RegExp(regExp);
          } catch(e) {
            return false
          }
          return true
    }
    
    var validateDefaultValueForGivenRegex = function(rowData, fieldTypeText, errorElements, errorMessagesMap){
        var validateFlag = rowData.find("aui-toggle[name='field-validate']").attr('checked');
        if(validateFlag){
            var regex = rowData.find("input[name='field-regex']");
            var errorMsg = rowData.find("input[name='field-errormsg']");
            var helpText = rowData.find("input[name='field-helptext']");
            var regexVal = regex.val();
            //if validate enabled make sure regex given
            if(!regexVal){
                errorElements.push(regex);
                addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Regular expression cannot be empty for {0} field. Enter a value for this field or disable Validate to proceed.", fieldTypeText));
                errorElements = [];
            }
            else{
                //Validate if valid regex given
                var isRegexValid = isValidRegex(regexVal);
                if(isRegexValid){
                    var defaultValField = rowData.find("input[name='field-value']");
                    var defaultVal = defaultValField.val();
                    //if default value given, validate against given regex.
                    if(defaultVal){
                        var matches = defaultVal.match(new RegExp(regexVal, 'ig'));
                        if(!matches){ //regex not matching default val
                            errorElements.push(defaultValField);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Regular expression does not match the field value for {0} field. Please try again!", fieldTypeText));
                            errorElements = [];
                        }
                    }
                }
                else{
                    errorElements.push(regex);
                    addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Regular expression given for {0} field is not valid.", fieldTypeText));
                    errorElements = [];
                }
            }
            //if validate enabled make sure errorMsg given
            if(!errorMsg.val()){
                errorElements.push(errorMsg);
                addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Error message cannot be empty for {0} field. Enter a value for this field or disable Validate to proceed.", fieldTypeText));
                errorElements = [];
            }
          //if validate enabled make sure helpText given
            if(!helpText.val()){
                errorElements.push(helpText);
                addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Help text cannot be empty for {0} field. Enter a value for this field or disable Validate to proceed.", fieldTypeText));
                errorElements = [];
            }
        }
    }
    //Method to validate form fields
    var validateFormFields = function(errors, form) {
        var fieldNamesMap = {};
        var errorMessagesMap = {};
        var fieldMap={};
        $("#run-form-fields").find(".appfire-row").each(function(index, row) {
            var rowData = $(row).find(".row-data");
            
            var fieldTypeElement = rowData.find("select[name='field-type']")
            var fieldType = fieldTypeElement.val();
            var fieldTypeText = rowData.find("select[name='field-type'] option:selected").text();
            
            var fieldNameElement = rowData.find("input[name='field-name']");
            var fieldName = fieldNameElement.val();
            
            var errorElements = [rowData];
            //Validation to check whether field type is selected or not.
            if (!fieldType) {
                errorElements.push(fieldTypeElement);
                addErrorMessageToMap(errorMessagesMap, errorElements, "The field type must be selected.");
                errorElements = [];
            }
            //Validation to check whether field key is empty or duplicate.
            if (!fieldName) {
                errorElements.push(fieldNameElement);
                addErrorMessageToMap(errorMessagesMap, errorElements, "The field key must not be blank.");
                errorElements = [];
            } else if (fieldNamesMap.hasOwnProperty(fieldName)) {
                errorElements.push(fieldNameElement);
                addErrorMessageToMap(errorMessagesMap, errorElements, "The field key must be unique.");
                errorElements = [];
            }
            //Adding fieldNames to check duplicates.
            fieldNamesMap[fieldName] = fieldNameElement;
            
            var fieldValue = rowData.find("input[name='field-value']").val();
                        
            if (fieldType) {
                switch (fieldType) {
                    case '' :
                    case 'text' : 
                    case 'password' : 
                        var inputSizeElement = rowData.find("input[name='field-inputsize']");
                        var inputSize = inputSizeElement.val();
                        //InputSize value can contain '%' or 'px' suffix
                        if (inputSize && !isInteger(inputSize.replace(/%/g,'').replace(/px/g,''))) {
                            errorElements.push(inputSizeElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Input size value must be numeric integer for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        validateDefaultValueForGivenRegex(rowData, fieldTypeText, errorElements, errorMessagesMap);
                        break;
                    case 'textarea' :
                        var numberOfRowsElement = rowData.find("input[name='field-rows']");
                        var numberOfRows = numberOfRowsElement.val();
                        
                        var numberOfColumnsElement = rowData.find("input[name='field-columns']");
                        var numberOfColumns = numberOfColumnsElement.val();
                        
                        if (numberOfRows && !isInteger(numberOfRows)) {
                            errorElements.push(numberOfRowsElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Number of rows value must be numeric integer for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        if (numberOfColumns && !isInteger(numberOfColumns)) {
                            errorElements.push(numberOfColumnsElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Number of columns value must be numeric integer for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        validateDefaultValueForGivenRegex(rowData, fieldTypeText, errorElements, errorMessagesMap);
                        break;
                    case 'radio' : 
                    case 'checkbox' : 
                        var numberOfRowsElement = rowData.find("input[name='field-non-select-options-display']");
                        var numberOfRows = numberOfRowsElement.val();
                        if (numberOfRows && !isPositiveInteger(numberOfRows)) {
                            errorElements.push(numberOfRowsElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Number of rows to display options value must be numeric and positive integer for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        break;
                    case 'select' : 
                    case 'select-multi' :
                        var numberOfRowsElement = rowData.find("input[name='field-select-options-display']");
                        var numberOfRows = numberOfRowsElement.val();
                        if (numberOfRows && !isPositiveInteger(numberOfRows)) {
                            errorElements.push(numberOfRowsElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Number of options value must be positive integer for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        break;
                    case 'dynamic-select' :
                    case 'dynamic-selectmulti' :
                        var numberOfRowsElement = rowData.find("input[name='field-select-options-display']");
                        var numberOfRows = numberOfRowsElement.val();
                        if (numberOfRows && !isPositiveInteger(numberOfRows)) {
                            errorElements.push(numberOfRowsElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Number of options value must be positive integer for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        var sqlDS = rowData.find("input[name='field-dynamic-select-ds']");
                        var query = rowData.find("textarea[name='field-dynamic-select-query']");
                        
                        var sqlAppEnabled = sqlDS.data('SQL_APP_STATUS');
                        if(!sqlAppEnabled){
                            errorElements.push(sqlDS);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Please make sure to enable SQL for Confluence app to use this field type", fieldTypeText));
                            errorElements = [];
                        }
                        else if(sqlDS.val().trim() == '' ){
                            errorElements.push(sqlDS);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Please provide a data source profile.", fieldTypeText));
                            errorElements = [];
                        }
                        
                        if(query.val().trim() == '' ){
                            errorElements.push(query);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Please provide a SQL query.", fieldTypeText));
                            errorElements = [];
                        } else {
                            // RUN-463 Adding validation for circular field dependencies
                            if (!validateDynamicFieldRef(query.val(), fieldMap,fieldName)) {
                                errorElements.push(query);
                                addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Please remove all circular field references in the given SQL query.", fieldTypeText));
                                errorElements = [];
                            }   
                        }
                        
                        break;
                    case 'float' : 
                        //Validation for Float fields
                        var lowerboundElement = rowData.find("input[name='field-lowerbound']");
                        var lowerbound = lowerboundElement.val();
                        var upperboundElement = rowData.find("input[name='field-upperbound']");
                        var upperbound = upperboundElement.val();
                        if (lowerbound && !$.isNumeric(lowerbound)) {
                            errorElements.push(lowerboundElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Lower bound value must be numeric for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        if (upperbound && !$.isNumeric(upperbound)) {
                            errorElements.push(upperboundElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Upper bound value must be numeric for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        validateDefaultValueForGivenRegex(rowData, fieldTypeText, errorElements, errorMessagesMap);
                        break;
                    case 'integer' : 
                        var lowerboundElement = rowData.find("input[name='field-lowerbound']");
                        var lowerbound = lowerboundElement.val();
                        var upperboundElement = rowData.find("input[name='field-upperbound']");
                        var upperbound = upperboundElement.val();
                        
                        //Validation for Integer fields
                        if (lowerbound && !isInteger(lowerbound)) {
                            errorElements.push(lowerboundElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Lower bound value must be numeric integer for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        if (upperbound && !isInteger(upperbound)) {
                            errorElements.push(upperboundElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Upper bound value must be numeric integer for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        validateDefaultValueForGivenRegex(rowData, fieldTypeText, errorElements, errorMessagesMap);
                        break;
                    case 'integer-select' : 
                        var lowerboundElement = rowData.find("input[name='field-lowerbound']");
                        var lowerbound = lowerboundElement.val();
                        var upperboundElement = rowData.find("input[name='field-intselect-upperbound']");
                        var upperbound = upperboundElement.val();
                        
                        //validations for only Integer Select
                        if (!lowerbound || !upperbound) {
                            errorElements.push(lowerboundElement);
                            errorElements.push(upperboundElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Both lower bound and upper bound must be specified for {0} field.", fieldTypeText));
                            errorElements = [];
                        } 
                        if (lowerbound && !isInteger(lowerbound)) {
                            errorElements.push(lowerboundElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Lower bound value must be numeric integer for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        if (upperbound && !isInteger(upperbound)) {
                            errorElements.push(upperboundElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Upper bound value must be numeric integer for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        if ((upperbound - lowerbound) > 10000) {
                            errorElements.push(lowerboundElement);
                            errorElements.push(upperboundElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("The difference between lower bound and upper bound must be less than 10000 for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        break;
                    case 'date' : 
                        //TODO: Add validation for Date field.
                        validateDefaultValueForGivenRegex(rowData, fieldTypeText, errorElements, errorMessagesMap);
                        break;
                    case 'output' : 
                    case 'hidden' : 
                        break;
                    case 'group' : 
                        var widthElement = rowData.find("input[name='field-width']");
                        var width = widthElement.val();
                        //Width value can contain '%' or 'px' suffix
                        if (width && !isInteger(width.replace(/%/g,'').replace(/px/g,''))) {
                            errorElements.push(widthElement);
                            addErrorMessageToMap(errorMessagesMap, errorElements, AJS.format("Width value must be numeric integer for {0} field.", fieldTypeText));
                            errorElements = [];
                        }
                        break;
                    default:
                }    
            }
        });
        var buttonPaddingElement = form.find("input[name='buttonPadding']");
        var buttonPadding = buttonPaddingElement.val();
        if (buttonPadding && !isInteger(buttonPadding)) {
            addErrorMessageToMap(errorMessagesMap, buttonPaddingElement, "Button padding value must be numeric integer.");
        }
        if (errors) {
            for (var key in errorMessagesMap) {
                errors.push({ ele: errorMessagesMap[key], msg: key});
            }
            if (errors.length > 0) {
                errors.push({ ele: null, msg: "<p>" + "Please see the highlighted error fields above." + "</p>"});
                return false;
            }
        }
        return true;
    }
    
    // Validate dynamic select for circular field references
    function validateDynamicFieldRef(query, fieldMap,fieldName) {
        let isValid = true;
        let matches = query.match(/\$\{.+?\}/g);
        if (matches && matches.length != 0) {
            fieldMap[fieldName] = [];
            matches.forEach(s => {
                fieldMap[fieldName].push(s.substring(2, s.length - 1));
            });
            for (const [key, value] of Object.entries(fieldMap)) {
                if (fieldMap[`${key}`] && fieldMap[`${key}`].length != 0) {
                    fieldMap[`${key}`].forEach(v => {
                        if (isValid && fieldMap[v] && fieldMap[v].includes(`${key}`)) {
                            isValid = false;
                        }
                    });
                }
            }
        }
        return isValid;
    }
    //checks whether given number is integer or not.
    var isInteger = function(number) {
        return $.isNumeric(number) && Math.floor(number) == number;
    }

    //checks whether given number is integer or not.
    var isPositiveInteger = function (number) {
        return isInteger(number) && number > 0;
    }
    
    //Adds unique error messages with corresponding elements to show validation errors.
    var addErrorMessageToMap = function(errorMessagesMap, fieldNameElement, errorMsg) {
        errorMsg = "<p>" + errorMsg + "</p>";
        var elements = errorMessagesMap.hasOwnProperty(errorMsg) ? errorMessagesMap[errorMsg] : [];

        if ($.isArray(fieldNameElement)) {
            elements.push.apply(elements, fieldNameElement)
        } else {
            elements.push(fieldNameElement);
        }
        errorMessagesMap[errorMsg] = elements;
    }
}(AJS.$));
}catch(e){WRMCB(e)};
;
try {
/* module-key = 'org.swift.confluence.run:run-macro-editor-resources', location = '/js/run-macro-util.js' */
/*
 * Copyright (c) 2018 Appfire Technologies, Inc.
 * All rights reserved.
 *
 * This software is licensed under the provisions of the "Bob Swift Atlassian Add-ons EULA"
 * (https://bobswift.atlassian.net/wiki/x/WoDXBQ) as well as under the provisions of
 * the "Standard EULA" from the "Atlassian Marketplace Terms of Use" as a "Marketplace Product"
 * (http://www.atlassian.com/licensing/marketplace/termsofuse).
 *
 * See the LICENSE file for more details.
 */

if(!window.appfire) { window.appfire = {};}
if(!window.appfire.run) { window.appfire.run = {};}

(function(apprun, $, undefined) {
    'use strict';

    /**
     * Prepares replace string for each field with given parameters.
     */
    apprun.prepareReplace = function(fieldType, key, value, desc, moreParams) {
        if (!key) {
            return '';
        }
        if (!fieldType) {
            fieldType = '';
        }
        key = apprun.addEnclosedQuotes(key);
        value = apprun.addEnclosedQuotes(value);
        desc = apprun.addEnclosedQuotes(desc);
        var replaceParam = key + ':' + value + ':' + desc + ':' + fieldType;
        switch (fieldType.split('-')[0]) {
            case '' :
            case 'text' : 
            case 'password' : 
                replaceParam = apprun.appendMoreParms (replaceParam, moreParams);
                break;
            case 'textarea' : 
                replaceParam = apprun.appendMoreParms (replaceParam, moreParams);
                break;
            case 'radio' : 
            case 'checkbox' : 
            case 'select' : 
            case 'select-multi' :
            case 'dynamic' : //dynamic-select
                if (moreParams && moreParams.length > 0) {
                    var noOfRows = moreParams[0] ? moreParams[0].trim() : '';
                    replaceParam += ':' + noOfRows;
                    //value:text pairs
                    if (moreParams.length > 1) {
                        for (var i = 1; i < moreParams.length; i++) {
                            replaceParam += ':' + apprun.addEnclosedQuotes(moreParams[i]);
                        }
                    }
                }
                break;
            case 'float' : 
            case 'integer' : 
                replaceParam = apprun.appendMoreParms (replaceParam, moreParams);
                break;
            case 'integer-select' : 
                if (moreParams && moreParams.length > 0) {
                    var lowerBound = moreParams[0] ? moreParams[0].trim() : '';
                    replaceParam += ':' + lowerBound;
                    if (moreParams.length > 1) {
                        replaceParam += ':';
                        replaceParam += moreParams[1] ? moreParams[1].trim() : '';
                    }
                }
                break;
            case 'date' : 
                if (moreParams && moreParams.length > 0) {
                    $.each(moreParams, function( index, value ) {
                        var val;
                        if(moreParams[index]){
                            if(typeof moreParams[index] == 'boolean'){
                                val = moreParams[index];
                            }
                            else{
                                val = moreParams[index].trim();
                            }
                        }
                        else{
                            val = ''; 
                        }
                        replaceParam += ':';
                        if(index < 3){
                            replaceParam += apprun.addEnclosedQuotes(val);
                        }
                        else{
                            replaceParam += val;
                        }
                      });
                }
                break;
            case 'output' : 
            case 'hidden' : 
                break;
            case 'group' : 
                if (moreParams && moreParams.length > 0) {
                    replaceParam += ':';
                    replaceParam += moreParams[0] ? moreParams[0].trim() : '';
                }
                break;
            default:
        }
        return replaceParam;
    }
    
    apprun.appendMoreParms = function (replaceParam, moreParams) {
        if (moreParams && moreParams.length > 0) {
            $.each(moreParams, function( index, value ) {
                replaceParam += ':';
                replaceParam += moreParams[index] ? moreParams[index] : '';
              });
        }
        return replaceParam;
    }
    
    /**
     * Prepares field type along with field qualifier.
     */
    apprun.prepareFieldType = function(fieldType, isRequired, isDisabled, isEnd, isMore) {
        if (!fieldType) {
            //Default field type is text. TODO: Is default empty or text while saving?
            fieldType = 'text';
        }
        if (isRequired) {
            fieldType += '-required';
        }
        if (isDisabled) {
            fieldType += '-disabled';
        }
        if (isEnd) {
            fieldType += '-end';
        }
        if (isMore) {
            fieldType += '-more';
        }
        
        
        return fieldType;
    }
    
    /**
     * Converts split field string to individual parameters.
     */
    apprun.replaceStringToObject = function(fieldsList) {
        if (!fieldsList || fieldsList.length == 0) {
            return {};
        }
        var fieldName = apprun.removeEnclosedQuotes(fieldsList[0]);
        var fieldDesc = apprun.removeEnclosedQuotes(fieldsList[2]);
        var fieldValue = apprun.removeEnclosedQuotes(fieldsList[1]);
        
        var fieldType = "";
        var typeQualifier = "";
        if (fieldsList.length > 3) {
            fieldType = fieldsList[3];
            var index = fieldType.indexOf("-");
            //if fieldType itself contains the hyphen(-), we should split from next hyphen to get the correct fieldType and qualifiers.
            //As of now, we have below two field types which contains hyphen in it.
            if (fieldType.includes('select-multi') || fieldType.includes('integer-select') || fieldType.includes('dynamic')) {
                index = fieldType.indexOf("-", index + 1);
            }
            if (index != -1) {
                typeQualifier = fieldType.substring(index);
                fieldType = fieldType.substring(0, index);
            }
        }
        
        fieldType = apprun.removeEnclosedQuotes(fieldType);
        if (!fieldType) {
            //Default field type is text. TODO: Is default empty or text while showing?
            fieldType = 'text';
        }
        
        return {
            fieldName : fieldName,
            fieldValue : fieldValue,
            fieldDesc : fieldDesc,
            fieldType : fieldType.trim(),
            typeQualifier: typeQualifier.trim()
        };
    }
    
    /**
     * Invert the boolean parameter value in parms.
     */
    apprun.invertBooleanParamValue = function (parms, defaultVal, paramName) {
        if (parms == null || defaultVal == null || !paramName) {
            return;
        }
        if (typeof(defaultVal) === "boolean") {
            //if there is no value, assign default value as it got deleted in appcme.parseParameters() call.
            if (parms[paramName] == null) {
                parms[paramName] = defaultVal;
            }
            
            //Reverse the value
            //parms[paramName] = !parms[paramName]; //it is not working as boolean value is set to "true"/"false" by appcme.parseParameters().
            if (parms[paramName] == true || parms[paramName] == "true") {
                parms[paramName] = false;
            } else {
                parms[paramName] = true;
            }
            
            //If final value matches default value, remove it.
            if (parms[paramName] == defaultVal) {
                delete parms[paramName];
            }
        }
    }
    
    //Method to remove enclosed single quotes.
    apprun.removeEnclosedQuotes = function (replaceStr) {
        if (replaceStr) {
            replaceStr = replaceStr.trim();
            if (replaceStr.startsWith("'") && replaceStr.endsWith("'")) {
                replaceStr = replaceStr.substring(1, replaceStr.length - 1);
            }
        } else {
            replaceStr = '';
        }
        return replaceStr;
    }
    
    //Method to add enclosed single quotes.
    apprun.addEnclosedQuotes = function (replaceStr) {
        if (replaceStr) {
            replaceStr = replaceStr.trim();
            if (replaceStr.includes(",") || replaceStr.includes(":")) {
                replaceStr = "'" + replaceStr + "'";
            }
        } else {
            replaceStr = '';
        }
        return replaceStr;
    }
    
    //Removes empty elements from the list
    apprun.removeEmptyFields = function (array) {
        if (!array || array.length == 0) {
            return array;
        }
        return array.filter(function (element) {
            return element && element.trim();
        });
    }
}(window.appfire.run, AJS.$));
}catch(e){WRMCB(e)};
;
try {
/* module-key = 'org.swift.confluence.run:run-macro-editor-resources', location = '/soy/field-settings-row.soy' */
// This file was automatically generated from field-settings-row.soy.
