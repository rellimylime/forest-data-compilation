try {
/* module-key = 'com.adaptavist.confluence.formMailNG:form-mail-format-resource', location = 'js/forms/config/mail-body-formatter-description.js' */
AJS.bind("init.rte", function () {

    function openDialog(macro) {

        function resetPanel() {
            dialog.gotoPage(0);
            dialog.gotoPanel(0);
        }

        var dialog = new AJS.Dialog({
            width: 800,
            height: 500,
            closeOnOutsideClick: true
        });

        dialog.addHeader((macro.body ? "Edit" : "Insert") + " 'Mail body formatter' Macro");

        dialog.addPanel("Description", '<p>' + "Set a template for form submissions that are sent to an email" + '<p></p>'
            + "Reference a field by using #macroname to add it to the template." + '<p></p>'
            + "All text in the macro body will appear in the outgoing mail." + '<p></p>'
            + "Caution: Any fields which are omitted from the mail body formatter will not be included in the sent mail. To revert to the default template use the \u0022default\u0022 button or remove the mail-body formatter macro from the page." + '</p>'
            , "#formatterdescription");

        dialog.addPanel("Tutorial", '<img src="' + AJS.contextPath() + '/download/resources/com.adaptavist.confluence.formMailNG:images-resources/images/mail-body-formatter.png" alt="Image missing">', "#formattertutorial");

        // 2. add macro to editor
        dialog.addSubmit(macro.body ? "Save" : "Insert", function () {
            
            var t = tinymce.confluence.macrobrowser;
            
            AJS.Rte.BookmarkManager.restoreBookmark();

            if (t.editedMacroDiv) {
                delete t.editedMacroDiv;
            } else {
                tinymce.confluence.macrobrowser.macroBrowserComplete({
                    name: "mail-body-formatter",
                    "bodyHtml": "",
                    "params": {}
                });

            }

            resetPanel();
            dialog.remove();
        });

        dialog.addCancel('Cancel', function () {
            resetPanel();
            dialog.remove();
        });

        dialog.show();
    }

    AJS.MacroBrowser.setMacroJsOverride('mail-body-formatter', {opener: openDialog});

});

}catch(e){WRMCB(e)};
;
