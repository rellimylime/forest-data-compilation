try {
/* module-key = 'com.balsamiq.confluence.plugins.mockups:editor-web-resource', location = 'includes/editor/balsamiqmockups.js' */
try {
	AJS.bind("init.rte", function() {
		(function($)
		{
			BalsamiqMockups = function() { };

			BalsamiqMockups.prototype.removeSuffix = function (str, suffix) {
                var i = str.indexOf(suffix, str.length - suffix.length);
                if (i != -1) {
                    return str.substring(0, i);
                } else {
                    return str;
                }
            };

            BalsamiqMockups.prototype.getExtensionName = function(filename) {
                var a = filename.split(".");
                if( a.length === 1 || ( a[0] === "" && a.length === 2 ) ) {
                    return "";
                }
                return "." + a.pop();
            };

            BalsamiqMockups.prototype.refreshAllImagesPlaceHolders = function() {
                var iframes = document.getElementsByTagName('iframe');
                var i, j, images, url;
                for (j=0; j<iframes.length; j++) {
                    images = iframes[j].contentDocument.getElementsByTagName('img');
                    for(i = 0; i < images.length; i++) {
                        if (images[i].src.indexOf("balsamiq_wireframe") !== -1) {
                            url = images[i].src.split("?")[0];
                            images[i].src = url + "?" + new Date().getTime();
                            // console.log(images[i].src);
                        }
                    }
                }
            };


            // BalsamiqMockups.prototype.isDraft = function() {
            //     var draftStatus;
            //     if (AJS.params.pageId == "0") {
            //         draftStatus = true;
            //     } else {
            //         console.log("BWCS: DRAFT");
            //         draftStatus = false;
            //     }
            //
            //     return draftStatus;
            // };

			BalsamiqMockups.prototype.getAttachmentList = function(extNameList, callback) {
                var contextPath = typeof(AJS.contextPath()) == "undefined" ? "" : AJS.contextPath();
                var url, extName;
                var contentID;

                if (AJS.params.pageId == "0") {
                    contentID = AJS.Meta.get('content-id');
                } else {
                    pageParam = 'page=' + AJS.params.pageId;
                    contentID = AJS.params.pageId;
                }

                url = contextPath + '/rest/api/content/' + contentID + '/child/attachment';

                $.ajax({
                    url: url,
                    method: 'GET',
                    success: function (resp) {
                        var i, j, attachment, attachmentList;
                        attachmentList = {};
                        for (i=0; i<extNameList.length; i++) {
                            extName = extNameList[i];
                            attachmentList[extName] = [];
                        }

                        for (j = 0; j < resp.results.length; j++) {
                            attachment = resp.results[j];

                            for (i=0; i<extNameList.length; i++) {
                                extName = extNameList[i];
                                if (!extName || BM4C.getExtensionName(attachment.title) == extName) {
                                    attachmentList[extName].push(attachment);
                                    break;
                                }
                            }
                        }

                        callback({list: attachmentList});
                    },
                    error: function (error) {
                        var message = "Unable to retrieve attachment: " + url + " error " + JSON.stringify(error);
                        callback({ error: message });
                    }
				});
            };

            BalsamiqMockups.prototype.launchBalsamiqMacroEditorV2 = function(p_data) {
                var pageParam, draftStatus, key, keys, i, contentID, macroParams;
                var contextPath = typeof(AJS.contextPath()) == "undefined" ? "" : AJS.contextPath();

                // "Edit" button of the macro V2
                if (p_data && p_data["params"]) {
                    macroParams = p_data["params"];
                    console.log("BWCS: macroParam: ", macroParams);

                    if (AJS.params.pageId == "0") {
                        pageParam = 'draft=' + AJS.Meta.get('content-id');
                        contentID = AJS.Meta.get('content-id');
                        draftStatus = true;
                    } else {
                        pageParam = 'page=' + AJS.params.pageId;
                        contentID = AJS.params.pageId;
                        draftStatus = false;
                    }

                    pageParam += "&cp=" + contextPath;
                    pageParam += "&user_key=" + AJS.params.remoteUser;
                    pageParam += "&xdm_e=" + BM4C.removeSuffix(AJS.params.baseUrl, contextPath);
                    pageParam += "&draftStatus=" + draftStatus;
                    pageParam += "&contentid=" + contentID;
                    pageParam += "&action=macro-editor";

                    keys = Object.keys(macroParams);
                    for (i=0; i<keys.length; i++) {
                        key = keys[i];
                        pageParam += "&" + key + "=" + macroParams[key];
                    }


                    AJS.$(document.documentElement).append(
                        '<iframe id="balsamiq_mockups_macro_editor_iframe" allowfullscreen src="' + contextPath + '/plugins/servlet/com.balsamiq.mockups.macro.editor?' + pageParam
                        + '" style="position:fixed;left:0;top:0;border:none;" frameborder="0" width="100%" height="100%"></iframe>');
                } else {
                    // TODO: better error reporting
                    alert("Use the Balsamiq Wireframes Macro");
                }
            };

			BalsamiqMockups.prototype.launchBalsamiqMockupsEditor = function(p_data)
			{
				console.log("BWCS: launchBalsamiqMockupsEditor", p_data);

                AJS.Rte.BookmarkManager.storeBookmark();

				if (p_data && p_data["params"]) {
				    // "Edit" button of the macro
                    BM4C.openEditor(p_data.params);
                } else {
				    // "Balsamiq Wireframes" from "Add" menu
                    BM4C.getAttachmentList([".bmpr"], function(obj) {
                        var bmprList;
                        console.log("BWCS: getAttachmentList", obj);
                        if (obj.error) {
                            // TODO: better error reporting
                            alert(obj.error);
                        } else {
                            bmprList = obj.list[".bmpr"];

                            if (bmprList.length) {
                                // there is already a BMPR launch the macro editor and insert the macro
                                BM4C.launchMacroEditor();
                            } else {
                                // launch the BW editor and insert a macro on exit
                                // Hide the header and left side bar
                                AJS.$("#header").css("display", "none");
                                AJS.$(".ia-splitter-left").css("display", "none");

                                BM4C.openEditor();
                            }
                        }
                    });
                }
			};

			BalsamiqMockups.prototype.showMessage = function (obj) {
                if (AJS && AJS.flag) {
                    AJS.flag({
                        type: obj.type || "error",
                        title: obj.title,
                        body: obj.message
                    });
                } else {
                    alert(obj.textMessage);
                }
            };

			BalsamiqMockups.prototype.openEditor = function(p_data)
			{
                var contextPath;
                var action;
                var macroParam;
                var confluenceVersionNumber = AJS.Meta.get("version-number");

                // we save if we are inserting or editing, so we will be able to discriminate the case when the closeEditor will be invoked
                BM4C.inserting = (p_data == null);

                if (p_data == null) {
                    // add a new macro
					action = "create";
 				} else {
                    // open the editor on the existing resource
                    action = "edit";
				}
				var pageParam;
                var draftStatus;
                var contentID;
				if (AJS.params.pageId == "0") {
					pageParam = 'draft=' + AJS.Meta.get('content-id');
                    contentID = AJS.Meta.get('content-id');
                    draftStatus = true;
				} else {
					pageParam = 'page=' + AJS.params.pageId;
                    contentID = AJS.params.pageId;
                    draftStatus = false;
				}

				console.log("BWCS: Confluence " + confluenceVersionNumber + " draftStatus " + draftStatus);
				if (draftStatus && confluenceVersionNumber.indexOf("5.") == 0) {
                    BM4C.showMessage({
                        title: "Balsamiq Wireframes",
                        type: "warning",
                        message: "Sorry, due to a Confluence 5.x limitation, it is not possible to create a Balsamiq Wireframe Project in a draft page.<br/> " +
                        "Please save the page before adding a wireframe.<br/>" +
                        "You can find more information <a target='_blank' href='https://support.balsamiq.com/plugins/noprojectdraft/'>here</a>.",
                        textMessage: "Sorry, due to a Confluence 5.x limitation, it is not possible to create a Balsamiq Wireframe Project in a draft page.\n" +
                        "Please save the page before adding a wireframe."
                    });
                } else {
                    contextPath = typeof(AJS.contextPath()) == "undefined" ? "" : AJS.contextPath();

                    pageParam += "&cp=" + contextPath;
                    pageParam += "&user_key=" + AJS.params.remoteUser;
                    pageParam += "&xdm_e=" + BM4C.removeSuffix(AJS.params.baseUrl, contextPath);
                    pageParam += "&draftStatus=" + draftStatus;
                    pageParam += "&contentid=" + contentID;
                    pageParam += "&action=" + action;
                    // license status will be enquired in the ConfluenceClient init
                    // pageParam += "&lic=active";

                    // console.log("BWCS: GOTCHA contentID " + contentID + " draftStatus " + draftStatus);

                    var getAttachmentIdInThisContent = function(platformArchiveID, platformArchiveName, callback) {
                        // TODO: pass the already retrieved attachment list?
                        BM4C.getAttachmentList([".bmpr"], function (obj) {
                            var i, attachment, found = false, newAttachmentID = null;
                            if (obj.error) {
                                callback && callback(obj);
                            } else {
                                for (i = 0; i < obj.list[".bmpr"].length; i++) {
                                    attachment = obj.list[".bmpr"][i];
                                    if (attachment.id === platformArchiveID) {
                                        found = true;
                                        break;
                                    } else {
                                        if (newAttachmentID === null && attachment.title === platformArchiveName + ".bmpr") {
                                            newAttachmentID = attachment.id;
                                        }
                                    }
                                }

                                if (found) {
                                    callback && callback(attachment);
                                } else {
                                    callback && callback({
                                        attachmentID: newAttachmentID
                                    });
                                }
                            }
                        });
                    };

                    var finalise = function() {
                        if (p_data) {
                            var keys = Object.keys(p_data);
                            var key, i;
                            macroParam = {};
                            for (i = 0; i < keys.length; i++) {
                                key = keys[i];
                                if (p_data[key]) {
                                    macroParam[key] = p_data[key];
                                    pageParam += "&" + key + "=" + macroParam[key];
                                }
                            }
                            BM4C.prevMacroData = macroParam;
                            console.log("BWCS: openEditor", BM4C.prevMacroData);

                            // macroParam = p_data;
                            // var keys = Object.keys(macroParam);
                            // var key, i;
                            // for (i = 0; i < keys.length; i++) {
                            //     key = keys[i];
                            //     if (macroParam[key]) {
                            //         pageParam += "&" + key + "=" + macroParam[key];
                            //     }
                            // }
                            console.log("BWCS: openEditor: ", macroParam);
                        }

                        AJS.$(document.body).append(
                            '<iframe id="balsamiq_mockups_editor_iframe" allowfullscreen src="' + contextPath + '/plugins/servlet/com.balsamiq.mockups.editor?' + pageParam
                            + '" style="position:fixed;left:0;top:0;border:none;background:#FFFFFF;z-index:1000;" frameborder="0" width="100%" height="100%"></iframe>');

                    };

                    if (p_data && p_data.platformArchiveID && p_data.platformArchiveName) {
                        getAttachmentIdInThisContent(p_data.platformArchiveID, p_data.platformArchiveName, function(attachmentObj) {
                            if (attachmentObj.attachmentID) {
                                console.log("BWCS: WARNING archive pointed by the macro is not attached, using the project attached to the page ");
                                p_data.platformArchiveID = attachmentObj.attachmentID;
                            }
                            finalise();
                        });
                    } else {
                        finalise();
                    }
                }
			};

            //p_mockupID is the ID of the edited mockup
            //p_mockupID is null if the user cancelled without saving
            BalsamiqMockups.prototype.closeEditor = function(data)
            {
                var params = BM4C.prevMacroData || data;

                AJS.$("#balsamiq_mockups_editor_iframe").remove();

                // Show the header and left side bar
                AJS.$("#header").css("display", "block");
                AJS.$(".ia-splitter-left").css("display", "block");

                console.log("BWCS: closeEditor", data, BM4C.prevMacroData, params);

                if (params.forcePngExport) {
                    // we have migrated, we do not save the macro
                } else {
                    var macroRenderRequest = {
                        contentId: Confluence.Editor.getContentId(),
                        macro: {
                            name: "wireframe",
                            params: params,
                            defaultParameterValue: "",
                            body: ""
                        }
                    };

                    BM4C.refreshAllImagesPlaceHolders();

                    AJS.Rte.getEditor().focus();
                    AJS.Rte.BookmarkManager.restoreBookmark();
                    tinyMCE.confluence.MacroUtils.insertMacro(macroRenderRequest);
                }
            };

            BalsamiqMockups.prototype.launchMacroEditor = function(p_macroNode)
            {
            	var contextPath = typeof(AJS.contextPath()) == "undefined" ? "" : AJS.contextPath();
                var pageParam ="";
                var draftStatus;
                var contentID, i, keys, key;
                var macroParams;

                var macroDiv = AJS.$(p_macroNode);
                AJS.Rte.getEditor().selection.select(macroDiv[0]);

                macroParams = BM4C.getMacroParams(macroDiv);

                if (AJS.params.pageId == "0") {
                    pageParam = 'draft=' + AJS.Meta.get('content-id');
                    contentID = AJS.Meta.get('content-id');
                    draftStatus = true;
                } else {
                    pageParam = 'page=' + AJS.params.pageId;
                    contentID = AJS.params.pageId;
                    draftStatus = false;
                }

                pageParam += "&cp=" + contextPath;
                pageParam += "&user_key=" + AJS.params.remoteUser;
                pageParam += "&xdm_e=" + BM4C.removeSuffix(AJS.params.baseUrl, contextPath);
                pageParam += "&draftStatus=" + draftStatus;
                pageParam += "&contentid=" + contentID;
                pageParam += "&action=macro-editor";
                // license status will be enquired in the ConfluenceClient init
                // pageParam += "&lic=active";

                keys = Object.keys(macroParams);
                for (i=0; i<keys.length; i++) {
                	key = keys[i];
                    pageParam += "&" + key + "=" + macroParams[key];
				}

				console.log("BWCS: macroParam: ", macroParams);

                AJS.$(document.documentElement).append(
                    '<iframe id="balsamiq_mockups_macro_editor_iframe" allowfullscreen src="' + contextPath + '/plugins/servlet/com.balsamiq.mockups.macro.editor?' + pageParam
                    + '" style="position:fixed;left:0;top:0;border:none;" frameborder="0" width="100%" height="100%"></iframe>');
            };

            BalsamiqMockups.prototype.closeMacroEditor = function(macroParams) {
                var macroRenderRequest;
                AJS.$("#balsamiq_mockups_macro_editor_iframe").remove();

                // TODO: we do not need this
				// Show the header and left side bar
                // AJS.$("#header").css("display", "block");
                // AJS.$(".ia-splitter-left").css("display", "block");

                // we create the macro only when the mockup is inserted the first time
                if (macroParams) {
                    if (macroParams.Name) {
                        macroRenderRequest = {
                            contentId : Confluence.Editor.getContentId(),
                            macro : {
                                name : "mockup",
                                params : macroParams,
                                defaultParameterValue : "",
                                body : ""
                            }
                        };
                    } else {
                        macroRenderRequest = {
                            contentId : Confluence.Editor.getContentId(),
                            macro : {
                                name : "wireframe",
                                params : macroParams,
                                defaultParameterValue : "",
                                body : ""
                            }
                        };
                    }
                    AJS.Rte.getEditor().focus();
                    AJS.Rte.BookmarkManager.restoreBookmark();
                    tinyMCE.confluence.MacroUtils.insertMacro(macroRenderRequest);
                }
            };

            AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("balsamiq-mockups-macro-prop-config", function(e, macroNode)
            {
                BM4C.launchMacroEditor(macroNode);
            });

			AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("balsamiq-mockups-macro-prop-size-small", function(e, macroNode)
			{
				BM4C.editMacroSize(macroNode, "s");
			});
			AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("balsamiq-mockups-macro-prop-size-medium", function(e, macroNode)
			{
				BM4C.editMacroSize(macroNode, "m");
			});
			AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("balsamiq-mockups-macro-prop-size-original", function(e, macroNode)
			{
				BM4C.editMacroSize(macroNode, "o");
			});

            BalsamiqMockups.prototype.getMacroSettings = function(p_macroNode)
            {
                var macroDiv = AJS.$(p_macroNode);
                AJS.Rte.getEditor().selection.select(macroDiv[0]);

                return BM4C.getMacroParams(macroDiv);
            };

            BalsamiqMockups.prototype.editMacroSize = function(p_macroNode, p_value)
			{
				var macroDiv = AJS.$(p_macroNode);
				AJS.Rte.getEditor().selection.select(macroDiv[0]);
				AJS.Rte.BookmarkManager.storeBookmark();

				var params = BM4C.getMacroParams(macroDiv);

				if (p_value == "o") {
					delete params.Width; // Original is the default
				} else {
					params.Width = ((p_value == "s") ? 120 : 600);
				}

				var macroRenderRequest = {
					contentId : Confluence.Editor.getContentId(),
					macro : {
						name : "wireframe",
						params : params,
						defaultParameterValue : "",
						body : ""
					}
				};

				tinyMCE.confluence.MacroUtils.insertMacro(macroRenderRequest);
			};

			AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("balsamiq-mockups-macro-prop-align-left", function(e, macroNode)
			{
				BM4C.editMacroAlign(macroNode, "l");
			});
			AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("balsamiq-mockups-macro-prop-align-center", function(e, macroNode)
			{
				BM4C.editMacroAlign(macroNode, "c");
			});
			AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("balsamiq-mockups-macro-prop-align-right", function(e, macroNode)
			{
				BM4C.editMacroAlign(macroNode, "r");
			});

			BalsamiqMockups.prototype.editMacroAlign = function(p_macroNode, p_value)
			{
				var macroDiv = AJS.$(p_macroNode);
				AJS.Rte.getEditor().selection.select(macroDiv[0]);
				AJS.Rte.BookmarkManager.storeBookmark();

				var params = BM4C.getMacroParams(macroDiv);

				if (p_value == "c") {
					delete params.Alignment; // Center is the default
				} else {
					params.Alignment = ((p_value == "l") ? "Left" : "Right");
				}

				var macroRenderRequest = {
					contentId : Confluence.Editor.getContentId(),
					macro : {
						name : "wireframe",
						params : params,
						defaultParameterValue : "",
						body : ""
					}
				};

				tinyMCE.confluence.MacroUtils.insertMacro(macroRenderRequest);
			};
					
			BalsamiqMockups.prototype.getMacroParams = function(p_macro) {
				var macroParams = {};
				if (p_macro.data("macro-parameters")) {
					$.each(p_macro.data("macro-parameters").split("|"), function(idx, item) {
						var param = item.split("=");
						macroParams[param[0]] = param[1];
					});
				}
				return macroParams;
			};
			
			BM4C = new BalsamiqMockups();

            AJS.MacroBrowser.setMacroJsOverride('mockup', {opener : BM4C.launchBalsamiqMacroEditorV2});
            AJS.MacroBrowser.setMacroJsOverride('wireframe', {opener : BM4C.launchBalsamiqMockupsEditor});

			if (window.location.search.indexOf("openBalsamiq=true") != -1) {
			    // TODO: this should never happen
				BM4C.launchBalsamiqMockupsEditor({action: 1});
			}

            console.log("BWCS: loaded balsamiqmockups.js");
        }(AJS.$));
	});

} catch (err) {
	if (console && console.log) {
		console.log("Error loading balsamiqmockups.js");
		console.log(err);
	}
}

}catch(e){WRMCB(e)};
;
try {
/* module-key = 'confluence.macros.multimedia:macro-browser-smart-fields', location = 'javascript/macro-fields.js' */
(function(a){AJS.MacroBrowser.activateSmartFieldsAttachmentsOnPage("multimedia","swf avi mov mp4 mpeg mpg wmv wma mp3 ram rm".split(" "))})(AJS.$);
}catch(e){WRMCB(e)};
;
