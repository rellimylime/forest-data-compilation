    standardExtrasText = 'You (and the users who will use the form) must have edit permissions on this page. To reference field value use: [entry.field_name]. Must resolve into spaceKey:pageTitle or in pageId value. Leaving this parameter blank means current page';
    standardTitleText = standardTitleText + ' You can give/construct it in a form spacekey:title, just a title (and current space will be used) or pageId (numeric value)';

