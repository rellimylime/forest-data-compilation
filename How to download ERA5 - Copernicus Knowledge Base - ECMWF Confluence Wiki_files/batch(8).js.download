define('js/forms/config/textarea-macro', ['exports', 'js/forms/config/common'], function (exports, _common) {
    'use strict';

    Object.defineProperty(exports, "__esModule", {
        value: true
    });
    exports.addBindings = addBindings;
    function addBindings() {
        (0, _common.macroJsOverride)('mail-textarea', createTextAreaMacro);
    }

    function createTextAreaMacro(macro) {

        //Creates a new TextArea object that holds the parameters, or initial empty values
        var textArea = new _common.getMacroParameters(macro.params);

        //Calls the dialog with Edit or Insert accordingly.
        AJS.dialog2(Forms.Macros.TextArea.dialog({
            title: macro.body === undefined ? "Insert \u0027Textarea\u0027 Macro" : "Edit \u0027Textarea\u0027 Macro",
            buttonTitle: macro.body === undefined ? "Insert" : "Save",
            label: textArea.getLabel(),
            name: textArea.getName(),
            description: textArea.getDescription(),
            required: textArea.getRequired(),
            rows: textArea.getRows(),
            cssClass: textArea.getCssClass(),
            cssStyle: textArea.getCssStyle(),
            labelLength: textArea.getLabelLength(),
            fieldWidth: textArea.getFieldWidth(),
            value: textArea.getValue(),
            maxLength: textArea.getMaxLength()
        })).show();

        (0, _common.setupCommonBehaviour)("mail-textarea");
        (0, _common.setupCommonButtonsBehaviour)();
    }
});

