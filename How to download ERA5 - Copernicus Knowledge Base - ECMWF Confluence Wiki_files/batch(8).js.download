Forums.Macros.RestForum.dialog = function(opt_data, opt_ignored) {
  return '' + aui.dialog.dialog2({id: 'forumpalette-dialog', titleText: opt_data.title, modal: true, size: 'medium', content: '' + Forums.Macros.RestForum.content(opt_data), footerActionContent: '' + Forums.Macros.RestForum.footerContent(soy.$$augmentMap(opt_data, {docHrefHtml: 'https://docs.adaptavist.com/x/ppAOBg'}))});
};
if (goog.DEBUG) {
  Forums.Macros.RestForum.dialog.soyTemplateName = 'Forums.Macros.RestForum.dialog';
}


Forums.Macros.RestForum.content = function(opt_data, opt_ignored) {
  return '<div class="module custom-macro-dialog"><form id="forumPaletteForm" class="aui edit forum"><div role="application" class="aui-tabs horizontal-tabs"><ul role="tablist" class="tabs-menu"><li role="presentation" class="menu-item active-tab"><a aria-selected="true" role="tab" id="link-details" href="#tabs-details"><strong>' + soy.$$escapeHtml('Macro Options') + '</strong></a></li><li role="presentation" class="menu-item"><a aria-selected="false" role="tab" id="link-color" href="#tabs-color"><strong>' + soy.$$escapeHtml('Color Options') + '</strong></a></li></ul><div aria-hidden="false" role="tabpanel" class="tabs-pane active-pane" id="tabs-details"><fieldset class="details"><legend>' + soy.$$escapeHtml('Forum Details') + '</legend><div class="field-group group-name autocomplete-page-div"><label for="root-page">' + soy.$$escapeHtml('Forum root page') + '</label><input id="root-page" name="root-page" title="root-page" class="text medium-field autocomplete-page" data-max="10" data-none-message="No results" data-template="{space.key}:{title}" value="' + soy.$$escapeHtml(opt_data.page) + '"/><span class="aui-icon aui-icon-small aui-iconfont-info cheecky-aui-icon1" title="' + soy.$$escapeHtml('You can provide an alternative root page for your forum. All pages under the root will be topics in the forum and topics added to the forum will live under the root') + '"></span><div style="color: red" id="root-page-error"></div></div><div class="field-group group-name"><label for="no-of-topics" class="label-only">' + soy.$$escapeHtml('Number of topics displayed per page') + '</label><input id="no-of-topics" name="no-of-topics" class="text short-field"  value="' + soy.$$escapeHtml(opt_data.pageSize) + '"/><span class="aui-icon aui-icon-small aui-iconfont-info cheecky-aui-icon2" title="' + soy.$$escapeHtml('Number of topics displayed per page') + '" ></span><div style="color: red" id="no-of-topics-error"></div></div><div class="field-group group-name template-page-element"><label for="template-page">' + soy.$$escapeHtml('Topic template') + '</label><input id="template-page" name="template-page" class="text" type="text" value="' + soy.$$escapeHtml(opt_data.templatePageName) + '" templateId="' + soy.$$escapeHtml(opt_data.templatePageId) + '" /><span class="aui-icon aui-icon-small aui-iconfont-info cheecky-aui-icon3" title="' + soy.$$escapeHtml('Provide a template page which will be used for all newly created topics on this forum') + '"></span></div></fieldset><fieldset class="checkboxes"><div class="checkbox"><input type="checkbox" class="checkbox forum-config" name="sticky-on-top" id="sticky-on-top" value="true" ' + ((opt_data.stickyOnTop == 'true') ? 'checked="true"' : '') + '/><label class="adv-options">Advanced options</label><label for="sticky-on-top">' + soy.$$escapeHtml('Always show sticky topics on top') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Displaying the activity score is not necessary for enabling the activity score functionality') + '" ></span></div><div class="checkbox"><input type="checkbox" class="checkbox forum-config" name="sub-forum" id="sub-forum" value="true" ' + ((opt_data.recurse == 'true') ? 'checked="true"' : '') + ' /><label for="sub-forum">' + soy.$$escapeHtml('Include topics from sub-forums') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('The forum table will display all topics and sub-topics from across the forum and sub-forums') + '" ></span></div><div class="checkbox"><input type="checkbox" class="checkbox forum-config" name="show-excerpt" id="show-excerpt" value="true" ' + ((opt_data.showExcerpt == 'true') ? 'checked="true"' : '') + ' /><label for="show-excerpt">' + soy.$$escapeHtml('Show Excerpt') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('First checks to see whether a child page contains an \x22Excerpt\x22 macro and shows the contents, otherwise it displays the contents of the Confluence Page Excerpt feature') + '" ></span></div></fieldset></div><div aria-hidden="true" role="tabpanel" class="tabs-pane" id="tabs-color"><fieldset class="advanced"><div class="checkbox color-options"><label for="override-background-color">' + soy.$$escapeHtml('Override background color') + '</label><input type="checkbox" class="checkbox forum-config" name="override-background-color" id="override-background-color" value="true" ' + ((opt_data.overrideBackgroundColor == 'true') ? 'checked="true"' : '') + ' /><input type="text" id="background-color" class="form-control demo" data-control="hue" ' + ((opt_data.overrideBackgroundColor == 'true') ? 'value="' + soy.$$escapeHtml(opt_data.backgroundColor) + '" ' : 'value="#4a6785"') + ' /><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Overrides the default banner color scheme for this Forum') + '" ></span></div><div class="checkbox color-options"><label for="override-text-color">' + soy.$$escapeHtml('Override text color') + '</label><input type="checkbox" class="checkbox forum-config" name="override-text-color" id="override-text-color" value="true" ' + ((opt_data.overrideTextColor == 'true') ? 'checked="true"' : '') + ' /><input type="text" id="text-color" class="form-control demo" data-control="hue" ' + ((opt_data.overrideTextColor == 'true') ? 'value="' + soy.$$escapeHtml(opt_data.textColor) + '" ' : 'value=\'#ffffff\'') + ' /><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Overrides the default banner text color scheme for this Forum') + '" ></span></div></fieldset></div></div><button style="display:none" id="hiddenButton" type="submit"></button></form></div>';
};
if (goog.DEBUG) {
  Forums.Macros.RestForum.content.soyTemplateName = 'Forums.Macros.RestForum.content';
}


Forums.Macros.RestForum.footerContent = function(opt_data, opt_ignored) {
  return '<fieldset class="palette-footer"><div class="custom-macro-footer"><div class="aui-group align-bottom aui-group-split"><div class="aui-item"><a class="" href="' + soy.$$escapeHtml(opt_data.docHrefHtml) + '" target="_blank">' + soy.$$escapeHtml('Documentation') + '</a></div><div class="aui-item"><button class="aui-button aui-button-primary" id="insertButtonGroup" type="submit">' + soy.$$escapeHtml('Save') + '</button><a class="aui-button aui-button-link" href="#" id="cancelButtonGroup">' + soy.$$escapeHtml('Close') + '</a></div></div></div></fieldset>';
};
