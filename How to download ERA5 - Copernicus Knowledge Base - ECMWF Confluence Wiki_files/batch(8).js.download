function setPageRef() {
  var pageId = AJS.$("#paramTable").find('#pageIdParamInput').val();
  AJS.$('#macro-param-extras').val(pageId);
}

function setSmartValues() {
  var pageId = AJS.$("#paramTable").find('#pageIdParamInput').val();
  var formName = AJS.$("#paramTable").find('#formNameParamInput').val();
  var fieldName = AJS.$("#paramTable").find('#fieldNameParamInput').val();
  var checked = AJS.$("#paramTable").find('#fieldNameParamInputAsValue').is(':checked');
  var sorting = AJS.$("#paramTable").find('#fieldNameParamInputSorting').val();
  var labelFieldName = AJS.$("#paramTable").find('#fieldNameParamInputLabelFieldName').val();

  if (pageId !== '' && formName !== '' && fieldName !== '') {
    AJS.$('#macro-param-values').val('[' + pageId + '|' + formName + '|' + fieldName + '|' + checked + '|' + sorting + '|' + labelFieldName + ']');
  }
  AJS.MacroBrowser.processRequiredParameters();
}

function setDynamicExtras() {
  var pageId = AJS.$("#paramTable").find('#pageIdParamInput').val();
  var formName = AJS.$("#paramTable").find('#formNameParamInput').val();
  var fieldName = AJS.$("#paramTable").find('#fieldNameParamInput').val();
  var checked = AJS.$("#paramTable").find('#fieldNameParamInputAsValue').is(':checked');
  var sorting = AJS.$("#paramTable").find('#fieldNameParamInputSorting').val();

  if (pageId !== '' && formName !== '' && fieldName !== '') {
    AJS.$('#macro-param-values').val('[' + pageId + '|' + formName + '|' + fieldName + '|' + checked + '|' + sorting + ']');
  }

  var trackChangesE = AJS.$("#macro-param-type-values").find('#trackChanges');
  var trackChanges = (trackChangesE ? trackChangesE.is(':checked') : '');

  var params = trackChanges + '[';
  AJS.$("#paramTable tr.values_toStore").each(function () {
    params = params + AJS.$(this).find('.i_macro-id-input').val() + '=' + AJS.$(this).find('.i_macro-value-input').val() + '|';
  });
  params = params + ']';

  AJS.$('#macro-param-extras').val(params);
  AJS.MacroBrowser.processRequiredParameters();
}

