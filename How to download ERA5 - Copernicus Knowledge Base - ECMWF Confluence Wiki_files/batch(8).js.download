function getStatusChoices(id) {
  return '<td style="max-width: 16%">' + getRadioChoiceForStatus(id, 'default') + '<span class="aui-lozenge">&nbsp;&nbsp;&nbsp;&nbsp;</span></input></td>' +
    '<td style="max-width: 16%">' + getRadioChoiceForStatus(id, 'success') + '<span class="aui-lozenge aui-lozenge-success">&nbsp;&nbsp;&nbsp;&nbsp;</span></input></td>' +
    '<td style="max-width: 16%">' + getRadioChoiceForStatus(id, 'error') + '<span class="aui-lozenge aui-lozenge-error">&nbsp;&nbsp;&nbsp;&nbsp;</span></input></td>' +
    '<td style="max-width: 16%">' + getRadioChoiceForStatus(id, 'current') + '<span class="aui-lozenge aui-lozenge-current">&nbsp;&nbsp;&nbsp;&nbsp;</span></input></td>' +
    '<td style="max-width: 16%">' + getRadioChoiceForStatus(id, 'complete') + '<span class="aui-lozenge aui-lozenge-complete">&nbsp;&nbsp;&nbsp;&nbsp;</span></input></td>' +
    '<td style="max-width: 16%">' + getRadioChoiceForStatus(id, 'moved') + '<span class="aui-lozenge aui-lozenge-moved">&nbsp;&nbsp;&nbsp;&nbsp;</span></input></td>';
}

