/* module-key = 'org.swift.confluence.sql:sql-editor-resources', location = 'scripts/editor/sql-editor-util.js' */
/*
 * Copyright (c) 2019 Appfire Technologies, Inc.
 * All rights reserved.
 *
 * This software is licensed under the provisions of the "Bob Swift Atlassian Add-ons EULA"
 * (https://bobswift.atlassian.net/wiki/x/WoDXBQ) as well as under the provisions of
 * the "Standard EULA" from the "Atlassian Marketplace Terms of Use" as a "Marketplace Product"
 * (http://www.atlassian.com/licensing/marketplace/termsofuse).
 *
 * See the LICENSE file for more details.
 */

(function(appsqlutil, $, undefined) {
    'use strict';
    appsqlutil.isExpress = false; //This var is used across js files to indicate if express installed or pro
    /**
     * Macro params common to all SQL macros with default values
     * Param Count=41 (excluding parameter markers)
     */
    appsqlutil.defaultSqlParms = {
        autoNumberSort: false,
        autoCommit: true,
        columnLabel: false,
        convertNull: true,
        dataSource: "",
        disableAntiXss: false,
        encoding: "",
        escape: false,
        expandArray: true,
        heading: 1,
        macros: false,
        limit: "Default",
        noDataError: false,
        noDataMessage: "",
        output: "html",
        queryTimeout: "Default",
        rowOrientation: "vertical",
        showUpdateCount: false,
        showWiki: false,
        table: true,
        transactionIsolation: "DEFAULT",
        parameterMarkers:[]
    }
    
    appsqlutil.getDocumentationLink = function(macroName){
            switch (macroName) {
              case "sql":
                return "https://apps.appf.re/sql/doc/p2/userguide/sqlmacro";
              case "sql-query":
                return "https://apps.appf.re/sql/doc/p2/userguide/sqlquerymacro";
              case "sql-file":
                return "https://apps.appf.re/sql/doc/p2/userguide/sqlfilemacro";
            }
        }
    
    /**
     * Get the macro name as displayed when inserting/editing macro.
     */
    appsqlutil.getPrettyMacroName = function(macroName){
        switch (macroName) {
          case "sql":
            return "SQL";
          case "sql-query":
            return "SQL Query";
          case "sql-file":
              return "SQL File";
        }
    }
    
    /**
     * This method is used for parameter marker(p1..pn) macro param (i.e  to assign it to custom editor parameter array i.e parameterMarkers[])
     */
    appsqlutil.convertParameterMarkersToArray = function(macroParams){
        //reinitialize parameterMarkers
        macroParams.parameterMarkers = [];
        for (var marker in macroParams) {
            if (marker.match(/p[0-9]+/g)){
                var index = marker.substring(1);
                macroParams.parameterMarkers[index-1] = macroParams[marker];
            }
        }
        $.extend(macroParams, {parameterMarkers : macroParams.parameterMarkers});
        
        return macroParams; 
    }
    /**
     * Prefix p along with the row number
     */
    appsqlutil.numberGridRows = function($grid) {
        $grid.find(".row-number").each(function(i) {
            $(this).text('p'+ (i+1));
          });
    }

}(window.appsqlutil = window.appsqlutil || {}, AJS.$));
}catch(e){WRMCB(e)};
;
try {
/* module-key = 'org.swift.confluence.sql:sql-editor-resources', location = 'scripts/editor/sql-editor.js' */
/*
 * Copyright (c) 2019 Appfire Technologies, Inc.
 * All rights reserved.
 *
 * This software is licensed under the provisions of the "Bob Swift Atlassian Add-ons EULA"
 * (https://bobswift.atlassian.net/wiki/x/WoDXBQ) as well as under the provisions of
 * the "Standard EULA" from the "Atlassian Marketplace Terms of Use" as a "Marketplace Product"
 * (http://www.atlassian.com/licensing/marketplace/termsofuse).
 *
 * See the LICENSE file for more details.
 */

/*jshint esversion: 6 */
'use strict';

AJS.bind("init.rte", function(evt) {
    //console.log("appfire: event=" + evt.type + "; macro name=sql");
    (function ($) {
        //validate fields indicated as required
        var validateRequiredInputFields = function(dialog, errors){
            var contentPane = dialog.find(".appfire-content-panes");
            var requiredElements = contentPane.find(".appfire-editor-input-required");
            requiredElements.each(function(index) {
                if(!$(this).val().trim()){
                    var elementName = appcme.getDisplayLabelText($(this));
                    if($(this).attr('id') == "dataSource"){
                        elementName =  "Data source profile";
                    }
                    errors.push({ ele: $(this), msg: "<p>" + AJS.format("{0} cannot be empty.",  elementName) + "</p>"});
                }
            });
        }
          
        //Either sql editor shall be filled in or a file/attachment/template should be given for macro to render data, else a validation error
        var validateAtleastOneSQLSourceGiven = function(dialog, errors){
            if(!dialog.find(".appfire-table-datalocation").val() && !dialog.find(".appfire-sql-editor-query-textarea").val().trim()){
                errors.push({ ele: dialog.find(".appfire-sql-editor-query-textarea"), msg: "<p>" + AJS.format("{0} cannot be empty."," SQL statement") + "</p>"});
            }
        }
        
        var editorGeneratorSql = function(macroDetails) {
            var parms = appcme.parametersToObj(sqlDefaultParms, macroDetails.params, tablebasecme.DELIMITER, tablebasecme.QUOTE);
            //Note: dataTypeToLocate is used to display the label "method of locating xxx data" in data-location-template.soy
            $.extend(parms, {macroName: macroDetails.name, macroBody: (macroDetails.body ? macroDetails.body.trim() : ''), dataTypeToLocate: 'SQL' , isExpress: appsqlutil.isExpress }); 
            parms = tablebasecme.splitScriptParam(parms);
            parms = appsqlutil.convertParameterMarkersToArray(parms);

            return {
                icon: "/download/resources/org.swift.confluence.sql/img/sql-32x32.png",
                title: "SQL for Confluence - " +appsqlutil.getPrettyMacroName(macroDetails.name) + " macro",
                showPreview: true,
                //datalocationfields: "true" for those macros (csv, json-table, sql, sql-query) where script macro param is supported and split into space, page, attachment select2 fields
                dataAttributes: {commontableeditor: "true", datalocationfields: "true" }, // required for all apps built around the common table editors for common event
                navigation: {
                    primary: [
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.sql/img/icon-sql-settings-48-wht-on-clr.png"),
                            name: "SQL settings",
                            panel: org.swift.confluence.sql.editor.sqlSettingsPanel(parms)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.sql/img/icon-display-settings-48-wht-on-clr.png"),
                            name: "Display settings",
                            panel: org.swift.confluence.sql.editor.displaySettingsPanel(parms)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/table-editor/img/icon-nav-table-48-wht-on-clr.png"),
                            name: "Table settings",
                            panel: org.swift.confluence.table.editor.tableSettingsPanel(parms)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/table-editor/img/icon-nav-columns-48-wht-on-clr.png"),
                            name: "Column settings",
                            panel: org.swift.confluence.table.editor.columnSettingsPanel(parms)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/table-editor/img/icon-nav-rows-48-wht-on-clr.png"),
                            name: "Row formatting",
                            panel: org.swift.confluence.table.editor.rowSettingsPanel(parms)
                        }
                    ],
                    secondary: [
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/editor/img/icon-nav-guide-48-wht-on-clr.png"),
                            name: appsqlutil.getPrettyMacroName(macroDetails.name) + " guide",
                            url:  appsqlutil.getDocumentationLink(macroDetails.name)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/editor/img/icon-nav-docs-48-wht-on-clr.png"),
                            name: appsqlutil.getPrettyMacroName(macroDetails.name) + " documentation",
                            url:  "https://apps.appf.re/sql/doc/p2/userguide"
                        }
                    ],
                },
                /**
                 * Validate form fields. 
                 * Input Parameters:
                 *      dialog - The jQuery editor dialog 
                 *      form - The jQuery form from the dialog 
                 * Return Parameters:
                 *      errors - This is a property array.  Each array element contains the message and an optional jQuery element for the error.  
                 * Return: 
                 *      True if the form validates correctly and can be saved. False if there are any errors. The form will not be allowed to close in that case. 
                 */
                validator: function (dialog, form, errors) {
                    var err = form.data('errors')
                    $(err).each(function() {
                        errors.push({ele: this.ele, msg: this.msg});
                    }); 
                    validateRequiredInputFields(dialog, errors);
                    tablebasecme.validateDataLocationFields(dialog, errors);
                    validateAtleastOneSQLSourceGiven(dialog, errors);
                    return tablebasecme.validateCommonTableParams(dialog, errors);
                }
            };
        };
        
        var editorGeneratorSqlFile = function(macroDetails) {
            var parms = appcme.parametersToObj(sqlFileDefaultParms, macroDetails.params, tablebasecme.DELIMITER, tablebasecme.QUOTE);
            //Note: dataTypeToLocate is used to display the label "method of locating xxx data" in data-location-template.soy
            $.extend(parms, {macroName: macroDetails.name, macroBody: (macroDetails.body ? macroDetails.body.trim() : ''), dataTypeToLocate: 'SQL', isExpress: appsqlutil.isExpress }); 
            parms = appsqlutil.convertParameterMarkersToArray(parms);
    
            return {
                icon: "/download/resources/org.swift.confluence.sql/img/sql-32x32.png",
                title: "SQL for Confluence - " + appsqlutil.getPrettyMacroName(macroDetails.name) + " macro",
                showPreview: true,
                //datalocationfields: "true" for those macros (csv, json-table, sql, sql-query) where script macro param is supported and split into space, page, attachment select2 fields
                dataAttributes: {commontableeditor: "true"}, // required for all apps built around the common table editors for common event
                navigation: {
                    primary: [
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.sql/img/icon-sql-settings-48-wht-on-clr.png"),
                            name: "SQL settings",
                            panel: org.swift.confluence.sql.editor.sqlSettingsPanel(parms)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.sql/img/icon-display-settings-48-wht-on-clr.png"),
                            name: "Display settings",
                            panel: org.swift.confluence.sql.editor.displaySettingsPanel(parms)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/table-editor/img/icon-nav-table-48-wht-on-clr.png"),
                            name: "Table settings",
                            panel: org.swift.confluence.table.editor.tableSettingsPanel(parms)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/table-editor/img/icon-nav-columns-48-wht-on-clr.png"),
                            name: "Column settings",
                            panel: org.swift.confluence.table.editor.columnSettingsPanel(parms)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/table-editor/img/icon-nav-rows-48-wht-on-clr.png"),
                            name: "Row formatting",
                            panel: org.swift.confluence.table.editor.rowSettingsPanel(parms)
                        }
                    ],
                    secondary: [
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/editor/img/icon-nav-guide-48-wht-on-clr.png"),
                            name: appsqlutil.getPrettyMacroName(macroDetails.name) + " guide",
                            url:  appsqlutil.getDocumentationLink(macroDetails.name)
                        },
                        {
                            icon: appcme.absolutePath("/download/resources/org.swift.confluence.tablesorter/editor/img/icon-nav-docs-48-wht-on-clr.png"),
                            name: appsqlutil.getPrettyMacroName(macroDetails.name) + " documentation",
                            url:  "https://apps.appf.re/sql/doc/p2/userguide"
                        }
                    ],
                },
                /**
                 * Validate form fields. 
                 * Input Parameters:
                 *      dialog - The jQuery editor dialog 
                 *      form - The jQuery form from the dialog 
                 * Return Parameters:
                 *      errors - This is a property array.  Each array element contains the message and an optinal jQuery element for the error.  
                 * Return: 
                 *      True if the form validates correctly and can be saved. False if there are any errors. The form will not be allowed to close in that case. 
                 */
                validator: function (dialog, form, errors) {
                    validateRequiredInputFields(dialog, errors);
                    return tablebasecme.validateCommonTableParams(dialog, errors);
                }
            };
        };
        
        //This is list of common table params (defined in table-library) and common sql params
        var sqlDefaultCommonParms = $.extend({}, tablebasecme.commonTableParams, appsqlutil.defaultSqlParms);
        
        //Total param count=46 (excluding parameter markers)
        //sql specific params here. Note that sql and sql-query macros share same set of params
        const sqlParms = {
                script: "",
                showSql: false,
                showSqlOptions: "",
                border: "",
                width: ""
        }
        
        var sqlDefaultParms = $.extend({}, sqlDefaultCommonParms, sqlParms );
        //sql and sql-query macros share same set of parameters. They differ only in execution
        appcme.setMacroJsOverride('sql', sqlDefaultParms, editorGeneratorSql);
        appcme.setMacroJsOverride('sql-query', sqlDefaultParms, editorGeneratorSql);
        
        //Total param count=42 (excluding parameter markers)
        //sql-file Specific params here. 
        const sqlFileParms = {
                file: "",
        }
        
        var sqlFileDefaultParms = $.extend({}, sqlDefaultCommonParms, sqlFileParms );
        appcme.setMacroJsOverride('sql-file', sqlFileDefaultParms, editorGeneratorSqlFile);
       
    }(AJS.$));
});
}catch(e){WRMCB(e)};
;
try {
/* module-key = 'org.swift.confluence.sql:sql-editor-resources', location = 'scripts/editor/sql-editor-events.js' */
/*
 * Copyright (c) 2019 Appfire Technologies, Inc.
 * All rights reserved.
 *
 * This software is licensed under the provisions of the "Bob Swift Atlassian Add-ons EULA"
 * (https://bobswift.atlassian.net/wiki/x/WoDXBQ) as well as under the provisions of
 * the "Standard EULA" from the "Atlassian Marketplace Terms of Use" as a "Marketplace Product"
 * (http://www.atlassian.com/licensing/marketplace/termsofuse).
 *
 * See the LICENSE file for more details.
 */
//This has to be loaded first
(function(sqlcme, $, undefined) {
    'use strict';
    var fetchTableData = function (editor, url) {
        var tableSearch = editor.find('#metadata-table-search');
        tableSearch.auiSelect2({ data: []}); //Initialise with empty data until data is loaded.
        editor.find("#s2id_metadata-table-search").find(".select2-chosen").html("\u003cspan id=\u0022still-loading\u0022 class=\u0022aui-icon aui-icon-wait\u0022\u003eLoading...\u003c/span\u003e&nbsp;Please wait while we load the tables...");
        tableSearch.auiSelect2("enable", false); //disable select2 while the results load
        
        return $.ajax({
            url: url,
            type: 'GET',
            contentType: 'application/json; charset=utf-8',
            cache: true,
           // timeout:600000 // timeout commented, until we support timeout in java code
       });
    }

    var fetchColumnData = function (editor, url) {
        editor.find("#s2id_metadata-column-search").find(".select2-chosen").html('<span id="still-loading" class="aui-icon aui-icon-wait">Loading...</span>&nbsp;'+"Please wait while we load the columns...");
        $('#metadata-column-search').auiSelect2("enable", false); //disable select2 while the results load
        
        return $.ajax({
            url: url,
            type: 'GET',
            contentType: 'application/json; charset=utf-8',
            cache: true,
       });
    }
    
    var getIconTable = function(type){
        if(type === 'table'){
            return '<span class="aui-icon aui-icon-small aui-iconfont-editor-table aui-iconfont-table sql-text-icon-align"></span>';
        }
        else{
            return '<span class="aui-icon aui-icon-small aui-iconfont-view aui-iconfont-watch-filled"></span>';  
        }
    }
    
    var getIconColumn = function(){
        return '<span class="aui-icon aui-icon-small aui-iconfont-pause aui-iconfont-board sql-text-icon-align"></span>';  
    }
    
    var displayTableError = function(element, errorMessage){
        errorMessage = escapeSpecialChars(errorMessage);
        var $icon = $("#show-editor-error");
        var $msg = $("#editor-error-msg");
        $msg.find(".body").html('<div class="inline-dialog-error-content">'+errorMessage+'</div>');
        $icon.show();
        $msg.attr("open", "");
        element.addClass("form-error");
        $('#s2id_metadata-table-search').find('.select2-choice').addClass('disable-select2');
        $('#s2id_metadata-table-search').find(".select2-chosen").html(''); //empty table placeholder
        $('#metadata-table-search').val('')//empty table value

        setColumnMetadataEmpty();
    }
    
    
    var setColumnMetadataEmpty = function(){
        var columnSearch = $('#metadata-column-search');
        columnSearch.attr('placeholder','');
        columnSearch.auiSelect2({data: [], multiple: true}); 
        columnSearch.auiSelect2("enable", false);
    }
    
    var setTableMetadataEmpty = function(){
        $('#s2id_metadata-table-search').find('.select2-choice').addClass('disable-select2');
        $('#s2id_metadata-table-search').find(".select2-chosen").html(''); //empty table placeholder
        $('#metadata-table-search').val('')//empty table value
    }
    var displayUnsupportedDBError = function(element, errorMessage){
        errorMessage = escapeSpecialChars(errorMessage);
        //Change default error icon to warning icon
        var $icon = $("#show-editor-error");
        $icon.removeClass('aui-iconfont-error');
        $icon.addClass('aui-iconfont-warning');
        $icon.addClass('custom-icon-align');
        $icon.show();
        //get custom error content to hide title
        var customErrorContent = org.swift.confluence.sql.editor.getCustomErrorContent({'content':errorMessage });
        var $msg = $("#editor-error-msg");
        $msg.find('#default-error-content').hide();
        $msg.find('.aui-inline-dialog-contents').append(customErrorContent);
        $msg.attr("open", "");
        
        element.addClass("form-error");
        setTableMetadataEmpty();
        
        setColumnMetadataEmpty();
    }
    
    var displayColumnError = function(element, errorMessage){
        errorMessage = escapeSpecialChars(errorMessage);
        var $icon = $("#show-editor-error");
        var $msg = $("#editor-error-msg");
        $msg.find(".body").html('<div class="inline-dialog-error-content">'+errorMessage+'</div>');
        $icon.show();
        $msg.attr("open", "");
        element.addClass("form-error");
        setColumnMetadataEmpty();
    }
    
    var loadMetadata = function(editor, reload){
        var metadataElement = editor.find("#metadata-table-search");
        var profileName = encodeURIComponent(editor.find("#dataSource").auiSelect2('val'));
        $.when(fetchTableData(editor, AJS.contextPath() + '/rest/bobswift/sql/1.0/profile/tables/'+profileName.trim() + (reload ? "?reload=true":'')))
        .then(function (response) {
            metadataElement.attr("placeholder", "Select tables and views");
            editor.find(".metadata-container").show();
            metadataElement.auiSelect2("enable", true);
            metadataElement.auiSelect2({
                 placeholder:  "Select tables and views",
                 closeOnSelect: false,
                 data: response,
                 // query with pagination
                 query: function(q) {
                   var pageSize,
                     results,
                     that = this;
                   pageSize = 20; // or whatever pagesize
                   editor.find("#s2id_metadata-table-search").find(".select2-chosen").html("Select tables and views");
                   results = [];
                   if (q.term && q.term !== '') {
                       console.log("No of tables searched "+that.data.length);
                       results = that.data.filter(function(table) {
                       return table.text.toUpperCase().indexOf(q.term.toUpperCase()) >= 0;
                     });
                   } else if (q.term === '') {
                     results = that.data;
                   }
                   q.callback({
                     results: results.slice((q.page - 1) * pageSize, q.page * pageSize),
                     more: results.length >= q.page * pageSize,
                   });
                 },
                 formatSelection: function(opt){
                     return getIconTable(opt.type) +' '+ opt.text; 
                 },
                 escapeMarkup: function(m) { 
                     return m;  //This is to escape the markup in the text
                 },
                 formatResult: function(opt){
                     return getIconTable(opt.type) +' '+ opt.text; //TODO: Add image here instead of java side
                 },
                 error: function (jqXHR, status, error) {
                     callback({ 
                         id: "Error while loading tables.",
                         text: "Error while loading tables."
                      });
                 },
                 params: {
                  //Any error like url itself is not a valid one
                  error: function(response) {
                      if(response.status == 404)
                          console.log("Looks like invalid metadata url.");
                      }
                 }
           });  
         })
         .fail(function(jqXHR, textStatus){
             editor.find(".metadata-container").show();
             var reason='';
             
             if(jqXHR.responseText)
                 reason = jqXHR.responseText;
             else
                 reason = "An error occurred loading the list of tables for the selected Data source profile."
                 
             if(jqXHR.status == 501){
                 displayUnsupportedDBError(editor.find("#metadata-table-search"), reason);
             }else{
                 displayTableError( editor.find("#metadata-table-search"), reason);
             }
             console.log("Fetch table request failed..."+ textStatus); 
         })
         .done(function(){
             console.log("Fetch table request done...")
         });//end ajax.then
    }
    
    var loadColumns = function(editor){
       var columnSearch = editor.find("#metadata-column-search");
       var profileName = editor.find("#dataSource").auiSelect2('val');
       profileName = encodeURIComponent(profileName);
       var columnUrl =  AJS.contextPath() + '/rest/bobswift/sql/1.0/profile/columns/' + profileName.trim() + '/' + editor.find("#metadata-table-search").auiSelect2('val').trim()+'/';
       $.when(fetchColumnData(editor, columnUrl))
       .then(function (response) {
           editor.find("#s2id_metadata-column-search").find(".select2-chosen").html("Select columns");
           columnSearch.attr("placeholder", "Select columns");
           columnSearch.auiSelect2("enable", true);
           columnSearch.auiSelect2({
               placeholder: "Select columns",
               //closeOnSelect: false,
               data: response,
               multiple: true,
               allowClear: true,
            // query with pagination
               query: function(q) {
                 var pageSize,
                   results,
                   that = this;
                 pageSize = 20; // or whatever pagesize
                editor.find("#s2id_metadata-column-search").find(".select2-chosen").html("Select columns");
                 results = [];
                 if (q.term && q.term !== '') {
                     console.log("No of columns searched"+that.data.length);
                     results = that.data.filter(function(table) {
                     return table.text.toUpperCase().indexOf(q.term.toUpperCase()) >= 0;
                   });
                 } else if (q.term === '') {
                   results = that.data;
                 }
                 q.callback({
                   results: results.slice((q.page - 1) * pageSize, q.page * pageSize),
                   more: results.length >= q.page * pageSize,
                 });
               },
               formatSelection: function(opt){
                   return getIconColumn() +' '+ opt.id; 
               },
               escapeMarkup: function(m) { 
                   return m;  //This is to escape the markup in the text
               },
               formatResult: function(opt){
                   return getIconColumn() +' '+ opt.text; //TODO: Add image here instead of java side
               },
               error: function (jqXHR, status, error) {
                   callback({ 
                       id: "Error while loading columns.",
                       text: "Error while loading columns."
                    });
               },
               params: {
                //Any error like url itself is not a valid one
                error: function(response) {
                    if(response.status == 404)
                        console.log("Looks like invalid metadata url.");
                    }
               }
           });
       }).fail(function(jqXHR, textStatus){
           console.log("Fetch column request failed..."+ textStatus); 
           var reason='';
           if(jqXHR.responseText){
               reason = jqXHR.responseText;
           }
           else{
               reason = "Error loading the columns for selected table or view."
           }
           //editor.find("#s2id_metadata-column-search").find(".select2-chosen").html("Select columns");
           displayColumnError( editor.find("#metadata-column-search"), reason);
       }).done(function(){
           console.log("Fetch column request done...")
       });
      
    }//end of function
    
    var addTableToSql =  function(thisForm, item){
      //add item at cursor position in the textarea
        var sqlTextarea = thisForm.find(".appfire-sql-editor-query-textarea");
        var sqlText = sqlTextarea.val();
        if (sqlText.trim().length) {
            if(!start && !finish){ //start and finish not defined yet for the very first time dialog loads
                start = finish = sqlText.length; 
            }
            var newText = sqlText.substring(0, start) + item + sqlText.substring(finish, sqlText.length);
            sqlTextarea.val(newText);
            finish = start+item.length;
            start = start+item.length;
        }
        else{
            sqlTextarea.val("select * from " + item);
            start = "select *".length - 1;
            finish = "select *".length;
            sqlTextarea.selectRange(start,finish);
        }
        //clearSelection(thisForm);
    }
    
    var addColumnToSql =  function(thisForm, item){
        //add item at cursor position in the textarea
          var sqlTextarea = thisForm.find(".appfire-sql-editor-query-textarea");
          var sqlText = sqlTextarea.val();
          if (sqlText.trim().length) {
              if(item.length){
                  var newText = sqlText.substring(0, start) + item + sqlText.substring(finish, sqlText.length);
                  sqlTextarea.val(newText);
              }
              finish = start+item.length;
              start = start+item.length;
          }
          else{
              var table = thisForm.find("#metadata-table-search").auiSelect2('val');
              if(!item.length){
                  item = '*';
                  start = "select *".length - 1;
                  finish = "select *".length;
              }
              sqlTextarea.val("select " + item + " from " + table);
              sqlTextarea.selectRange(start,finish);
          }
        //  clearSelection(thisForm);
    }
    
    /*var clearSelection = function(thisform){
        $('.appfire-sql-editor-query-textarea').highlightWithinTextarea('destroy');
        thisform.find('.hwt-content').find('mark').each(function(index, item) {
            $(item).css('background-color','white');
        });
    }*/
    
    var isSelect2Enabled = function(element){
        return element.data('select2') && element.data('select2')._enabled;
    }
    
    $.fn.selectRange = function(start, end) {
        return this.each(function() {
          if(this.setSelectionRange) {
            this.focus();
            this.setSelectionRange(start, end);
          } else if(this.createTextRange) {
            var range = this.createTextRange();
            range.collapse(true);
            range.moveEnd('character', end);
            range.moveStart('character', start);
            range.select();
          }
        });
      };
      
    /**
     * On click of insert menu "sql-query" link, 1st native browser dialog shows up for a second until our opener code calls up. 
     * Workaround is to hide the native macro browser then.
     * "sql-query" -> its the linkid given in the atlassian-plugin.xml for the web-item
     */
    $(document).on("click", "#sql-query", function() {
        $("#macro-browser-dialog:visible").hide();
    });
    
    var start = 0;
    var finish = 0;

    $(document).on("focusout", ".appfire-sql-editor-query-textarea", function (e) {
        var macroName = $(e.target).closest("[data-appfire-macro-name]").data("appfireMacroName");
          if(!appsqlutil.isExpress && macroName != 'sql-file') {
              // obtain the index of the first selected character
              start = this.selectionStart;
              // obtain the index of the last selected character
              finish = this.selectionEnd;
            //  $(this).highlightWithinTextarea({highlight: [start, finish]}); //Commenting highlightWithinTextarea in 10.1.0 release as there are some outstanding issues(SQL-1061).
        }
    });
    
    $(document).on("click", ".appfire-preview-actions", function() {
        var thisForm = $(this).closest("form");
        if($(".appfire-preview-container").is(":visible")){
            thisForm.find('#metadata-table-container').removeClass('sql-metadata-table-container');
            thisForm.find('#metadata-table-container').addClass('metadata-table-container-preview-on');
            thisForm.find('#metadata-column-container').removeClass('sql-metadata-table-container');
            thisForm.find('#metadata-column-container').addClass('metadata-column-container-preview-on');
            
            thisForm.find('.table-search-div').addClass('table-search-div-preview-on');
            thisForm.find('.column-search-div').addClass('column-search-div-preview-on');
        }else{
            thisForm.find('#metadata-table-container').removeClass('metadata-table-container-preview-on');
            thisForm.find('#metadata-table-container').addClass('sql-metadata-table-container');
            thisForm.find('#metadata-column-container').removeClass('metadata-column-container-preview-on');
            thisForm.find('#metadata-column-container').addClass('sql-metadata-table-container');
            
            thisForm.find('.table-search-div').removeClass('table-search-div-preview-on');
            thisForm.find('.column-search-div').removeClass('column-search-div-preview-on');
        }
        //$(".editor-area").width($(".scrollable-tab-content fieldset").first().width()); //SQL-1042
    });
    
    $(document).on("click", ".add-table", function (e) {
        e.preventDefault();
        var thisForm = $(this).closest("form");
        var tableElement = thisForm.find("#metadata-table-search");
        if(isSelect2Enabled(tableElement)){
            var table = tableElement.auiSelect2('val');
            addTableToSql($(this).closest("form"), table);
        }
    });
    
    $(document).on("click", ".add-column", function (e) {
        e.preventDefault();
        var thisForm = $(this).closest("form");
        var columnElement = thisForm.find("#metadata-column-search");
        if(isSelect2Enabled(columnElement)){
            var item = columnElement.auiSelect2('val');
            var columns = '';
            $.each(item, function( index, col ) {
                columns = columns +  col + (index < item.length - 1 ? ', ' : '');
            });
            addColumnToSql($(this).closest("form"), columns);
            columnElement.auiSelect2('val','');//reset column
        }
    });

    $(document).on('hover', ".metadata-tooltip", function() {
        $(this).tooltip();
    });
    
    //Append selected table or column to query editor text
    $(document).on('change', "#metadata-table-search", function() {
        var thisForm = $(this).closest("form");
        appcme.clearValidationErrors(thisForm);
        var columnSearch = thisForm.find('#metadata-column-search');
        columnSearch.auiSelect2({placeHolder: 'please wait', data: []}); //initialise with empty select2 to indicate data loading
        loadColumns(thisForm);
    });
    
    /**
     * If table selected and unselected, the selected value still stays. Here is the workaround to explicitly set val to empty if nothing chosen
     */
    $(document).on('select2-close','#metadata-table-search', function(){
        var thisForm = $(this).closest("form");
        if( thisForm.find("#s2id_metadata-table-search").find(".select2-chosen").html() == "Select tables and views"){
            $("#metadata-table-search").auiSelect2('val','');
        }
    });
    
    var escapeSpecialChars = function(originalString) {
        return originalString.replace(/"/g, '\\"').replace(/'/g,"\\'");
     }
    
    var displayProfileNotValidError = function(selectedProfile, errorMessage){
        errorMessage = escapeSpecialChars(errorMessage);
        var thisForm = selectedProfile.closest("form");
        var $icon = $("#show-editor-error");
        var $msg = $("#editor-error-msg");
        $msg.find(".body").html('<div class="inline-dialog-error-content">' + errorMessage + '</div>');
        $icon.show();
        $msg.attr("open", "");
        thisForm.find('#s2id_dataSource').addClass("form-error"); //TODO: Should we allow to save the custom editor??
        setTableMetadataEmpty();
        var errors = [];
        errors.push({ ele: thisForm.find('#s2id_dataSource'), msg: "<p>" + errorMessage + "</p>"});
        thisForm.data('errors', errors);
    }
    
    $(document).on('change', '#dataSource', function(evt) {
        var macroName = $(evt.target).closest("[data-appfire-macro-name]").data("appfireMacroName");
        var selectedProfile = $(this);
        var thisForm = $(this).closest("form");
        var profileVal = selectedProfile.val();
        if(profileVal.match(/[/\\]/g) && profileVal.match(/[/\\]/g).length > 0){
            displayProfileNotValidError( selectedProfile, "Profile name cannot contain any of the following characters \u0022\u005C\u0022 & \u0022/\u0022.");
        }
        else{
            profileVal = encodeURIComponent(profileVal);
           //If its draft page, pageId is 0, so consider parentPageId
            var thisPageId = (AJS.params.pageId != 0 ? AJS.params.pageId : AJS.params.parentPageId);
            //check if selected profile is allowed??
            $.getJSON(AJS.contextPath() + '/rest/bobswift/sql/1.0/profiles/' + profileVal + '?macroName=' + macroName + '&pageId=' + thisPageId).
            fail(function(data) {
                appcme.clearValidationErrors(thisForm);
                displayProfileNotValidError( selectedProfile, data.responseText);
                return false;
              })
            .done(function(data){
                //clear existing validation errors
                thisForm.removeData('errors');
                appcme.clearValidationErrors(thisForm);
                if(!appsqlutil.isExpress && macroName != 'sql-file') { //if not express and not sql-file macro, then load metadata
                    thisForm.find(".sql-editor-toolbar *").prop('disabled', false);
                    thisForm.find(".metadata-error-container").hide();
                    if(selectedProfile.val().trim()){
                        var columnSearch = thisForm.find('#metadata-column-search');
                        columnSearch.attr('placeholder',"Select a table or view to list the columns ");
                        columnSearch.auiSelect2({data: []}); //initialise with empty select2 to indicate data loading
                        columnSearch.auiSelect2("enable", false);
                        var tableSearch = thisForm.find('#metadata-table-search');
                        tableSearch.val('')//empty table value
                        tableSearch.auiSelect2({placeHolder: 'please wait', data: []}); //initialise with empty select2 to indicate data loading
                        loadMetadata(thisForm);
                    }
                    
                }
            });
        }
    });
    
    $(document).on('appfireEditorBeforeShow', "[data-appfire-macro-name='sql'], [data-appfire-macro-name='sql-query'], [data-appfire-macro-name='sql-file']", function(evt, editor, macroDetails) {
        //if no datasource chosen, then disable toolbar , hide select2 and display plain text box
        var currentProfileName = editor.find("#dataSource").val();
        if(currentProfileName === ''){
            editor.find(".sql-editor-toolbar *").prop('disabled', true);
        }
       // var profileName = (editor.find("#dataSource").val() !== '' ? editor.find("#dataSource").val() : 
        //If its draft page, pageId is 0, so consider parentPageId
        var thisPageId = (AJS.params.pageId != 0 ? AJS.params.pageId : AJS.params.parentPageId);
        //Get the profiles and once fetched, add to datasourceprofile select2
        $.getJSON(AJS.contextPath() + '/rest/bobswift/sql/1.0/profiles?keysOnly=true&macroName='+macroDetails.name+'&pageId='+thisPageId +'&profileName=' + currentProfileName).done(
            function( data ) {
                editor.data('allowed_rofiles', data);
                var profileData = $.map(data, function(item) {
                    return { id: item, text: item }; 
                });
                editor.find("#dataSource").auiSelect2({
                    placeholder: "Select a profile...",
                    allowClear: true,
                    multiple: false,
                    data: profileData,
                    initSelection: function(element, callback) {
                        callback({
                             id: element.val(),
                             text: element.val() ? element.val() : "Select a profile..."
                         }); 
                    },
                    createSearchChoice:function(term, data) {
                        //This creates search choice with query/search term
                        if(!appsqlutil.isExpress) {
                            return {id:term, text:term};
                        }
                        else { 
                            return null; 
                        } //for express, only profiles configured in the profile config section will be allowed
                    },
                    formatNoMatches: function (term) {
                        return "No profiles found.";
                    },
                });
                
                if(currentProfileName.match(/[/\\]/g) && currentProfileName.match(/[/\\]/g).length > 0){
                    displayProfileNotValidError( editor.find("#dataSource"), "Profile name cannot contain any of the following characters \u0022\u005C\u0022 & \u0022/\u0022.");
                }
                else {
                    if(currentProfileName.trim() != '' ){
                        if( data.includes(currentProfileName)){
                            if(!appsqlutil.isExpress && macroDetails.name != 'sql-file')
                                loadMetadata(editor);
                        }
                        else{
                            displayProfileNotValidError(editor.find("#dataSource"), AJS.format("Use of {0} profile is restricted through Macro Security configuration. Contact your administrator for more information.", currentProfileName));
                        }
                    }
                }
            }); //end of ajax.done
        
        
        //for sql editor parameters tab row positions
        var $row = $(org.swift.confluence.sql.editor.parameterRowPositionRow({position: 0, parameterMarkers: ""}));
        $("#parameter-row-positions").data("masterGridRow", $row);   
       
    });
    
    //Handler to prefix p for the parameters row numbers
    $(document).on('appfireEditorGridAddRowBeforeShow appfireEditorGridDeleteRow', "[data-appfire-macro-name='sql'], [data-appfire-macro-name='sql-query'], [data-appfire-macro-name='sql-file']", function(evt, $row) {
        var $grid = $("#parameter-row-positions");
        if ($grid.find(".appfire-row").length > 0 ) {
            appsqlutil.numberGridRows($grid);
        }
    });
    
    $(document).on('appfireEditorAfterShow', "[data-appfire-macro-name='sql'], [data-appfire-macro-name='sql-query'], [data-appfire-macro-name='sql-file']", function(evt, editor) {
        //TODO: Find a better approach. 
        //Issue: When select2 field available on editor load, it does not allow to type in for search until an extra click is done.
        //Tried click other elements available around, but that does not work. Somehow the Workaround applied in AT also doesnot work here.
        // Here is workaround to focus the input field when dropdown opens 
        editor.find("#dataSource").on("select2-opening", function() {
            $(this).auiSelect2("focus");
        });
        
        editor.find("#metadata-table-search").on("select2-opening", function() {
            $(this).auiSelect2("focus");
        });
        
        //if mandatory param datasource is already set and if data location (i.e script param for attachment/file/template) is not set, then set 'sql-editor' as active menu
        if(editor.find("#dataSource").val() && $(this).data("appfireMacroName") != 'sql-file'){
            if(!editor.find(".appfire-table-datalocation").val()){
                editor.find(".nav-item[title='"+"org.swift.confluence.sql.editor.nav.button.sql.editor"+"']").click();
            }
        }
        //remove filename and template options from list as they are not supported for express
        if(appsqlutil.isExpress){
            $(this).find("option[value='filename']").remove();
            $(this).find("option[value='template']").remove();
        }

    });
    
    // Handler to before serialize the form params
    $(document).on('appfireEditorBeforeSerialize appfireEditorBeforePreviewSerialize', "[data-appfire-macro-name='sql'], [data-appfire-macro-name='sql-query'], [data-appfire-macro-name='sql-file']", 
            function(evt, dialog, form, defaultParms, errors) {
            // To get all the parameter markers and assign add it to the parameter-row-positions div as hidden macro parameters.
            var parameterMarkersDiv = dialog.find("#parameter-row-positions");
            //Clean up existing elements if any before adding p1, p2, etc as hidden elements
            parameterMarkersDiv.find(".sql-parameter-marker").remove();
            parameterMarkersDiv.find(".appfire-row").each(function(index, row) {
                var rowData = $(row).find(".row-data");
                var parameterMarker = rowData.find("input[name='parameterMarkers']").val();
                var pIndex = 'p' + (index + 1);
                AJS.$('<input>').attr({
                    type: 'hidden',
                    id: pIndex,
                    name: pIndex,
                    class: 'sql-parameter-marker',
                    value: parameterMarker
                }).appendTo(parameterMarkersDiv);
            });
    });
    
    $(document).on("appfireEditorBeforeMacroRender", "[data-appfire-macro-name='sql'], [data-appfire-macro-name='sql-query']", function(e, macroRenderRequest) {
        //Update macro body in macroRenderRequest, so that editor macro body can be updated
        macroRenderRequest.macro.body = macroRenderRequest.macro.params["sql-editor-query-input"].trim();
        //delete it, as it is not a macro param
        delete macroRenderRequest.macro.params["sql-editor-query-input"];
    });
    
    // Save handler to remove the custom element parameterMarkers before saving the macro.
    $(document).on('appfireEditorBeforeSave appfireEditorBeforePreview', "[data-appfire-macro-name='sql'], [data-appfire-macro-name='sql-query'], [data-appfire-macro-name='sql-file']", function(evt, macroParms, dialog, form, defaultParms) {
        //delete the "non-macro" parameters from the form
        delete macroParms['parameterMarkers'];
    });
    
    // On click of data location list, update the note if already there is query in sql editor, and applicable to sql and sql-query only
    $(document).on("change", ".appfire-table-datalocation", function(evt) {
        var thisForm = $(this).closest("form");
        var noteDiv = thisForm.find(".appfire-macroBody-filled-message");
        //if there is data in query editor, then display note
        if($(this).val() && thisForm.find(".appfire-sql-editor-query-textarea").val()){
            noteDiv.show();
        }
        else{
            noteDiv.hide();
        }
    });
    
}(window.sqlcme = window.sqlcme || {}, AJS.$));

}catch(e){WRMCB(e)};
;
try {
/* module-key = 'org.swift.confluence.sql:sql-editor-resources', location = 'scripts/highlights/jquery.highlight-within-textarea.js' */
/*
 * highlight-within-textarea
 *
 * @author  Will Boyd
 * @github  https://github.com/lonekorean/highlight-within-textarea
 */

(function($) {
    let ID = 'hwt';

    let HighlightWithinTextarea = function($el, config) {
        this.init($el, config);
    };

    HighlightWithinTextarea.prototype = {
        init: function($el, config) {
            this.$el = $el;

            // backwards compatibility with v1 (deprecated)
            if (this.getType(config) === 'function') {
                config = { highlight: config };
            }

            if (this.getType(config) === 'custom') {
                this.highlight = config;
                this.generate();
            } else {
                console.error('valid config object not provided');
            }
        },

        // returns identifier strings that aren't necessarily "real" JavaScript types
        getType: function(instance) {
            let type = typeof instance;
            if (!instance) {
                return 'falsey';
            } else if (Array.isArray(instance)) {
                if (instance.length === 2 && typeof instance[0] === 'number' && typeof instance[1] === 'number') {
                    return 'range';
                } else {
                    return 'array';
                }
            } else if (type === 'object') {
                if (instance instanceof RegExp) {
                    return 'regexp';
                } else if (instance.hasOwnProperty('highlight')) {
                    return 'custom';
                }
            } else if (type === 'function' || type === 'string') {
                return type;
            }

            return 'other';
        },

        generate: function() {
            this.$el
                .addClass(ID + '-input ' + ID + '-content')
                .on('input.' + ID, this.handleInput.bind(this))
                .on('scroll.' + ID, this.handleScroll.bind(this));

            this.$highlights = $('<div>', { class: ID + '-highlights ' + ID + '-content' });

            this.$backdrop = $('<div>', { class: ID + '-backdrop' })
                .append(this.$highlights);

            this.$container = $('<div>', { class: ID + '-container' })
                .insertAfter(this.$el)
                .append(this.$backdrop, this.$el) // moves $el into $container
                .on('scroll', this.blockContainerScroll.bind(this));

            this.browser = this.detectBrowser();
            switch (this.browser) {
                case 'firefox':
                    this.fixFirefox();
                    break;
                case 'ios':
                    this.fixIOS();
                    break;
            }

            // plugin function checks this for success
            this.isGenerated = true;

            // trigger input event to highlight any existing input
            this.handleInput();
        },

        // browser sniffing sucks, but there are browser-specific quirks to handle
        // that are not a matter of feature detection
        detectBrowser: function() {
            let ua = window.navigator.userAgent.toLowerCase();
            if (ua.indexOf('firefox') !== -1) {
                return 'firefox';
            } else if (!!ua.match(/msie|trident\/7|edge/)) {
                return 'ie';
            } else if (!!ua.match(/ipad|iphone|ipod/) && ua.indexOf('windows phone') === -1) {
                // Windows Phone flags itself as "like iPhone", thus the extra check
                return 'ios';
            } else {
                return 'other';
            }
        },

        // Firefox doesn't show text that scrolls into the padding of a textarea, so
        // rearrange a couple box models to make highlights behave the same way
        fixFirefox: function() {
            // take padding and border pixels from highlights div
            let padding = this.$highlights.css([
                'padding-top', 'padding-right', 'padding-bottom', 'padding-left'
            ]);
            let border = this.$highlights.css([
                'border-top-width', 'border-right-width', 'border-bottom-width', 'border-left-width'
            ]);
            this.$highlights.css({
                'padding': '0',
                'border-width': '0'
            });

            this.$backdrop
                .css({
                    // give padding pixels to backdrop div
                    'margin-top': '+=' + padding['padding-top'],
                    'margin-right': '+=' + padding['padding-right'],
                    'margin-bottom': '+=' + padding['padding-bottom'],
                    'margin-left': '+=' + padding['padding-left'],
                })
                .css({
                    // give border pixels to backdrop div
                    'margin-top': '+=' + border['border-top-width'],
                    'margin-right': '+=' + border['border-right-width'],
                    'margin-bottom': '+=' + border['border-bottom-width'],
                    'margin-left': '+=' + border['border-left-width'],
                });
        },

        // iOS adds 3px of (unremovable) padding to the left and right of a textarea,
        // so adjust highlights div to match
        fixIOS: function() {
            this.$highlights.css({
                'padding-left': '+=3px',
                'padding-right': '+=3px'
            });
        },

        handleInput: function() {
            let input = this.$el.val();
            let ranges = this.getRanges(input, this.highlight);
            let unstaggeredRanges = this.removeStaggeredRanges(ranges);
            let boundaries = this.getBoundaries(unstaggeredRanges);
            this.renderMarks(boundaries);
        },

        getRanges: function(input, highlight) {
            let type = this.getType(highlight);
            switch (type) {
                case 'array':
                    return this.getArrayRanges(input, highlight);
                case 'function':
                    return this.getFunctionRanges(input, highlight);
                case 'regexp':
                    return this.getRegExpRanges(input, highlight);
                case 'string':
                    return this.getStringRanges(input, highlight);
                case 'range':
                    return this.getRangeRanges(input, highlight);
                case 'custom':
                    return this.getCustomRanges(input, highlight);
                default:
                    if (!highlight) {
                        // do nothing for falsey values
                        return [];
                    } else {
                        console.error('unrecognized highlight type');
                    }
            }
        },

        getArrayRanges: function(input, arr) {
            let ranges = arr.map(this.getRanges.bind(this, input));
            return Array.prototype.concat.apply([], ranges);
        },

        getFunctionRanges: function(input, func) {
            return this.getRanges(input, func(input));
        },

        getRegExpRanges: function(input, regex) {
            let ranges = [];
            let match;
            while (match = regex.exec(input), match !== null) {
                ranges.push([match.index, match.index + match[0].length]);
                if (!regex.global) {
                    // non-global regexes do not increase lastIndex, causing an infinite loop,
                    // but we can just break manually after the first match
                    break;
                }
            }
            return ranges;
        },

        getStringRanges: function(input, str) {
            let ranges = [];
            let inputLower = input.toLowerCase();
            let strLower = str.toLowerCase();
            let index = 0;
            while (index = inputLower.indexOf(strLower, index), index !== -1) {
                ranges.push([index, index + strLower.length]);
                index += strLower.length;
            }
            return ranges;
        },

        getRangeRanges: function(input, range) {
            return [range];
        },

        getCustomRanges: function(input, custom) {
            let ranges = this.getRanges(input, custom.highlight);
            if (custom.className) {
                ranges.forEach(function(range) {
                    // persist class name as a property of the array
                    if (range.className) {
                        range.className = custom.className + ' ' + range.className;
                    } else {
                        range.className = custom.className;
                    }
                });
            }
            return ranges;
        },

        // prevent staggered overlaps (clean nesting is fine)
        removeStaggeredRanges: function(ranges) {
            let unstaggeredRanges = [];
            ranges.forEach(function(range) {
                let isStaggered = unstaggeredRanges.some(function(unstaggeredRange) {
                    let isStartInside = range[0] > unstaggeredRange[0] && range[0] < unstaggeredRange[1];
                    let isStopInside = range[1] > unstaggeredRange[0] && range[1] < unstaggeredRange[1];
                    return isStartInside !== isStopInside; // xor
                });
                if (!isStaggered) {
                    unstaggeredRanges.push(range);
                }
            });
            return unstaggeredRanges;
        },

        getBoundaries: function(ranges) {
            let boundaries = [];
            ranges.forEach(function(range) {
                boundaries.push({
                    type: 'start',
                    index: range[0],
                    className: range.className
                });
                boundaries.push({
                    type: 'stop',
                    index: range[1]
                });
            });

            this.sortBoundaries(boundaries);
            return boundaries;
        },

        sortBoundaries: function(boundaries) {
            // backwards sort (since marks are inserted right to left)
            boundaries.sort(function(a, b) {
                if (a.index !== b.index) {
                    return b.index - a.index;
                } else if (a.type === 'stop' && b.type === 'start') {
                    return 1;
                } else if (a.type === 'start' && b.type === 'stop') {
                    return -1;
                } else {
                    return 0;
                }
            });
        },

        renderMarks: function(boundaries) {
            let input = this.$el.val();
            boundaries.forEach(function(boundary, index) {
                let markup;
                if (boundary.type === 'start') {
                    markup = '{{hwt-mark-start|' + index + '}}';
                } else {
                    markup = '{{hwt-mark-stop}}';
                }
                input = input.slice(0, boundary.index) + markup + input.slice(boundary.index);
            });

            // this keeps scrolling aligned when input ends with a newline
            input = input.replace(/\n(\{\{hwt-mark-stop\}\})?$/, '\n\n$1');

            // encode HTML entities
            input = input.replace(/</g, '&lt;').replace(/>/g, '&gt;');

            if (this.browser === 'ie') {
                // IE/Edge wraps whitespace differently in a div vs textarea, this fixes it
                input = input.replace(/ /g, ' <wbr>');
            }

            // replace start tokens with opening <mark> tags with class name
            input = input.replace(/\{\{hwt-mark-start\|(\d+)\}\}/g, function(match, submatch) {
                var className = boundaries[+submatch].className;
                if (className) {
                    return '<mark class="' + className + '">';
                } else {
                    return '<mark>';
                }
            });

            // replace stop tokens with closing </mark> tags
            input = input.replace(/\{\{hwt-mark-stop\}\}/g, '</mark>');

            this.$highlights.html(input);
        },

        handleScroll: function() {
            let scrollTop = this.$el.scrollTop();
            this.$backdrop.scrollTop(scrollTop);

            // Chrome and Safari won't break long strings of spaces, which can cause
            // horizontal scrolling, this compensates by shifting highlights by the
            // horizontally scrolled amount to keep things aligned
            let scrollLeft = this.$el.scrollLeft();
            this.$backdrop.css('transform', (scrollLeft > 0) ? 'translateX(' + -scrollLeft + 'px)' : '');
        },

        // in Chrome, page up/down in the textarea will shift stuff within the
        // container (despite the CSS), this immediately reverts the shift
        blockContainerScroll: function() {
            this.$container.scrollLeft(0);
        },

        destroy: function() {
            this.$backdrop.remove();
            this.$el
                .unwrap()
                .removeClass(ID + '-text ' + ID + '-input')
                .off(ID)
                .removeData(ID);
        },
    };

    // register the jQuery plugin
    $.fn.highlightWithinTextarea = function(options) {
        return this.each(function() {
            let $this = $(this);
            let plugin = $this.data(ID);

            if (typeof options === 'string') {
                if (plugin) {
                    switch (options) {
                        case 'update':
                            plugin.handleInput();
                            break;
                        case 'destroy':
                            plugin.destroy();
                            break;
                        default:
                            console.error('unrecognized method string');
                    }
                } else {
                    console.error('plugin must be instantiated first');
                }
            } else {
                if (plugin) {
                    plugin.destroy();
                }
                plugin = new HighlightWithinTextarea($this, options);
                if (plugin.isGenerated) {
                    $this.data(ID, plugin);
                }
            }
        });
    };
})(jQuery);


}catch(e){WRMCB(e)};
;
