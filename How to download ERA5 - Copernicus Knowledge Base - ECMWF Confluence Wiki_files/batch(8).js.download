/* module-key = 'com.adaptavist.confluence.formMailNG:form-mail-format-resource', location = 'js/forms/config/mail-format-autocompleter.js' */
var AFMTemplates = AFMTemplates || {};

/**
 * The page editor is initialized. !!! No dom available at this point
 */
AJS.bind("init.rte", function () {
    if (!Confluence.Editor.Autocompleter) {
        Confluence.Editor.Autocompleter = tinymce.confluence.Autocompleter;
    }

    var variableManager = Confluence.VariableManager.defaultVariableManager;
    AFMTemplates.variableManager = variableManager;
    loadAutocompleteSettings(variableManager);
});

/**
 * Wait for iframe to be loaded.
 */
AJS.bind("rte-ready", function () {
    var ifr = document.getElementById('wysiwygTextarea_ifr');

    ifr.onload = function () {
        var editorDoc = $(AJS.Rte.getEditor().getDoc());
        var elements = editorDoc.find('.wysiwyg-macro[data-macro-name="mail-body-formatter"] td.wysiwyg-macro-body');
        elements.each(function () {
            var variables = loadAvailableVariables($(this).closest('.wysiwyg-macro[data-macro-name="mail-form"]'));
            if (needsHighlighting($(this), variables)) {
                var formatterElements = $("pre", this);
                highlightExistingVariables(formatterElements, variables);
            }
        });
    };
});

/**
 * Enables and disables variable autocomplete outside of mail-body-formatter macro
 */
AJS.bind("user-blurred-rte-element", function (e, data) {
    if ($(data.containerEl).attr('data-macro-name') !== 'mail-body-formatter') {
        delete Confluence.Editor.Autocompleter.Settings["#"];
        return;
    }
    loadAutocompleteSettings(AFMTemplates.variableManager);
});

/**
 * Sets the autocomplete settings for mail-body-formatter variables autocomplete
 *
 * @param variableManager
 */
var loadAutocompleteSettings = function (variableManager) {
    Confluence.Editor.Autocompleter.Settings["#"] = {
        ch: "#",
        cache: false,
        endChars: [],
        dropDownDelay: 0, // No delay needed because there is no AJAX request involved
        preventStartNodes: "",//[data-macro-name!='mail-body-formatter'], [data-macro-body-type!='PLAIN_TEXT'], p, div.code, a[href], img,

        dropDownClassName: "autocomplete-variables",
        selectFirstItem: true,

        getHeaderText: function (autoCompleteControl, value) {
            if (value) {
                return "Variable suggestions";
            }
            else {
                return "Variable suggestions";
            }
        },

        getAdditionalLinks: function (autoCompleteControl, value) {
            return [];
        },

        getDataAndRunCallback: function (autoCompleteControl, val, callback) {
            var k, i, l;
            var unescapedVal = Confluence.unescapeEntities(val);
            variableManager.clearExisting();
            loadAvailableVariables().forEach(function (variable) {
                !variableManager.contains(variable) && variableManager.add(variable);
            });
            var variables = variableManager.find(unescapedVal);
            var sortedVariables = [];
            var dropdownItems = [];

            for (var k in variables) {
                if (variables.hasOwnProperty(k)) {
                    sortedVariables.push(k);
                }
            }
            sortedVariables.sort(ignoreCaseComparator);
            for (i = 0, l = sortedVariables.length; i < l; i++) {
                k = sortedVariables[i];
                dropdownItems.push(makeVariableDropdownItem(k, variables[k]));
            }
            callback([dropdownItems], val);
        },

        update: function (autoCompleteControl, link) {
        }
    };

    function makeVariableDropdownItem(name, additionalAttrs) {
        return {
            callback: function (autoCompleteControl) {
                autoCompleteControl.replaceWithSelectedSearchText();
                createVariable(name, additionalAttrs);
            },
            name: AJS.escapeHtml(name),
            href: '#'
        };
    }

    function createVariable(name, additionalAttrs) {
        AJS.Rte.BookmarkManager.storeBookmark();
        !variableManager.contains(name) && variableManager.add(name);
        var variablePlaceholder = AJS.$(AFMTemplates.mailBodyVariable({variableName: name}))[0];
        AJS.Rte.getEditor().selection.setNode(variablePlaceholder);
    }

    function ignoreCaseComparator(a, b) {
        if (!a && !b) return 0;
        if (!a) return -1;
        if (!b) return 1;

        return a.toLocaleLowerCase().localeCompare(b.toLocaleLowerCase());
    }
};

/**
 * Finds the mail input macro with a name parameter and inside the current mail-form macro
 *
 * @param containingMacro the current mail-form element
 * @returns {Array} the list of variables found
 */
var loadAvailableVariables = function (containingMacro) {
    var variables = [];
    var selection = AJS.$(AJS.Rte.getEditor().selection.getNode());
    var containingMailFormMacro = containingMacro || selection.closest('.wysiwyg-macro[data-macro-name="mail-form"]');
    var macrosWithNameParam = AJS.$('[data-macro-parameters*="name="][data-macro-name!="mail-submit"][data-macro-name!="forms-attachment"]' +
        '[data-macro-name!="mail-outgoing-parameter"][data-macro-name!="forms-additional-recipients"]', containingMailFormMacro);
    var searchedParamName = "name=";
    macrosWithNameParam.each(function () {
        var params = AJS.$(this).attr('data-macro-parameters').split("|");
        params.forEach(function (param) {
            if (param.indexOf(searchedParamName) === 0) {
                var variable = param.substring(searchedParamName.length);
                if (variables.indexOf(variable) < 0) {
                    variables.push(param.substring(searchedParamName.length));
                }
            }
        });
    });
    return variables;
};

/**
 * Checks whether all the existing variables (names of input macros) inside mail-body-formatter macro body are highlighted
 *
 * @param macroBodyContainer the root element of mail-body-formatter macro body
 * @param variables the existing variable (names of input macros) in the current mail-form macro
 */
var needsHighlighting = function (macroBodyContainer, variables) {
    if (macroBodyContainer.text().length <= 1) {
        return false;
    }

    var updates = 0;
    var content = macroBodyContainer.html();
    variables.forEach(function (variableName) {
        var variable = "#" + variableName;
        var placeholder = AFMTemplates.mailBodyVariable({variableName: variableName});
        var variableOccurrences = content.split(variable).length - 1;
        var placeholderOccurrences = content.split(placeholder).length - 1;
        if (variableOccurrences != placeholderOccurrences) {
            updates++;
        }
    });
    return updates > 0;
};

/**
 * Adds styling/highlight for the variables inside mail-body-formatter macro
 *
 * @param elements the list of elements (<pre> elements) inside mail-body-formatter macro body
 * @param variables the existing variable (names of input macros) in the current mail-form macro
 */
var highlightExistingVariables = function (elements, variables) {
    AJS.Rte.BookmarkManager.storeBookmark();
    elements.each(function () {
        var element = $(this);
        var elementClone = element.clone();
        var content = element.html();
        variables.forEach(function (variableName) {
            var variable = "#" + variableName;
            var placeholder = AFMTemplates.mailBodyVariable({variableName: variableName});
            content = replaceAllVariables(content, variable, placeholder);
        });
        elementClone.html(content);
        if (element.html() !== elementClone.html()) {
            element.html(content);
        }
    });
};

var replaceAllVariables = function (content, toReplace, replacement) {
    var re;
    var formattedText;
    formattedText = toReplace.replace(/\?/g, "\\?");
    re = new RegExp('(' + formattedText + ')', 'gi');
    return content.replace(re, replacement);
};

/**
 * Generates the default mail body for the mail-body-formatter
 */
AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("mail-body-generate-default", function (e, macroNode) {
    AJS.Rte.BookmarkManager.storeBookmark();
    var macroBody = $("td.wysiwyg-macro-body", $(macroNode));
    macroBody.html(AFMTemplates.defaultMailBodyTemplate({variableNames: loadAvailableVariables()}));
});

/**
 * Clears the mail-body-formatter macro contebt
 */
AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("mail-body-clear", function (e, macroNode) {
    AJS.Rte.BookmarkManager.storeBookmark();
    var macroBody = $(macroNode).closest('[data-macro-name="mail-body-formatter"]').find('td.wysiwyg-macro-body');
    macroBody.html("<br>");
});

//polyfills
if (!Array.prototype.indexOf) {
    Array.prototype.indexOf = function (searchElement, fromIndex) {
        var k;
        if (this == null) {
            throw new TypeError('"this" is null or not defined');
        }

        var O = Object(this);
        var len = O.length >>> 0;
        if (len === 0) {
            return -1;
        }
        var n = +fromIndex || 0;

        if (Math.abs(n) === Infinity) {
            n = 0;
        }
        if (n >= len) {
            return -1;
        }
        k = Math.max(n >= 0 ? n : len - Math.abs(n), 0);
        while (k < len) {
            if (k in O && O[k] === searchElement) {
                return k;
            }
            k++;
        }
        return -1;
    };
}

if (!Array.prototype.forEach) {
    Array.prototype.forEach = function (callback, thisArg) {
        var T, k;
        if (this == null) {
            throw new TypeError(' this is null or not defined');
        }
        var O = Object(this);
        var len = O.length >>> 0;
        if (typeof callback !== "function") {
            throw new TypeError(callback + ' is not a function');
        }
        if (arguments.length > 1) {
            T = thisArg;
        }
        k = 0;
        while (k < len) {

            var kValue;
            if (k in O) {
                kValue = O[k];
                callback.call(T, kValue, k, O);
            }
            k++;
        }
    };
}
}catch(e){WRMCB(e)};
;
try {
/* module-key = 'com.adaptavist.confluence.formMailNG:form-mail-format-resource', location = 'js/forms/config/variables-manager.js' */
(function($) {

    function caseInsensitiveLocalCompare(a, b) {
        var la = a.toLocaleLowerCase();
        var lb = b.toLocaleLowerCase();
        var r = la.localeCompare(lb);
        if(r == 0)
            r = a.localCompare(b);
        return r;
    }

    function defaultVariable(type) {
        var defaultVar = Confluence.VariableManager.defaults[type] || Confluence.VariableManager.defaults["string"];
        return $.extend(true, {}, defaultVar);
    }

    Confluence.VariableManager = function() {
        var variables = {};

        return {
            find : function(startName) {
                var search = startName.toLocaleLowerCase();
                var result = {};
                for(var k in variables) {
                    if(variables.hasOwnProperty(k)) {
                        if(!search.length || k.toLocaleLowerCase().indexOf(search) === 0) {
                            result[k] = variables[k];
                        }
                    }
                }
                return result;
            },

            contains: function(name) {
                return !!variables[name];
            },

            get : function(name) {
                return variables[name];
            },

            getAll : function() {
                return $.extend(true, {}, variables); // clone a copy
            },

            getSortedNames : function() {
                var names = [];
                for(var name in variables)
                    names.push(name);
                return names.sort(caseInsensitiveLocalCompare);
            },

            add : function(name, details) {
                variables[name] = details || defaultVariable();
                AJS.trigger('add.confluence-variable', {
                    name: name,
                    details :$.extend(true, {}, details)
                });
            },

            del : function(name) {
                var details = variables[name];
                delete variables[name];
                AJS.trigger('delete.confluence-variable', {
                    name: name,
                    details :$.extend(true, {}, details)
                });
            },

            rename : function(oldName, newName) {
                var old = variables[oldName];
                delete variables[oldName];
                if(old) {
                    variables[newName] = old;
                    AJS.trigger('rename.confluence-variable', {
                        oldName: oldName,
                        newName: newName,
                        details :$.extend(true, {}, details)
                    });
                }
            },

            clearExisting: function() {
                variables = {};
            },

            createDefault: defaultVariable
        };
    };

    Confluence.VariableManager.defaultVariableManager = Confluence.VariableManager();
    Confluence.VariableManager.defaults =  {
        textarea: {
            type: "textarea",
            rows: 5,
            columns: 100
        },
        list: {
            type: "list",
            options: []
        },
        string: {
            type: "string"
        }
    }

})(AJS.$);
}catch(e){WRMCB(e)};
;
