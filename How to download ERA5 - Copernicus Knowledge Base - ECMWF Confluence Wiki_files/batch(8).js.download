//converting valid formats for moment.js to jQuery datepicker formats

function convertDatePickerFormats(format) {
    var newFormat;

    if (format === "dd/MM/yyyy") {
        newFormat = "dd/mm/yy"
    }
    else if (format === "MM/dd/yyyy") {
        newFormat = "mm/dd/yy"
    }
    else if (format === "yyyy/MM/dd") {
        newFormat = "yy/mm/dd"
    }
    if (format === "dd-MM-yyyy") {
        newFormat = "dd-mm-yy"
    }
    else if (format === "MM-dd-yyyy") {
        newFormat = "mm-dd-yy"
    }
    else if (format === "yyyy-MM-dd") {
        newFormat = "yy-mm-dd"
    }
    if (format === "dd.MM.yyyy") {
        newFormat = "dd.mm.yy"
    }
    else if (format === "MM.dd.yyyy") {
        newFormat = "mm.dd.yy"
    }
    else if (format === "yyyy.MM.dd") {
        newFormat = "yy.mm.dd"
    }
    return newFormat;
}

AJS.$(document).ready(function () {

    $('.data-date-field').each(function () {
        var newDatepicker = AJS.$(this);
        var format = newDatepicker.attr("format");
        var newFormat = convertDatePickerFormats(format);

        newDatepicker.datePicker({overrideBrowserDefault: true, dateFormat: newFormat});

        newDatepicker.attr("placeholder", format);
    });

});
}catch(e){WRMCB(e)};
