if (typeof org == 'undefined') { var org = {}; }
if (typeof org.swift == 'undefined') { org.swift = {}; }
if (typeof org.swift.confluence == 'undefined') { org.swift.confluence = {}; }
if (typeof org.swift.confluence.run == 'undefined') { org.swift.confluence.run = {}; }
if (typeof org.swift.confluence.run.editor == 'undefined') { org.swift.confluence.run.editor = {}; }


org.swift.confluence.run.editor.fieldSettingsRow = function(opt_data, opt_ignored) {
  opt_data = opt_data || {};
  return '<div class="grid appfire-row" > <!-- row --><!-- Field row side bar notch for group child elements --><div class="group-child-sidebar-notch" style="display: none;"></div><div class="col-1 row-header"><h4 class="row-number" style="display: none;">' + soy.$$escapeHtml(opt_data.position + 1) + '</h4><!-- To display group sequence --><div class="field-row-sequence">' + soy.$$escapeHtml(opt_data.position + 1) + '</div></div><div class="col-auto row-data"> <!-- row content --><!-- Need this replace field to hold entire replace field before splitting into multiple parts and assign them to below input fields --><input class="text row-data-element" type="hidden" name="replace" ' + ((opt_data.replace[opt_data.position]) ? ' value="' + soy.$$escapeHtml(opt_data.replace[opt_data.position]) + '" ' : '') + '/><div class="grid show-hide-empty fields-row-first"><div class="col-md-auto" data-collapsible="col-md-auto"><div class="field-group"><label for="field-type">' + soy.$$escapeHtml('Field type') + '<span class="aui-icon icon-required">required</span></label><select class="select row-data-element" name="field-type"><option value="">Select field type</option><option value="text" data-imagename="icon-form-field-text-48-wht-on-clr.png">Text</option><option value="password" data-imagename="icon-form-field-password-48-wht-on-clr.png">Password</option><option value="textarea" data-imagename="icon-form-field-textarea-48-wht-on-clr.png">Textarea</option><option value="radio" data-imagename="icon-form-field-radio-48-wht-on-clr.png">Radio</option><option value="checkbox" data-imagename="icon-form-field-checkbox-48-wht-on-clr.png">Checkbox</option><option value="select" data-imagename="icon-form-field-select-48-wht-on-clr.png">Select</option><option value="dynamic-select" data-imagename="icon-form-field-select-48-wht-on-clr.png">Dynamic Select</option><option value="dynamic-selectmulti" data-imagename="icon-form-field-multi-select-48-wht-on-clr.png">Dynamic Multi Select</option><option value="select-multi" data-imagename="icon-form-field-multi-select-48-wht-on-clr.png">Multi Select</option><option value="float" data-imagename="icon-form-field-float-48-wht-on-clr.png">Float</option><option value="integer" data-imagename="icon-form-field-integer-48-wht-on-clr.png">Integer</option><option value="integer-select" data-imagename="icon-form-field-integer-select-48-wht-on-clr.png">Integer Select</option><option value="date" data-imagename="icon-form-field-date-48-wht-on-clr.png">Date</option><option value="output" data-imagename="icon-form-field-output-48-wht-on-clr.png">Output</option><option value="hidden" data-imagename="icon-form-field-hidden-48-wht-on-clr.png">Hidden</option></select></div></div><div class="col-md-auto" data-collapsible="col-md-auto"><div class="field-group"><label for="field-name">' + soy.$$escapeHtml('Field key') + '<span class="aui-icon icon-required">required</span></label><input class="text row-data-element" type="text" name="field-name"/></div></div><div class="col-md-auto" data-collapsible="col-md-auto"><div class="field-group"><label for="field-desc">' + soy.$$escapeHtml('Field label') + '</label><input class="text row-data-element" type="text" name="field-description" value=""/></div></div><div class="col-md-auto group-hide-element" data-collapsible="col-md-auto"><div class="field-group"><label for="field-value">' + soy.$$escapeHtml('Field value') + '</label><input class="text row-data-element" type="text" name="field-value" value=""/></div></div><div class="col-md-auto show-hide-element field-type-group" data-collapsible="col-md-auto"><div class="field-group"><label for="field-width">' + soy.$$escapeHtml('Width') + '</label><input class="text row-data-element" type="text" name="field-width" value=""/></div></div></div><div class="grid fields-row-dynamic"><div class="col-md-auto fields-row-options show-hide-element field-type-select field-type-select-multi field-type-radio field-type-checkbox" data-collapsible="col-md-auto"><div class="field-group static-options"><label for="value-text-table">' + soy.$$escapeHtml('List of options') + '</label><table><tbody class="value-text-table"><tr class="value-text-row"><td><input type="text" name="field-option-value" class="text row-data-element" placeholder="Value"/></td><td><input type="text" name="field-option-text"  class="text row-data-element" placeholder="Text"/></td><td><button class="aui-button remove-option-btn" style="display: none;"><img src="' + soy.$$escapeHtml(opt_data.contextPath) + '/download/resources/org.swift.confluence.run/img/icon-field-settings-remove-32.png" height="16px" width="16px" align="top"></button></td></tr></tbody><tfoot><tr><td><button class="aui-button add-option-btn"><span class="aui-icon aui-icon-small aui-iconfont-add"></span> ' + soy.$$escapeHtml('Add option') + '</button></td></tr></tfoot></table></div></div><div class="col-md-auto show-hide-element field-type-dynamic-select field-type-dynamic-selectmulti" data-collapsible="col-md-auto"><div class="field-group"><label for="field-dynamic-select-ds">' + soy.$$escapeHtml('Data source profile') + '<span class="aui-icon icon-required">required</span>' + org.swift.confluence.table.editor.addHelpContent({id: 'sql-profile-help' + opt_data.position, helpContent: 'Lists all the data source profiles configured by your Confluence administrator. Select a profile to access the respective SQL data.'}) + '</label><input class="text row-data-element" type="text"  name="field-dynamic-select-ds" value=""/></div></div><div class="col-md-auto show-hide-element field-type-dynamic-select  field-type-dynamic-selectmulti" data-collapsible="col-md-auto"><div class="field-group"><label for="field-dynamic-select-query">' + soy.$$escapeHtml('SQL query') + '<span class="aui-icon icon-required">required</span>' + org.swift.confluence.table.editor.addHelpContent({id: 'sql-query-help' + opt_data.position, helpContent: 'Enter query to fetch data to be used as the select options. If the