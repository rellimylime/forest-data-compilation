Forms.Macros.Form.content = function(opt_data, opt_ignored) {
  return '<div class="module custom-macro-dialog form-macro"><form id="buttonGroupForm" class="aui"><div role="application" class="aui-tabs horizontal-tabs"><ul role="tablist" class="tabs-menu"><li role="presentation" class="menu-item active-tab"><a aria-selected="true" role="tab" id="link-details" href="#tabs-details"><strong>' + soy.$$escapeHtml('Destinations') + '</strong></a></li><li role="presentation" class="menu-item"><a aria-selected="false" role="tab" id="link-submit-button" href="#tabs-submit-button"><strong>' + soy.$$escapeHtml('Submit Button') + '</strong></a></li><li role="presentation" class="menu-item"><a aria-selected="false" role="tab" id="link-advanced" href="#tabs-advanced"><strong>' + soy.$$escapeHtml('Advanced Options') + '</strong></a></li></ul><div aria-hidden="false" role="tabpanel" class="tabs-pane active-pane" id="tabs-details"><input id="avst-custom-dialog-macro-name" type="hidden" value="mail-form"><fieldset class="advanced"><legend>' + soy.$$escapeHtml('Details') + '</legend><div class="field-group"><label for="group-desc">' + soy.$$escapeHtml('Destination') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Can be a comma separated list of Form IDs, email addresses and Confluence usernames. Each destination will receive a copy of the outgoing Response.') + '" ></span><input class="text long-field" type="text" name="destination" id="destination" value="' + soy.$$escapeHtml(opt_data.destination) + '" required/></div><div class="field-group"><label for="group-desc">' + soy.$$escapeHtml('Subject') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('The subject of outgoing Response from this Form. Can be overwritten by the Forms Destination Macro.') + '" ></span><input class="text long-field" type="text" name="subject" id="subject" value="' + soy.$$escapeHtml(opt_data.subject) + '" /></div></fieldset></div><div aria-hidden="true" role="tabpanel" class="tabs-pane" id="tabs-submit-button"><fieldset class="advanced"><legend>' + soy.$$escapeHtml('Submit Button') + '</legend><div class="field-group group-style"><label for="group-style">' + soy.$$escapeHtml('Button Text') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Text to be shown in the Submit button') + '" ></span><input type="text" title="submitButtonText" name="submitButtonText" id="submitButtonText" value="' + soy.$$escapeHtml(opt_data.submitButtonText) + '" class="text"/></div><div class="field-group group-style"><label for="group-style">' + soy.$$escapeHtml('Hide Button') + '</label><div class="checkboxes"><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Choose whether to show or hide the submit button') + '" ></span><input id="hideSubmitButton" name="hideSubmitButton" type="checkbox" value="false" ' + ((opt_data.hideSubmitButton) ? 'checked="true"' : '') + '/></div></div><div class="field-group group-style"><label for="group-style">' + soy.$$escapeHtml('Button CSS Class') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Optional CSS Class to help with styling the Submit button') + '" ></span><input type="text" title="Css Class" name="group-class" id="group-class" value="' + soy.$$escapeHtml(opt_data.cssClass) + '" class="text"/></div><div class="field-group group-style"><label for="group-style">' + soy.$$escapeHtml('Button CSS Style') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Optional CSS styling for the Submit button') + '" ></span><input type="text" title="Css Style" name="group-style" id="group-style" value="' + soy.$$escapeHtml(opt_data.cssStyle) + '" class="text"/></div><div class="field-group group-style"><label for="group-style">' + soy.$$escapeHtml('Image URL') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Adds an image to be used as the submit button') + '" ></span><input type="text" class="text long-field" title="imageURL" name="imageURL" id="imageURL" value="' + soy.$$escapeHtml(opt_data.imageURL) + '" class="text"/></div></fieldset></div><div aria-hidden="true" role="tabpanel" class="tabs-pane" id="tabs-advanced"><fieldset class="advanced"><legend>' + soy.$$escapeHtml('Advanced Options') + '</legend><div class="field-group group-style"><label class="advancedOptionsLabel" for="group-style">' + soy.$$escapeHtml('Allow anonymous submissions') + '</label><div class="checkboxes"><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Allow users the ability to choose whether to submit forms anonymously (No user details submitted)') + '" ></span><input name="allowSubmitAsAnonymous" id="allowSubmitAsAnonymous" type="checkbox" value="false" ' + ((opt_data.allowSubmitAsAnonymous) ? ' checked="true"' : '') + '/></div></div><div class="field-group group-style"><label class="advancedOptionsLabel" for="group-style">' + soy.$$escapeHtml('Add a Captcha') + '</label><div class="checkboxes"><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Form submission captcha block') + '" ></span><input id="captcha" name="captcha" type="checkbox" value="true" ' + ((opt_data.captcha) ? 'checked="true"' : '') + '/></div></div><div class="field-group group-style"><label class="advancedOptionsLabel" for="group-style">' + soy.$$escapeHtml('Receipt') + '</label><div class="checkboxes"><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Send a copy of the sent email to the user who clicks the submit button') + '" ></span><input id="receipt" name="receipt" type="checkbox" value="true" ' + ((opt_data.receipt) ? 'checked="true"' : '') + '/></div></div><div class="field-group group-style"><label class="advancedOptionsLabel" for="group-style">' + soy.$$escapeHtml('Include destinations in the receipt') + '</label><div class="checkboxes"><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Caution: If checked, the receipt email will contain a list of all destination email addresses.\nForm IDs and associated destinations will not be included in the receipt') + '" ></span><input id="includeDestinations" name="includeDestinations" type="checkbox" value="true" ' + ((opt_data.includeDestinations) ? 'checked="true"' : '') + '/></div></div><div class="field-group group-style"><label class="advancedOptionsLabel" for="group-style">' + soy.$$escapeHtml('Left Spacing') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('This helps the Form elements like Submit Button and Captcha match with other fields label width') + '" ></span><input type="text" title="leftSpacing" name="leftSpacing" id="leftSpacing" value="' + soy.$$escapeHtml(opt_data.leftSpacing) + '" class="text"/></div></fieldset></div></div><button class="hiddenButton" id="hiddenButton" type="submit"></button></form></div>';
};
if (goog.DEBUG) {
  Forms.Macros.Form.content.soyTemplateName = 'Forms.Macros.Form.content';
}


Forms.Macros.Form.footerContent = function(opt_data, opt_ignored) {
  return '<fieldset class="form-config-footer"><div class="custom-macro-footer"><div class="aui-group align-bottom aui-group-split"><div class="aui-item"><a class="" href="' + soy.$$escapeHtml(opt_data.docHrefHtml) + '" target="_blank">' + soy.$$escapeHtml('Documentation') + '</a></div><div class="aui-item"><button class="aui-button aui-button-primary button-panel-button ok" id="insertButtonGroup" type="submit">' + soy.$$escapeHtml(opt_data.buttonTitle) + '</button><a class="aui-button aui-button-link" href="#" id="cancelButtonGroup">' + soy.$$escapeHtml('Cancel') + '</a></div></div></div></fieldset>';
};
if (goog.DEBUG) {
  Forms.Macros.Form.footerContent.soyTemplateName = 'Forms.Macros.Form.footerContent';
}

}catch(e){WRMCB(e)};
;
try {
/* module-key = 'com.adaptavist.confluence.formMailNG:form-macro-js', location = '/js/forms/config/form-macro.js' */
AJS.bind("init.rte", function () {

    //Model for FormConfig section
    function FormConfig(params) {
        this.getDestination = function () {
            return (params === undefined || params.destination === undefined) ? '' : params.destination.toString();
        };

        this.getSubject = function () {
            return (params === undefined || params.subject === undefined) ? '' : params.subject.toString();
        };

        this.getSubmitButtonText = function () {
            return (params === undefined || params.submitButtonText === undefined) ? 'Submit' : params.submitButtonText.toString();
        };

        this.getImageURL = function () {
            return (params === undefined || params.imageURL === undefined) ? '' : params.imageURL.toString();
        };

        this.getCaptcha = function () {
            return params === undefined ? '' : params.captcha === 'true';
        };

        this.getReceipt = function () {
            return params === undefined ? '' : params.receipt === 'true';
        };

        this.getIncludeDestinations = function () {
            return params === undefined ? '' : params.includeDestinations === 'true';
        };

        this.getLeftSpacing = function () {
            return (params === undefined || params.leftSpacing === undefined) ? '' : params.leftSpacing;
        };

        this.getCssClass = function () {
            return (params === undefined || params.cssClass === undefined) ? '' : params.cssClass;
        };

        this.getCssStyle = function () {
            return (params === undefined || params.cssStyle === undefined) ? '' : params.cssStyle;
        };

        this.getHideSubmitButton = function () {
            return params === undefined ? '' : params.hideSubmitButton === 'true';
        };

        this.getAllowSubmitAsAnonymous = function () {
            return params === undefined ? '' : params.allowSubmitAsAnonymous === 'true';
        };
    }

    function getFormConfigValues() {
        return {
            destination: AJS.$('#destination').val(),
            subject: AJS.$('#subject').val(),
            submitButtonText: AJS.$('#submitButtonText').val(),
            imageURL: AJS.$('#imageURL').val(),
            captcha: AJS.$('#captcha').is(':checked'),
            receipt: AJS.$('#receipt').is(':checked'),
            includeDestinations: AJS.$('#includeDestinations').is(':checked'),
            leftSpacing: AJS.$('#leftSpacing').val(),
            cssClass: AJS.$('#group-class').val(),
            cssStyle: AJS.$('#group-style').val(),
            hideSubmitButton: AJS.$('#hideSubmitButton').is(':checked'),
            allowSubmitAsAnonymous: AJS.$('#allowSubmitAsAnonymous').is(':checked')
        };
    }

    function setupFormMacroEvents() {

        // Hooks up the Esc Button from keyboard
        AJS.$(document).keyup(function (e) {
            if (e.keyCode == 27) {
                AJS.dialog2('#editor-dialog').remove();
            }
        });

        //Hooks up the Cancel Button
        AJS.$('#cancelButtonGroup').click(function (e) {
            e.preventDefault();
            AJS.dialog2('#editor-dialog').remove();
        });

        //Hooks up the Insert Button
        AJS.$('#insertButtonGroup').click(function () {
            AJS.$('#buttonGroupForm').submit();
        });

        AJS.tabs.setup();
    }

    function createFormMacroConfig(macro) {
        //Creates a new FormConfig object that holds the parameters, or initial empty values
        var formConfig = new FormConfig(macro.params);

        //Calls the dialog with Edit or Insert heading accordingly.
        AJS.dialog2(Forms.Macros.Form.dialog({
            title: macro.body === undefined ?
                "Insert \u0027Forms\u0027 Macro" :
                "Edit \u0027Forms\u0027 Macro",
            buttonTitle: macro.body === undefined ?
                "Insert" :
                "Save",
            destination: formConfig.getDestination(),
            subject: formConfig.getSubject(),
            submitButtonText: formConfig.getSubmitButtonText(),
            imageURL: formConfig.getImageURL(),
            captcha: formConfig.getCaptcha(),
            receipt: formConfig.getReceipt(),
            includeDestinations: formConfig.getIncludeDestinations(),
            leftSpacing: formConfig.getLeftSpacing(),
            cssClass: formConfig.getCssClass(),
            cssStyle: formConfig.getCssStyle(),
            hideSubmitButton: formConfig.getHideSubmitButton(),
            allowSubmitAsAnonymous: formConfig.getAllowSubmitAsAnonymous()
        })).show();

        AJS.$('#insertButtonGroup').on('click', function (event) {
            AJS.$('#hiddenButton').click();
        });

        AJS.$(".aui-icon.aui-icon-small.aui-iconfont-info").tooltip({gravity: 'nw'});

        AJS.$('#buttonGroupForm').on('submit', function (e) {
            e.preventDefault();

            if (AJS.$('#buttonGroupForm')[0].checkValidity()) {
                var t = tinymce.confluence.macrobrowser;

                AJS.Rte.BookmarkManager.restoreBookmark();

                if (t.editedMacroDiv) {
                    delete t.editedMacroDiv;
                }

                //Saves the Macro. Since the values is an array, it needs to convert it to JSON and then parse it back to display.
                tinymce.confluence.macrobrowser.macroBrowserComplete({
                    name: "mail-form",
                    "bodyHtml": macro.body === undefined ? "" : macro.body,
                    "params": getFormConfigValues()
                });

                AJS.dialog2('#editor-dialog').remove();
            }
        });
        setupFormMacroEvents();

        function formatSearchResult(result) {
            if (typeof result.children !== 'undefined') {
                return '<strong class="select2-result-group">' + AJS.escapeHtml(result.text) + '</strong>';
            }
            return '<span class="select2-result-child">' + AJS.escapeHtml(result.text) + '</span>';
        }

        function formatSearchSelection(selection) {
            return AJS.escapeHtml(selection.text);
        }

        // Select2 for Form Macro
        var results = [];

        AJS.$("#destination").auiSelect2({
            placeholder: 'Please enter one or multiple Form IDs, usernames or email addresses',
            width: 'element',
            multiple: true,
            formatResult: formatSearchResult,
            formatSelection: formatSearchSelection,
            tags: true,
            tokenSeparators: [','],

            createSearchChoice: function (term) {
                if (results.indexOf(term.toLowerCase()) === -1) {
                    return {
                        id: $.trim(term),
                        text: $.trim(term)
                    };
                }
            },

            initSelection: function (element, callback) {
                var data = [];

                function splitVal(string, separator) {
                    var val, i, l;
                    if (string === null || string.length < 1) return [];
                    val = string.split(separator);
                    for (i = 0, l = val.length; i < l; i = i + 1) val[i] = $.trim(val[i]);
                    return val;
                }

                $(splitVal(element.val(), ",")).each(function () {
                    if (this.indexOf('~') === 0) {
                        var til = this.substring(1);

                        data.push({
                            id: this,
                            text: til
                        });
                    } else {
                        data.push({
                            id: this,
                            text: this
                        });
                    }
                });

                callback(data);
            },

            ajax: {
                url: AJS.Meta.get("context-path") + '/rest/formservice/1.0/configs/formmail/users/?' + 'spaceKey=' + AJS.params.spaceKey,
                dataType: 'json',
                type: "GET",
                quietMillis: 250,
                data: function (term) {
                    return {
                        queryName: term,
                        selectedDestinations: this.val()
                    };
                },
                results: function (data) {
                    var groups = {};
                    $.map(data, function (item) {
                        results.push(item.name.toLowerCase());
                        var group = item.group;
                        groups[group] = groups[group] || [];
                        groups[group].children = groups[group].children || [];
                        groups[group].text = item.group;
                        groups[group].children.push({
                            id: item.idAsString,
                            text: item.name
                        });
                    });

                    return {
                        results: $.map(groups, function (group) {
                            return {
                                text: group.text,
                                children: group.children
                            }
                        })
                    }
                }
            }
        });
    }

    //Intercepts normal Macro config and replaces with this one
    AJS.MacroBrowser.setMacroJsOverride('mail-form', {opener: createFormMacroConfig});
});

}catch(e){WRMCB(e)};
;
try {
/* module-key = 'com.adaptavist.confluence.formMailNG:form-macro-js', location = 'js/forms/config/common.js' */
define('js/forms/config/common', ['exports'], function (exports) {
    'use strict';

    Object.defineProperty(exports, "__esModule", {
        value: true
    });
    exports.setupCommonButtonsBehaviour = setupCommonButtonsBehaviour;
    exports.setupCommonBehaviour = setupCommonBehaviour;
    exports.getMaxIndex = getMaxIndex;
    exports.getMacroParameters = getMacroParameters;
    exports.removeGroupRow = removeGroupRow;
    exports.registerGroupRowButtons = registerGroupRowButtons;
    exports.macroJsOverride = macroJsOverride;
    exports.loadAvailableFields = loadAvailableFields;
    exports.loadAvailableFormPages = loadAvailableFormPages;
    function setupCommonButtonsBehaviour() {

        // Hooks up the Esc Button from keyboard
        AJS.$(document).keyup(function (e) {
            if (e.keyCode == 27) {
                AJS.dialog2('#editor-dialog').remove();
            }
        });

        // Setups Tabs in AJS
        AJS.tabs.setup();

        // Hooks up the Cancel Button
        AJS.$('#cancelButtonGroup').click(function (e) {
            e.preventDefault();
            AJS.dialog2('#editor-dialog').remove();
        });

        // Hooks up the Insert Button
        AJS.$('#insertButtonGroup').click(function () {
            AJS.$('#buttonGroupForm').submit();
        });

        AJS.$(".aui-icon.aui-icon-small.aui-iconfont-info").tooltip({ gravity: 'nw' });

        AJS.$('#insertButtonGroup').on('click', function (event) {
            AJS.$('#hiddenButton').click();
        });
    }

    function setupCommonBehaviour(editorType) {
        AJS.$('#buttonGroupForm').on('submit', function (e) {
            e.preventDefault();

            if (AJS.$('#buttonGroupForm')[0].checkValidity()) {
                var t = tinymce.confluence.macrobrowser;

                AJS.Rte.BookmarkManager.restoreBookmark();

                if (t.editedMacroDiv) {
                    delete t.editedMacroDiv;
                }

                //Saves the Macro. Since the values is an array, it needs to convert it to JSON and then parse it back to display.
                tinymce.confluence.macrobrowser.macroBrowserComplete({
                    name: editorType,
                    "bodyHtml": "undefined",
                    "params": getGroupParams()
                });

                AJS.dialog2('#editor-dialog').remove();
            }
        });
    }

    function getMaxIndex() {
        var maxIndex = 0;
        for (var i = 0; i < AJS.$("[id^='groupRow']").length; i++) {
            var row = AJS.$("[id^='groupRow']")[i];
            var currentIndex = parseInt(row.id.substring(8, row.id.length));
            maxIndex = Math.max(currentIndex, maxIndex);
        }
        return parseInt(maxIndex) + 1;
    }

    function getMacroParameters(params) {

        this.getLabel = function () {
            return params === undefined ? '' : params.label;
        };

        this.getName = function () {
            return params === undefined ? '' : params.name;
        };

        this.getDescription = function () {
            return params === undefined || params.description === undefined ? '' : params.description;
        };

        this.getRequired = function () {
            return params === undefined ? '' : params.required === 'true';
        };

        this.getMultiselect = function () {
            return params === undefined ? '' : params.multiselect === 'true';
        };

        this.getCssClass = function () {
            return params === undefined || params.cssClass === undefined ? '' : params.cssClass;
        };

        this.getCssStyle = function () {
            return params === undefined || params.cssStyle === undefined ? '' : params.cssStyle;
        };

        this.getLabelLength = function () {
            return params === undefined || params.labelLength === undefined ? '' : params.labelLength;
        };

        this.getFieldWidth = function () {
            return params === undefined || params.fieldWidth === undefined ? '' : params.fieldWidth;
        };

        this.getRows = function () {
            return params === undefined || params.rows === undefined ? '4' : params.rows;
        };

        this.getValue = function () {
            return params === undefined || params.value === undefined ? '' : params.value;
        };

        this.getMaxLength = function () {
            return params === undefined || params.maxLength === undefined ? '' : params.maxLength;
        };

        this.getValues = function () {
            if (params === undefined) {
                return [{
                    label: '',
                    value: '',
                    tableId: '',
                    destination: '',
                    subject: '',
                    success: '',
                    selected: true,
                    field: '',
                    fieldValue: '',
                    whatHappens: '',
                    fieldToTrigger: ''
                }];
            } else {
                var counter = Number(params.counter);
                var values = [];

                //Unfortunately, Confluence cannot parse a JSON string, so one needs to write each parameter individually
                for (var i = 0; i < counter; i++) {
                    values.push({
                        label: getSafeParamValue(params[i.toString() + '_label']),
                        value: getSafeParamValue(params[i.toString() + '_value']),
                        tableId: getSafeParamValue(params[i.toString() + '_tableId']),
                        selected: getSafeParamValue(params[i.toString() + '_selected'] === 'true'),
                        destination: getSafeParamValue(params[i.toString() + '_destination']),
                        subject: getSafeParamValue(params[i.toString() + '_subject']),
                        success: getSafeParamValue(params[i.toString() + '_success']),
                        field: getSafeParamValue(params[i.toString() + '_conditionalInputField']),
                        fieldValue: getSafeParamValue(params[i.toString() + '_conditionalInputFieldValue']),
                        whatHappens: getSafeParamValue(params[i.toString() + '_conditionalInputWhatHappens']),
                        fieldToTrigger: getSafeParamValue(params[i.toString() + '_conditionalInputFieldToTrigger'])
                    });
                }

                return values;
            }
        };
    }

    function getSafeParamValue(parameter) {
        return parameter === undefined ? '' : parameter;
    }

    //Fetches all Label/Values from each row, plus if it's selected.
    function getRowValues(values) {
        var counter = 0;

        //Unfortunately, Confluence cannot parse a JSON string, so one needs to write each parameter individually
        AJS.$("tr[id*='groupRow']").each(function () {
            var label = $(this).find("input[name='buttonLabel']").val();
            var value = $(this).find("input[name='buttonValue']").val();
            var tableId = $(this).attr('tableId');
            var selected = $(this).find("input[name*='buttonSelected']").is(':checked');
            var destination = $(this).find("input[name='destination']").val();
            var subject = $(this).find("input[name='subject']").val();
            var success = $(this).find("input[name='success']").val();
            var conditionalInputField = $(this).find("input[name='conditionalInputField']").val();
            var conditionalInputFieldValue = $(this).find("input[name='conditionalInputFieldValue']").val();
            var conditionalInputWhatHappens = $(this).find("input[name='conditionalInputWhatHappens']").val();
            var conditionalInputFieldToTrigger = $(this).find("input[name='conditionalInputFieldToTrigger']").val();

            values[counter + '_label'] = label;
            values[counter + '_value'] = value;
            values[counter + '_tableId'] = tableId;
            values[counter + '_selected'] = selected;
            values[counter + '_destination'] = destination;
            values[counter + '_subject'] = subject;
            values[counter + '_success'] = success;
            values[counter + '_conditionalInputField'] = conditionalInputField;
            values[counter + '_conditionalInputFieldValue'] = conditionalInputFieldValue;
            values[counter + '_conditionalInputWhatHappens'] = conditionalInputWhatHappens;
            values[counter + '_conditionalInputFieldToTrigger'] = conditionalInputFieldToTrigger;

            counter++;
        });

        values.counter = counter;

        return values;
    }

    function getGroupParams() {
        var values = {
            name: AJS.$('#group-name').val(),
            label: AJS.$('#group-label').val(),
            description: AJS.$('#group-desc').val(),
            required: AJS.$('#group-required').is(':checked'),
            multiselect: AJS.$('#group-multiselect').is(':checked'),
            cssClass: AJS.$('#group-class').val(),
            cssStyle: AJS.$('#group-style').val(),
            labelLength: AJS.$('#label-length').val(),
            fieldWidth: AJS.$('#field-width').val(),
            rows: AJS.$('#group-rows').val(),
            value: AJS.$('#group-value').val()
        };

        var maxLength = AJS.$('#maxLength');
        if (maxLength !== undefined) {
            values.maxLength = maxLength.val();
        }

        return getRowValues(values);
    }

    //need table id for matrix macros, to remove from correct row/column
    function removeGroupRow(event, tableId) {
        event.preventDefault();
        var rowIndex = AJS.$(event.target).data("row-index");

        if (tableId === undefined) {
            tableId = AJS.$(event.target).closest("tr").attr("tableId");
        }
        if (tableId) {
            AJS.$('#' + tableId + '_groupRow' + rowIndex).remove();
            if (AJS.$('#' + tableId + ' .removeGroupRowInput').length === 1) {
                AJS.$('#' + tableId + ' .removeGroupRowInput')[0].disabled = true;
            }
            if (AJS.$('[name=' + tableId + '_buttonSelected]').length > 0) {
                var isSelected = false;
                AJS.$('[name=' + tableId + '_buttonSelected]').each(function () {
                    if ($(this).is(':checked')) {
                        isSelected = true;
                    }
                });
                if (!isSelected) {
                    AJS.$('[name=' + tableId + '_buttonSelected]')[0].checked = true;
                }
            }
        } else {
            AJS.$('#groupRow' + rowIndex).remove();
            if (AJS.$('.removeGroupRowInput').length === 1) {
                AJS.$('.removeGroupRowInput')[0].disabled = true;
            }
            if (AJS.$('[name=buttonSelected]').length > 0) {
                var _isSelected = false;
                AJS.$('[name=buttonSelected]').each(function () {
                    if ($(this).is(':checked')) {
                        _isSelected = true;
                    }
                });
                if (!_isSelected) {
                    AJS.$('[name=buttonSelected]')[0].checked = true;
                }
            }
        }
    }

    function registerGroupRowButtons(addGroupRowFunction, rowIndex, tableId) {
        if (rowIndex === undefined) {
            AJS.$('.addGroupRowInput').on('click', function (event) {
                event.preventDefault();
                addGroupRowFunction(event);
            });
            AJS.$('.removeGroupRowInput').on('click', function (event) {
                removeGroupRow(event);
            });
        } else {
            if (tableId) {
                AJS.$(AJS.$('#' + tableId).find('.addGroupRowInput[data-row-index="' + rowIndex + '"]')[0]).on('click', function (event) {
                    event.preventDefault();
