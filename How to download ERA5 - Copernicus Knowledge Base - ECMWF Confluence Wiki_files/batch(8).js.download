function setValues() {
  var trackChangesE = AJS.$("#macro-param-type-values").find('#trackChanges');
  var trackChanges = (trackChangesE ? trackChangesE.is(':checked') : '');

  var extrasE = AJS.$("#macro-param-type-values").find('#extras');
  var extras = (extrasE ? extrasE.val() : '');

  var params = trackChanges + '[';
  AJS.$("#paramTable tr.values_toStore").each(function () {
    params = params + AJS.$(this).find('.i_macro-id-input').val() + '=' + AJS.$(this).find('.i_macro-value-input').val() + '|';
  });
  params = params + ']';

  if (params.length > 5600) {
    alert('Confluence has a limit set for the length of the macro parameters. And your last value exceeds this limit and could not be added');
    return;
  }

  AJS.$('#macro-param-values').val(params);
  AJS.$('#macro-param-extras').val(extras);
  AJS.MacroBrowser.processRequiredParameters();
}

