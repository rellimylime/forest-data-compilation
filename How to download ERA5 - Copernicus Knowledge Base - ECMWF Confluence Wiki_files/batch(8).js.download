/* module-key = 'com.adaptavist.confluence.formMailNG:destination-list-js', location = 'js/forms/config/destinationlist-macro.js' */
define('js/forms/config/destinationlist-macro', ['exports', 'js/forms/config/common'], function (exports, _common) {
    'use strict';

    Object.defineProperty(exports, "__esModule", {
        value: true
    });
    exports.addBindings = addBindings;
    function addBindings() {
        (0, _common.macroJsOverride)('mail-outgoing-parameter', createDestinationListMacro);
    }

    function createDestinationListMacro(macro) {

        //Creates a new ButtonGroupRow object that holds the parameters, or initial empty values
        var destinationListRow = new _common.getMacroParameters(macro.params);

        //Calls the dialog with Edit or Insert accordingly.
        AJS.dialog2(Forms.Macros.DestinationList.dialog({
            title: macro.body === undefined ? "Insert \u0027Destination list\u0027 Macro" : "Edit \u0027Destination list\u0027 Macro",
            buttonTitle: macro.body === undefined ? "Insert" : "Save",
            label: destinationListRow.getLabel(),
            description: destinationListRow.getDescription(),
            cssClass: destinationListRow.getCssClass(),
            cssStyle: destinationListRow.getCssStyle(),
            labelLength: destinationListRow.getLabelLength(),
            fieldWidth: destinationListRow.getFieldWidth(),
            required: macro.params === undefined ? true : macro.params.required === 'true',
            values: destinationListRow.getValues()
        })).show();

        var groupInput = AJS.$('#dataTable > tbody').find('input[name="destination"]');

        $.each(groupInput, function (input) {
            $(this).attr('id', 'destination' + input);
            createDestinationPicker('destination' + input);
        });

        (0, _common.setupCommonBehaviour)("mail-outgoing-parameter");
        (0, _common.setupCommonButtonsBehaviour)();
        (0, _common.registerGroupRowButtons)(addGroupRow);
        registerLabelChangeEvent();
        registerRequiredChangeEvent();
    }

    // Group Row Actions
    function addGroupRow(event) {
        var rowIndex = AJS.$(event.target).data("row-index");
        var maxIndex = (0, _common.getMaxIndex)();

        AJS.$('#dataTable > tbody > tr#groupRow' + rowIndex).after(Forms.Macros.DestinationList.addDestinationListRow({
            rowIndex: maxIndex,
            label: '',
            destination: '',
            required: AJS.$('#group-required').is(':checked'),
            subject: '',
            success: ''
        }));

        AJS.$('.removeGroupRowInput')[0].disabled = false;
        (0, _common.registerGroupRowButtons)(addGroupRow, maxIndex);

        var input = AJS.$('tr#groupRow' + maxIndex).find('input[name="destination"]');
        input.attr('id', 'destination' + maxIndex);
        createDestinationPicker('destination' + maxIndex);
    }

    function formatSearchResult(result) {
        if (typeof result.children !== 'undefined') {
            return '<strong class="select2-result-group">' + AJS.escapeHtml(result.text) + '</strong>';
        }
        return '<span class="select2-result-child">' + AJS.escapeHtml(result.text) + '</span>';
    }

    function formatSearchSelection(selection) {
        return AJS.escapeHtml(selection.text);
    }

    function createDestinationPicker(id) {

        // Select2 for Form Macro
        var _results = [];

        AJS.$("#" + id).auiSelect2({
            placeholder: 'Please enter one or multiple Form IDs, usernames or email addresses',
            multiple: true,
            formatResult: formatSearchResult,
            formatSelection: formatSearchSelection,
            tags: true,
            tokenSeparators: [','],

            createSearchChoice: function createSearchChoice(term) {
                if (_results.indexOf(term.toLowerCase()) === -1) {
                    return {
                        id: $.trim(term),
                        text: $.trim(term)
                    };
                }
            },

            initSelection: function initSelection(element, callback) {
                var data = [];

                function splitVal(string, separator) {
                    var val, i, l;
                    if (string === null || string.length < 1) return [];
                    val = string.split(separator);
                    for (i = 0, l = val.length; i < l; i = i + 1) {
                        val[i] = $.trim(val[i]);
                    }return val;
                }

                $(splitVal(element.val(), ",")).each(function () {
                    if (this.indexOf('~') === 0) {
                        var til = this.substring(1);

                        data.push({
                            id: this,
                            text: til
                        });
                    } else {
                        data.push({
                            id: this,
                            text: this
                        });
                    }
                });

                callback(data);
            },

            ajax: {
                url: AJS.Meta.get("context-path") + '/rest/formservice/1.0/configs/formmail/users/?' + 'spaceKey=' + AJS.params.spaceKey,
                dataType: 'json',
                type: "GET",
                quietMillis: 250,
                data: function data(term) {
                    return {
                        queryName: term,
                        selectedDestinations: this.val()
                    };
                },
                results: function results(data) {
                    var groups = {};
                    $.map(data, function (item) {
                        _results.push(item.name.toLowerCase());
                        var group = item.group;
                        groups[group] = groups[group] || [];
                        groups[group].children = groups[group].children || [];
                        groups[group].text = item.group;
                        groups[group].children.push({
                            id: item.idAsString,
                            text: item.name
                        });
                    });

                    return {
                        results: $.map(groups, function (group) {
                            return {
                                text: group.text,
                                children: group.children
                            };
                        })
                    };
                }
            }
        });
    }

    // needed to maintain a synchronization between label and name
    function registerLabelChangeEvent() {
        AJS.$('#group-label').on('change', function (event) {
            AJS.$('#group-name').val(AJS.$('#group-label').val());
        });
    }

    // needed to maintain the validation of destination field working
    function registerRequiredChangeEvent() {
        AJS.$('#group-required').on('change', function (event) {
            var destinationHeader = AJS.$('th:contains("Destination")');
            destinationHeader.find('span').remove();
            destinationHeader.html("Destination");
            var destinations = AJS.$('input[name="destination"]');
            destinations.removeAttr("required");
            if (event.target.checked) {
                destinationHeader.html("Destination" + Forms.Macros.Common.requiredIcon());
                destinations.attr("required", "required");
            }
        });
    }
});

}catch(e){WRMCB(e)};
;
try {
/* module-key = 'com.adaptavist.confluence.formMailNG:additional-recipients-js', location = 'js/forms/rendering/additional-recipients.js' */
AJS.toInit(function ($) {

    initAdditionalRecipientsField();
    registerClosePrePopulatedValueListener();

    function initAdditionalRecipientsField() {
        if (AJS.params.remoteUser) {
            loggedInUserSelect2();
        } else {
            handleAnonUserWithProfileViewPermission();
        }
    }

    //event which is triggered by the form submit button in forms.js to reset select2
    //re-register field and as a result re-register the listener
    AJS.$('.formMail-additional-recipients').on('additionalRecipientsSelect2:reset', function () {
        AJS.$('.formMail-additional-recipients').auiSelect2('destroy');
        initAdditionalRecipientsField();
        registerClosePrePopulatedValueListener();
    });

    function formatRepo(result) {
        if (typeof result.children !== 'undefined') {
            return '<strong class="select2-result-group">' + result.text + '</strong>';
        }
        return '<span class="select2-result-child">' + result.text + '</span>';
    }

    function handleAnonUserWithProfileViewPermission() {
        $.ajax({
            url: AJS.Meta.get("context-path") + '/rest/formservice/1.0/configs/formmail/anonuser/hasprofileviewpermission',
            dataType: 'json',
            type: "GET",
            quietMillis: 250,
            async: false,
            success: function (data) {
                if (data === true) {
                    loggedInUserSelect2();
                } else {
                    anonymousUserSelect2();
                }
            }
        });
    }

    //handle event when the default pre populated field value $user.email is removed
    function registerClosePrePopulatedValueListener() {
        AJS.$('.select2-search-choice-close').on('click', function () {
            var defaultFieldVal = $('.formMail-additional-recipients.text.select2-offscreen').attr('sel2value');
            //if the default value is being removed
            if ($(this).prev().text() === defaultFieldVal) {
                var currentFieldValue = [];
                $(this).closest('ul.select2-choices').find('.select2-search-choice').each(function () {
                    if ($(this).text().trim() !== defaultFieldVal) {
                        currentFieldValue.push($(this).text().trim());
                    }
                });
                //remove extra comma if the blank space exists
                var index = currentFieldValue.indexOf('');
                if (index > -1) {
                    currentFieldValue.splice(index, 1);
                    //add existing values back if they exist
                    $('.formMail-additional-recipients').val(currentFieldValue);
                } else {
                    //change select2 placeholder without affecting the field value
                    $('.formMail-additional-recipients').attr('data-placeholder', ' ');
                }
            }
        });
    }

    function loggedInUserSelect2() {
        AJS.$('.formMail-additional-recipients').each(function () {
            var results = [];

            //if a macro field value param was provided then prepopulate the field with the value before making the ajax call
            $(this).val(function () {
                if ($(this).attr('sel2value')) {
                    return [$(this).attr('sel2value')];
                } else {
                    $(this).attr('sell2value', "");
                    return "";
                }
            }).auiSelect2({
                placeholder: this.getAttribute('sel2value'),
                width: 'element',
                multiple: true,
                minimumInputLength: 2,
                maximumSelectionSize: this.getAttribute('maxSelection'),
                formatResult: formatRepo,
                tags: true,
                tokenSeparators: [','],

                createSearchChoice: function (term) {
                    if (results.indexOf(term.toLowerCase()) === -1 && validateEmail(term)) {
                        return {
                            id: $.trim(term),
                            text: $.trim(term)
                        };
                    }
                },

                initSelection: function (element, callback) {
                    var data = [];

                    function splitVal(string, separator) {
                        var val, i, l;
                        if (string === null || string.length < 1) return [];
                        val = string.split(separator);
                        for (i = 0, l = val.length; i < l; i = i + 1) val[i] = $.trim(val[i]);
                        return val;
                    }

                    $(splitVal(element.val(), ",")).each(function () {
                        if (this.indexOf('~') === 0) {
                            var til = this.substring(1);

                            data.push({
                                id: this,
                                text: til
                            });
                        } else {
                            data.push({
                                id: this,
                                text: this
                            });
                        }
                    });

                    callback(data);
                },

                ajax: {
                    url: AJS.Meta.get("context-path") + '/rest/formservice/1.0/configs/formmail/users/?' + 'spaceKey=' + AJS.params.spaceKey,
                    dataType: 'json',
                    type: "GET",
                    quietMillis: 250,
                    data: function (term) {
                        return {
                            queryName: term,
                            selectedDestinations: this.val()
                        };
                    },
                    results: function (data) {
                        var groups = {};
                        $.map(data, function (item) {
                            if (item.group !== 'Forms Config') {
                                results.push(item.name.toLowerCase());
                                var group = item.group;
                                groups[group] = groups[group] || [];
                                groups[group].children = groups[group].children || [];
                                groups[group].text = item.group;
                                groups[group].children.push({
                                    id: item.idAsString,
                                    text: item.name
                                });
                            }
                        });

                        return {
                            results: $.map(groups, function (group) {
                                return {
                                    text: group.text,
                                    children: group.children
                                }
                            })
                        }
                    }
                }
            });
        });
    }

    function anonymousUserSelect2() {
        AJS.$('.formMail-additional-recipients').each(function () {
            var results = [];

            //if a macro field value param was provided then prepopulate the field with the value before making the ajax call
            $(this).val(function () {
                if ($(this).attr("sel2value")) {
                    return [$(this).attr("sel2value")];
                } else {
                    $(this).attr('sell2value', "");
                    return "";
                }
            }).auiSelect2({
                placeholder: this.getAttribute('sel2value'),
                width: 'element',
                multiple: true,
                minimumInputLength: 2,
                maximumSelectionSize: this.getAttribute('maxSelection'),
                formatResult: formatRepo,
                tags: true,
                tokenSeparators: [','],

                createSearchChoice: function (term) {
                    if (results.indexOf(term.toLowerCase()) === -1  && validateEmail(term)) {
                        return {
                            id: $.trim(term),
                            text: $.trim(term)
                        };
                    }
                },

                initSelection: function (element, callback) {
                    var data = [];

                    function splitVal(string, separator) {
                        var val, i, l;
                        if (string === null || string.length < 1) return [];
                        val = string.split(separator);
                        for (i = 0, l = val.length; i < l; i = i + 1) val[i] = $.trim(val[i]);
                        return val;
                    }

                    $(splitVal(element.val(), ",")).each(function () {
                        if (this.indexOf('~') === 0) {
                            var til = this.substring(1);

                            data.push({
                                id: this,
                                text: til
                            });
                        } else {
                            data.push({
                                id: this,
                                text: this
                            });
                        }
                    });

                    callback(data);
                }
            });
        });
    }

    function validateEmail(email) {
        var re = /^(([^<>()[\]\\.,;:\s@\"]+(\.[^<>()[\]\\.,;:\s@\"]+)*)|(\".+\"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
        return re.test(email);
    }
});


}catch(e){WRMCB(e)};
;
