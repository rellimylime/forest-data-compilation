        select.append(AJS.$("<option/>").attr("value", 'voting').html('Voting Control'));

        select.append(AJS.$("<option/>").attr("value", 'objectRef').html('Webservice Object Referencing Field'));

        select.append(AJS.$("<option/>").attr("value", 'wsselect').html('Webservice Dropdown'));
        select.append(AJS.$("<option/>").attr("value", 'wsselect2').html('Webservice Dropdown (advanced)'));

        select.append(AJS.$("<option/>").attr("value", 'wsdynamicmultilabel').html('Webservice Dynamic Multi-label'));
        select.append(AJS.$("<option/>").attr("value", 'wsmultiselect').html('Webservice Multi-select'));
        select.append(AJS.$("<option/>").attr("value", 'wscheckbox').html('Webservice Checkbox'));
        select.append(AJS.$("<option/>").attr("value", 'wsradio').html('Webservice Radio Group'));

        select.append(AJS.$("<option/>").attr("value", 'wysiwyg').html('WYSIWYG Simple Editor'));

        select.change(function () {
          if ('multiselect' === AJS.$(this).val()) { // on cloud this is unfortunatelly called as multiselect
            showCFParams('multi');
          } else {
            showCFParams(AJS.$(this).val());
          }
        });

        select.css('width', '100%');

        select.after('<div id="macro-param-type-values"></div>');

        //AJS.$(select).val("text"); // set text option as default

        //showCFParams(AJS.$(select).val());

        return AJS.MacroBrowser.CFField2(paramDiv, select, options);
      } else if ((param.name === "values") || (param.name === "extras") || (param.name === "separator") || (param.name === "mapping") || (param.name === "extracontext")) {
        var paramDiv = AJS.$(Confluence.Templates.MacroBrowser.macroParameterHidden());
        paramDiv.hide();
        var input = AJS.$("input", paramDiv);
        return AJS.MacroBrowser.Field(paramDiv, input, options);
      } else {
        var paramDiv = $(Confluence.Templates.MacroBrowser.macroParameter());
        var input = $("input", paramDiv);
        if (param.required) {
          input.keyup(AJS.MacroBrowser.processRequiredParameters);
        }
        return AJS.MacroBrowser.Field(paramDiv, input, options);
      }
    }
  }
});

AJS.MacroBrowser.CFField2 = function (paramDiv, input, options) {
  options = options || {};

  var setValue = options.setValue || function (value) {
    if (value == null || value === '') {
      value = 'text';
    }
      input.val(value);
      showCFParams(value);
      //resetSubParams();
    };

  var getValue = options.getValue || function () {
      return input.val();
    };

  input.change(options.onchange || AJS.MacroBrowser.paramChanged);

  return {
    paramDiv: paramDiv,
    input: input,
    setValue: setValue,
    getValue: getValue
  };
};

function showCFParams(val) {
  //if (val == 'checkbox_group' || val == 'radio_group' || val == 'select' || val == 'dynamicselect' || val == 'dynamicmultilabel' || val == 'smartselect' || val == 'smartcheckbox' || val == 'smartradio' || val == 'smartmultiselect' || val == 'smartclass' || val == 'status' || val == 'multi' || val == 'auto' || val == 'simpledate' || val == 'page' || val == 'autopage' || val == 'hidden' || val == 'read_only' || val == 'hiddenhtml' || val == 'user' || val == 'autolink' || val == 'maskedtext' || val == 'currency' || val == 'calc' || val == 'formula' || val == 'enroll' || val == 'voting' || val == 'datetime' || val == 'datetimeinterval' || val == 'multiuser' || val == 'action_button') {
  var paramsDivHtml = "";
  $("#macro-browser-dialog button.ok").prop("disabled", true);
  AJS.$.ajax({
    type: "POST",
    async: false,
    url: AJS.Meta.get('context-path') + "/plugins/servlet/confiform/params",
    success: function (data) {
      paramsDivHtml = data;
      AJS.$("#macro-param-type-values").replaceWith(paramsDivHtml);

      if (val === 'smartselect' || val === 'smartselect2' || val === 'smartmultiselect' || val === 'smartcheckbox' || val === 'smartradio') {
        setSmartValues();
        AJS.MacroBrowser.processRequiredParameters();

        lookupPages(AJS.$('#macro-param-type-values').find('input[id="pageParamInput"]'),
          function (pageId) {
            AJS.$('#macro-param-type-values').find('input[id="pageIdParamInput"]').val(pageId).trigger("change");
            setSmartValues();
            showCFParams(val);
            AJS.MacroBrowser.processRequiredParameters();
          }, true);
      }
      if (val === 'attachment') {
        setPageRef();
        AJS.MacroBrowser.processRequiredParameters();

        lookupPages(AJS.$('#macro-param-type-values').find('input[id="pageParamInput"]'),
          function (pageId) {
            AJS.$('#macro-param-type-values').find('input[id="pageIdParamInput"]').val(pageId).trigger("change");
            setPageRef();
            AJS.MacroBrowser.processRequiredParameters();
          }, true);
      }

      if (val === 'dynamicselect' || val === 'dynamicmultilabel') {
        setDynamicExtras();
        AJS.MacroBrowser.processRequiredParameters();

        lookupPages(AJS.$('#macro-param-type-values').find('input[id="pageParamInput"]'),
          function (pageId) {
            AJS.$('#macro-param-type-values').find('input[id="pageIdParamInput"]').val(pageId).trigger("change");
            setDynamicExtras();
            showCFParams(val);
            AJS.MacroBrowser.processRequiredParameters();
          }, true);
      }

      if (val === 'smartclass' || val === 'smartmultirow' || val === 'smartconfiquery') {
        setClassifierValues();
        AJS.MacroBrowser.processRequiredParameters();

        lookupPages(AJS.$('#macro-param-type-values').find('input[id="pageParamInput"]'),
          function (pageId) {
            AJS.$('#macro-param-type-values').find('input[id="pageIdParamInput"]').val(pageId).trigger("change");

            AJS.$("#paramTable tr.values_toStore").each(function () {
              AJS.$(this).remove();
            }, true);

            setClassifierValues();
            showCFParams(val);
            AJS.MacroBrowser.processRequiredParameters();
          }, true);
      }

      AJS.MacroBrowser.processRequiredParameters();
    },
    data: jQuery.param({
      params: AJS.$('#macro-param-values').val(),
      extras: AJS.$('#macro-param-extras').val(),
      extracontext: AJS.$('#macro-param-extracontext').val(),
      separator: AJS.$('#macro-param-separator').val(),
      mapping: AJS.$('#macro-param-mapping').val(),
      pageId: AJS.Meta.get("page-id"),
      type: val
    })
  });
}

