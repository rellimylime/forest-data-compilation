font-info" title="' + soy.$$escapeHtml('Displayed below the field') + '" ></span><input id="group-desc" name="group-desc" type="text" value="' + soy.$$escapeHtml(opt_data.description) + '" class="text"/></div></div><div class="aui-group aui-group-split"><div class="aui-item align-left group-required"><label for="group-required">' + soy.$$escapeHtml('Required') + '</label><input id="group-required" name="group-required" type="checkbox" value="true" ' + ((opt_data.required) ? 'checked="true"' : '') + '/></div><div class="aui-item align-left group-multiselect"><label for="group-multiselect">' + soy.$$escapeHtml('Multiselect') + '</label><input id="group-multiselect" name="group-multiselect" type="checkbox" value="true" ' + ((opt_data.multiselect) ? 'checked="true"' : '') + '/></div></div></fieldset><fieldset class="rows"><legend>' + soy.$$escapeHtml('Add or Remove Dropdown List Options') + '</legend><div class="aui-group"><div class="aui-item create-button-rows"><table class="aui" id="dataTable"><thead><tr><th class="buttonLabel">' + soy.$$escapeHtml('Label') + '</th><th class="buttonValue">' + Forms.Macros.Common.velocityValueLink(null) + '</th><th class="actions">' + soy.$$escapeHtml('Actions') + '</th></tr></thead><tbody>';
