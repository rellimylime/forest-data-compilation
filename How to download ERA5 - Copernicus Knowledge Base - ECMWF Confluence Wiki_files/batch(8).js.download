function setExtrasAndQueryState() {
  var extrasE = AJS.$("#macro-param-type-values").find('#extras');
  var configId = (extrasE ? extrasE.val() : '');
  AJS.$('#macro-param-extras').val(configId);
  AJS.MacroBrowser.processRequiredParameters();

  processSQLConfigParamDetails(configId);
}

function processSQLConfigParamDetails(configId) {
  var dbConfigs = tryProcessAsJSON(AJS.$('#dbConfigsHolderJSON').html());

  var showDBMapping = false;

  for (let i = 0; i < dbConfigs.length; i++) {
    let dbConfig = dbConfigs[i];
    if (configId === dbConfig.id) {
      if (dbConfig.readonly) {
        AJS.$('#sqlQueryPane').hide();

        AJS.$('#sqlQuerySelector option').remove();

        if (dbConfig.queries.length > 0) {
          AJS.$('#sqlQuerySelector').append('<option value=""></option>');
          for (let j = 0; j < dbConfig.queries.length; j++) {
            AJS.$('#sqlQuerySelector').append('<option value="' + dbConfig.queries[j].id + '">' + dbConfig.queries[j].name + '</option>');
          }
        }
        AJS.$('#sqlQuerySelectorPane').show();
      } else {
        AJS.$('#sqlQueryPane').show();
        AJS.$('#sqlQuerySelector option').remove();
        AJS.$('#sqlQuerySelectorPane').hide();
      }
      showDBMapping = true;
    }
  }

  if (showDBMapping) {
    AJS.$('#showMappingBtn').show();
  } else {
    AJS.$('#showMappingBtn').hide();
  }
}

function setStatusId(elem) {
  var trow = AJS.$(elem).closest('tr');
  var valVal = AJS.$(trow).find('.i_macro-value-input').val(elem.value);
  AJS.MacroBrowser.processRequiredParameters();
}

function saveStatusEntry(elem) {
  var trow = AJS.$(elem).closest('tr');

  var idVal = AJS.$('.redef_status_cl:checked').val();
  var valVal = AJS.$(trow).find('.i_macro-value-input').val();

  if (idVal != '' && valVal != '') {
    var html = '<tr class="values_toStore">' +
      '<td class="confluenceTd"><span class="aui-lozenge aui-lozenge-' + idVal + '">' + valVal + '</span>' +
      '<input type="hidden" name="i_macro-id-input" class="macro-param-input i_macro-id-input" value="' + idVal + '"/>' +
      '<input type="hidden" name="i_macro-value-input" class="macro-param-input i_macro-value-input" value="' + valVal + '"/>' +
      '<br/><button type="button" class="aui aui-button" onclick="editStatusEntry(this);"><span class="aui-icon aui-icon-small aui-iconfont-edit">Edit</span></button>' +
      '<button type="button" class="aui aui-button" onclick="removeEntry(this);"><span class="aui-icon aui-icon-small aui-iconfont-remove">Remove</span></button>' +
      '</td></tr>';

    AJS.$(trow).replaceWith(html);
    setValues();
  } else {
    AJS.$(trow).replaceWith('');
  }
  AJS.MacroBrowser.processRequiredParameters();
}

function saveDynamicEntry(elem) {
  var trow = AJS.$(elem).closest('tr');
  var valVal = AJS.$(trow).find('.i_macro-value-input').val();

  if (valVal !== '') {
    var html = '<tr class="values_toStore">' +
      '<td class="confluenceTd"><input type="hidden" name="i_macro-id-input" class="macro-param-input i_macro-id-input" value="' + valVal + '"/>' +
      valVal + '<input type="hidden" name="i_macro-value-input" class="macro-param-input i_macro-value-input" value="' + valVal + '"/>' +
      '<br/><button type="button" class="aui aui-button" onclick="editDynamicEntry(this);"><span class="aui-icon aui-icon-small aui-iconfont-edit">Edit</span></button>' +
      '<button type="button" class="aui aui-button" onclick="removeEntry(this);"><span class="aui-icon aui-icon-small aui-iconfont-remove">Remove</span></button>' +
      '</td></tr>';

    AJS.$(trow).replaceWith(html);
    setDynamicExtras();
  } else {
    AJS.$(trow).replaceWith('');
  }
  AJS.MacroBrowser.processRequiredParameters();
}

function saveEntry(elem) {
  var trow = AJS.$(elem).closest('tr');
  var idVal = AJS.$(trow).find('.i_macro-id-input').val();
  var valVal = AJS.$(trow).find('.i_macro-value-input').val();

  if (idVal !== '' && valVal !== '') {
    var html = '<tr class="values_toStore confluenceTr">' +
      '<td class="confluenceTd">' + idVal + '<input type="hidden" name="i_macro-id-input" class="macro-param-input i_macro-id-input" value="' + idVal + '"/></td>' +
      '<td class="confluenceTd">' + valVal + '<input type="hidden" name="i_macro-value-input" class="macro-param-input i_macro-value-input" value="' + valVal + '"/>' +
      '<br/><button type="button" class="aui aui-button" onclick="editEntry(this);"><span class="aui-icon aui-icon-small aui-iconfont-edit">Edit</span></button>' +
      '<button type="button" class="aui aui-button" onclick="removeEntry(this);"><span class="aui-icon aui-icon-small aui-iconfont-remove">Remove</span></button>' +
      '</td></tr>';

    AJS.$(trow).replaceWith(html);

    setValues();
  } else {
    AJS.$(trow).replaceWith('');
  }
  AJS.MacroBrowser.processRequiredParameters();
}

function editDynamicEntry(elem) {
  AJS.$('.cf_saveEntry').each(function () {
    AJS.$(this).click();
  });

  var trow = AJS.$(elem).closest('tr');
  var idVal = AJS.$(trow).find('.i_macro-id-input').val();
  var valVal = AJS.$(trow).find('.i_macro-value-input').val();

  addOrModifyDynamicEntry(idVal, valVal, trow);
  AJS.$(trow).find('.i_macro-id-input').focus();
  AJS.MacroBrowser.processRequiredParameters();
}

function editEntry(elem) {
  AJS.$('.cf_saveEntry').each(function () {
    AJS.$(this).click();
  });

  var trow = AJS.$(elem).closest('tr');
  var idVal = AJS.$(trow).find('.i_macro-id-input').val();
  var valVal = AJS.$(trow).find('.i_macro-value-input').val();

  addOrModifyEntry(idVal, valVal, trow);
  AJS.$(trow).find('.i_macro-id-input').focus();
  AJS.MacroBrowser.processRequiredParameters();
}

function editStatusEntry(elem) {
  AJS.$('.cf_saveEntry').each(function () {
    AJS.$(this).click();
  });

  var trow = AJS.$(elem).closest('tr');
  var idVal = AJS.$(trow).find('.i_macro-id-input').val();
  var valVal = AJS.$(trow).find('.i_macro-value-input').val();

  addOrModifyStatusEntry(idVal, valVal, trow);
  AJS.MacroBrowser.processRequiredParameters();
}

function removeEntry(elem) {
  if (window.confirm("Are you sure you want to remove it?")) {
    var trow = AJS.$(elem).closest('tr');
    trow.remove();
    setValues();
  }
}

function removeDynamicEntry(elem) {
  if (window.confirm("Are you sure you want to remove it?")) {
    var trow = AJS.$(elem).closest('tr');
    trow.remove();
    setDynamicExtras();
  }
}

function removeClassifierEntry(elem) {
  if (window.confirm("Are you sure you want to remove it?")) {
    var trow = AJS.$(elem).closest('tr');
    trow.remove();
    setClassifierValues();
  }
}

function lookupPages(element, onItemSelected, withRefToSelf) {
  if (element != null) {
    var xhr;

    element.change(function(){
      if (AJS.$(element).val() === '') {
        onItemSelected('');
      }
    });

    element.confiFormsAutoComplete({
      minChars: 2,
      cache: false,
      onSelect: function (e, v, item) {
        var selectedPageId = item.attr('data-internal');
        onItemSelected(selectedPageId);
        try {
          e.preventDefault();
        } catch (e) {
        }
        return false;
      },
      renderItem: function (item, search) {
        //search = search.replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&');
        //var re = new RegExp("(" + search.split(' ').join('|') + ")", "gi");
        var encodedLabel = encodeHTML1(item.label);
        return "<a class='autocomplete-suggestion text' style='display: block;' data-internal='" + item.id + "' data-val='" + encodedLabel + "'>"
          + "<span data-internal='" + item.id + "' data-val='" + encodedLabel + "' style='padding-left: 10px;font-size: inherit;padding-right: 0; cursor: pointer'>" + encodedLabel + "</span></a>";
      },
      source: function (term, response) {
        try {
          xhr.abort();
        } catch (e) {
        }

        xhr = AJS.$.getJSON(AJS.Meta.get('context-path') + "/rest/prototype/1/search/name.json?max-results=20&pageSize=25&type=page%2Cblogpost", {query: "" + term}, function (rawData) {
          var data = AJS.$.parseJSON(JSON.stringify(rawData));
          var r = new Array();
          var idx = 0;

          if (withRefToSelf) {
            r[idx++] = {
              "id": '[entry._page]',
              "label": '@self'
            };
          }

          if (data.group && data.group.length > 0) {
            var jsonResult = data.group[0].result;
            for (var key = 0; key < jsonResult.length; key++) {
              r[idx++] = {
                "id": jsonResult[key].id,
                "label": jsonResult[key].space.name + ' : ' + jsonResult[key].title
              };
            }
          }
          if (data.group && data.group.length > 1) {
            var jsonResult = data.group[1].result;
            for (var key = 0; key < jsonResult.length; key++) {
              r[idx++] = {
                "id": jsonResult[key].id,
                "label": jsonResult[key].space.name + ' : ' + jsonResult[key].title
              };
            }
          }
          response(r);
        });
      }
    });
  }
}

AJS.MacroBrowser.setMacroJsOverride("confiform-ifttt", {
