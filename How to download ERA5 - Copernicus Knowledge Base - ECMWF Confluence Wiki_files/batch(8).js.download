  return '<div class="field-group"><label for="field-width">' + soy.$$escapeHtml('Field width') + '</label><span class="aui-icon aui-icon-small aui-iconfont-info" title="' + soy.$$escapeHtml('Defines the width of the field') + '" ></span><select name="field-width" id="field-width" class="select" ><option value="short-field" ' + ((opt_data.fieldWidth == 'short-field') ? 'selected' : '') + '>Extra Small</option><option value="medium-field" ' + ((opt_data.fieldWidth == 'medium-field') ? 'selected' : '') + '>Small</option><option value="mediumField" ' + ((opt_data.fieldWidth == 'mediumField' || opt_data.fieldWidth == '') ? 'selected' : '') + '>Medium</option><option value="medium-long-field" ' + ((opt_data.fieldWidth == 'medium-long-field') ? 'selected' : '') + '>Large</option><option value="long-field" ' + ((opt_data.fieldWidth == 'long-field') ? 'selected' : '') + '>Extra Large</option></select></div>';
};
if (goog.DEBUG) {
  Forms.Macros.Common.fieldWidth.soyTemplateName = 'Forms.Macros.Common.fieldWidth';
}


Forms.Macros.Common.addGroupRow = function(opt_data, opt_ignored) {
  return '<tr id="groupRow' + soy.$$escapeHtml(opt_data.rowIndex) + '"><td class="buttonLabel"><input id="buttonInputLabel-' + soy.$$escapeHtml(opt_data.rowIndex) + '" class="text buttonInputLabel" name="buttonLabel" type="text" value="' + soy.$$escapeHtml(opt_data.label) + '" required="required" /></td><td class="buttonValue"><input id="buttonInputValue-' + soy.$$escapeHtml(opt_data.rowIndex) + '" class="text buttonInputValue" name="buttonValue" type="text" value="' + soy.$$escapeHtml(opt_data.value) + '" ' + ((opt_data.required) ? 'required="required"' : '') + ' /></td>' + ((opt_data.selected != undefined) ? '<td class="buttonSelected"><input id="rowSelected-' + soy.$$escapeHtml(opt_data.rowIndex) + '" name="buttonSelected" name="selected" type="' + soy.$$escapeHtml(opt_data.selectedType) + '" ' + ((opt_data.selected) ? 'checked="true"' : '') + '/></td>' : '') + '<td class="actions"><input type="button" class="aui-button addGroupRowInput" value="+" data-row-index="' + soy.$$escapeHtml(opt_data.rowIndex) + '"/><input type="button" class="aui-button removeGroupRowInput" data-row-index="' + soy.$$escapeHtml(opt_data.rowIndex) + '" value="-" ' + ((opt_data.size == 1) ? 'disabled' : '') + '/></td></tr>';
};
if (goog.DEBUG) {
  Forms.Macros.Common.addGroupRow.soyTemplateName = 'Forms.Macros.Common.addGroupRow';
}

