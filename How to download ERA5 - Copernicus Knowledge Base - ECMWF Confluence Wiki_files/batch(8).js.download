function cleanInput(input) {
    return removeHtmlTags(input).trim();
}

function removeHtmlTags(input) {
    return input.replace(/<\/?[^>]+(>|$)/g, "");
}

if (typeof exports !== 'undefined') {
    exports.cleanInput = cleanInput;
}
}catch(e){WRMCB(e)};
;
