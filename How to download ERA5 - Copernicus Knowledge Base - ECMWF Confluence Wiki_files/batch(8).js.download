        select.append(AJS.$("<option/>").attr("value", 'Copy Attachment').html('Copy Attachment'));
        select.append(AJS.$("<option/>").attr("value", 'Copy ConfiForms Data').html('Copy ConfiForms Data'));
        select.append(AJS.$("<option/>").attr("value", 'Copy ConfiForms Data to DB').html('Copy ConfiForms Data to DB'));
        select.append(AJS.$("<option/>").attr("value", 'Copy Page').html('Copy Page'));
        select.append(AJS.$("<option/>").attr("value", 'Create Attachment').html('Create Attachment'));
        select.append(AJS.$("<option/>").attr("value", 'Create BlogPost').html('Create BlogPost'));
        select.append(AJS.$("<option/>").attr("value", 'Create Comment').html('Create Comment'));
        select.append(AJS.$("<option/>").attr("value", 'Create ConfiForms Entry').html('Create / Update ConfiForms Entry'));
        select.append(AJS.$("<option/>").attr("value", 'Create Insight Object').html('Create Insight Object'));
        select.append(AJS.$("<option/>").attr("value", 'Create JIRA Issue').html('Create Jira Issue'));
        select.append(AJS.$("<option/>").attr("value", 'Create Page').html('Create Page'));
        // select.append(AJS.$("<option/>").attr("value", 'Create Task').html('Create Confluence Task'));
        select.append(AJS.$("<option/>").attr("value", 'Delete Attachment').html('Delete Attachment'));
        select.append(AJS.$("<option/>").attr("value", 'Delete ConfiForms Entry').html('Delete ConfiForms Entry'));
        select.append(AJS.$("<option/>").attr("value", 'Delete Page').html('Delete Page'));
        select.append(AJS.$("<option/>").attr("value", 'Force Page Re-index').html('Force Page Re-index'));
        select.append(AJS.$("<option/>").attr("value", 'Generate next number').html('Generate next number'));
        select.append(AJS.$("<option/>").attr("value", 'Make request').html('Make HTTP Request (deprecated)'));
        select.append(AJS.$("<option/>").attr("value", 'Move Attachment').html('Move Attachment'));
        select.append(AJS.$("<option/>").attr("value", 'Move Page').html('Move Page'));
        select.append(AJS.$("<option/>").attr("value", 'Redirect to URL').html('Redirect to URL'));
        select.append(AJS.$("<option/>").attr("value", 'Remove Attachment Label').html('Remove Attachment Label'));
        select.append(AJS.$("<option/>").attr("value", 'Remove Page Label').html('Remove Page Label'));
        select.append(AJS.$("<option/>").attr("value", 'Remove Page Edit Restrictions').html('Remove Page Edit Restrictions'));
        select.append(AJS.$("<option/>").attr("value", 'Remove Page View Restrictions').html('Remove Page View Restrictions'));
        select.append(AJS.$("<option/>").attr("value", 'Remove Page Watcher').html('Remove Page Watcher'));
        select.append(AJS.$("<option/>").attr("value", 'Rename Page').html('Rename Page'));
        select.append(AJS.$("<option/>").attr("value", 'Render (execute) macro').html('Render (execute) macro'));
        select.append(AJS.$("<option/>").attr("value", 'Restrict Page Edit').html('Restrict Page Edit'));
        select.append(AJS.$("<option/>").attr("value", 'Restrict Page View').html('Restrict Page View'));
        select.append(AJS.$("<option/>").attr("value", 'Run JavaScript').html('Run JavaScript'));
        select.append(AJS.$("<option/>").attr("value", 'Send Email').html('Send Email'));
        select.append(AJS.$("<option/>").attr("value", 'Send Notification').html('Send Notification'));
        select.append(AJS.$("<option/>").attr("value", 'Set Page Revision').html('Set Page Revision'));
        select.append(AJS.$("<option/>").attr("value", 'Synchronize smart field references').html('Synchronize smart field references'));
        select.append(AJS.$("<option/>").attr("value", 'Update ConfiForms entries by filter').html('Update ConfiForms entries by filter'));
        select.append(AJS.$("<option/>").attr("value", 'Update JIRA Issue').html('Update Jira Issue'));
        select.append(AJS.$("<option/>").attr("value", 'WebService Request').html('WebService Request'));

        select.change(function () {
          showLabels(AJS.$(this).val());
        });

        select.css('width', '100%');
        return AJS.MacroBrowser.IFTTTMacroField(paramDiv, select, options);
      } else if ((param.name === "extras") || (param.name === "extras2")
        || (param.name === "extras3")
        || (param.name === "additionalContext")
        || (param.name === "extras4") || (param.name === "extras5")) {
        var paramDiv = AJS.$(Confluence.Templates.MacroBrowser.macroParameter());
        var input = AJS.$("input", paramDiv);
        return AJS.MacroBrowser.IFTTTMacroField(paramDiv, input, options);
      } else {
        var paramDiv = $(Confluence.Templates.MacroBrowser.macroParameter());
        var input = $("input", paramDiv);
        if (param.required) {
          input.keyup(AJS.MacroBrowser.processRequiredParameters);
        }
        return AJS.MacroBrowser.IFTTTMacroField(paramDiv, input, options);
      }
    }
  }
});

AJS.MacroBrowser.IFTTTMacroField = function (paramDiv, input, options) {
  options = options || {};

  var setValue = options.setValue || function (value) {
      input.val(value);
      showLabels(AJS.$('#macro-param-action').val());
    };

  var getValue = options.getValue || function () {
      return input.val();
    };

  input.change(options.onchange || AJS.MacroBrowser.paramChanged);

  return {
    paramDiv: paramDiv,
    input: input,
    setValue: setValue,
    getValue: getValue
  };
};

function showLabels(choice) {
  AJS.$('#extraDetails').remove();

  var titleLabel = 'Subject for email message';
  var whoLabel = 'Recipients';
  var extrasLabel = 'Sender';
  var extras2Label = 'Labels';
  var extras3Label = 'Flatten entries';
  var extras4Label = 'Bypass field restrictions and validation rules';
  var extras5Label = 'All IFTTT rules should be used (including lifecycle rules, such as: create/modify/copy ConfiForms entries)';
  var additionalContextLabel = 'Set parameter name (multipart file upload)';

  var standardTitleText = 'Could be constructed dynamically. You can reference record owner as [owner]; record modifier, as [modifier]; any record field as [entry.field_name], you can reference page watchers as [watchers], you can reference page contributors as [contributors]';
  var standardWhoText = 'Multiple values should be given as comma separated list. Record owner could be referenced as [owner], Record modifier, as [modifier]. To reference field value use: [entry.field_name]';
  var standardExtrasText = 'Accepts username or email address. Leave blank if you want current user to be used as sender. You can use references to entry values via [entry.field_name]';
  var standardExtras2Text = 'Comma separated list of labels to add to created page. You can use references to entry values via [entry.field_name]';
  var standardExtras3Text = 'Flatten entries before copying (when form has multi-select values)';
  var standardExtras4Text = 'When enabled, field definition edit restrictions will be ignored';
  var standardExtras5Text = 'When enabled, all IFTTTs will be called (including the ones to create/copy data). This assumes your "Stop events propagation" is not set. Important! This might cause infinite loops!';
  var additionalContextText = 'Set when you are configuring the file uploads (using ConfiForms Field macros inside this IFTTT and want to use multi-part form data method to upload). Leave empty then the file should be uploaded as a stream';

  AJS.$('#macro-param-div-title').show();
  AJS.$('#macro-param-div-who').show();
  AJS.$('#macro-param-div-extras').show();
  AJS.$('#macro-param-div-extras2').hide();
  AJS.$('#macro-param-div-extras3').hide();
  AJS.$('#macro-param-div-extras4').hide();
  AJS.$('#macro-param-div-extras5').hide();
  AJS.$('#macro-param-div-additionalContext').hide();
  AJS.$('#macro-param-extras').show();

  // remove autocomplete
  try {
    AJS.$('#macro-param-div-extras').find('#macro-param-extras').destroy();
  } catch (e) {

  }

  if (choice == null || '' === choice) {
    AJS.$('#macro-param-div-title').hide();
    AJS.$('#macro-param-div-who').hide();
    AJS.$('#macro-param-div-extras').hide();
    AJS.$('#macro-param-div-extras2').hide();
    AJS.$('#macro-param-div-extras3').hide();
    AJS.$('#macro-param-div-additionalContext').hide();
  }

  if ('Create Comment' === choice) {
    extrasLabel = 'Page';
    standardExtrasText = 'You (and the users who will use the form) must have edit permissions on this page. Leave blank if current page should be used as parent page. To reference field value use: [entry.field_name]. Must resolve into spaceKey:pageTitle or in pageId value. Leaving this parameter blank means current page.';

    lookupPages(AJS.$('#macro-param-div-extras').find('#macro-param-extras'),
      function (pageId) {
        AJS.$('#macro-param-div-extras').find('#macro-param-extras').val(pageId).trigger("change");
        AJS.MacroBrowser.processRequiredParameters();
      }, false);

    AJS.$('#macro-param-div-extras').show();
    AJS.$('#macro-param-div-who').hide();
    AJS.$('#macro-param-div-title').hide();
    AJS.$('#macro-param-div-extras2').hide();
    AJS.$('#macro-param-div-extras3').hide();
  }

  if ('Create Page' === choice) {
    titleLabel = 'Page Title';
    whoLabel = 'Page editors (comma separated list of users/usergroups)';
    extrasLabel = 'Parent page';
    standardExtrasText = 'You (and the users who will use the form) must have edit permissions on this page. Leave blank if current page should be used as parent page. To reference field value use: [entry.field_name]. Must resolve into spaceKey:pageTitle or in pageId value. Leaving this parameter blank means current page.';

    lookupPages(AJS.$('#macro-param-div-extras').find('#macro-param-extras'),
      function (pageId) {
        AJS.$('#macro-param-div-extras').find('#macro-param-extras').val(pageId).trigger("change");
        AJS.MacroBrowser.processRequiredParameters();
      }, false);

    extras3Label = 'Skip creation if the page with a given title and in a given Confluence space already exists';
    standardExtras3Text = '';

    AJS.$('#macro-param-div-extras').show();
    AJS.$('#macro-param-div-extras2').show();
    AJS.$('#macro-param-div-extras3').show();
  }

  if ('Delete Page' === choice) {
    // titleLabel = 'Page title';
    whoLabel = '';
    extrasLabel = 'Page to DELETE';
    standardExtrasText = 'You (and the users who will use the form) must have edit permissions on this page. To reference field value use: [entry.field_name]. Must resolve into spaceKey:pageTitle or in pageId value. Leaving this parameter blank means current page';

    lookupPages(AJS.$('#macro-param-div-extras').find('#macro-param-extras'),
      function (pageId) {
        AJS.$('#macro-param-div-extras').find('#macro-param-extras').val(pageId).trigger("change");
        AJS.MacroBrowser.processRequiredParameters();
      }, false);

    AJS.$('#macro-param-div-extras').show();
    AJS.$('#macro-param-div-extras2').hide();
    AJS.$('#macro-param-div-title').hide();
    AJS.$('#macro-param-div-who').hide();

    extras3Label = 'Delete children pages';
    standardExtras3Text = '';
    AJS.$('#macro-param-div-extras3').show();
  }
  if ('Move Page' === choice) {
    titleLabel = 'Page title or page ID to move (or page IDs, comma separated, to move multiple pages)';
    whoLabel = 'Page editors (comma separated list of users/usergroups)';
    extrasLabel = 'Parent page';
    standardTitleText = 'You (and the users who will use the form) must have edit permissions on this page. To reference field value use: [entry.field_name]. Must resolve into spaceKey:pageTitle or in pageId value. Leaving this parameter blank means current page';
    standardExtrasText = 'You (and the users who will use the form) must have edit permissions on this page. To reference field value use: [entry.field_name]. Must resolve into spaceKey:pageTitle or in pageId value. Leaving this parameter blank means current page';

    lookupPages(AJS.$('#macro-param-div-extras').find('#macro-param-extras'),
      function (pageId) {
        AJS.$('#macro-param-div-extras').find('#macro-param-extras').val(pageId).trigger("change");
        AJS.MacroBrowser.processRequiredParameters();
      }, false);

    AJS.$('#macro-param-div-extras').show();
    AJS.$('#macro-param-div-title').show();
    AJS.$('#macro-param-div-who').hide();
    AJS.$('#macro-param-div-extras2').hide();
  }
  if ('Copy Page' === choice) {
    titleLabel = 'Page title or page ID to copy (or page IDs, comma separated, to copy multiple pages)';
    whoLabel = 'Page editors (comma separated list of users/usergroups)';
    extrasLabel = 'Parent page';
    standardTitleText = 'You (and the users who will use the form) must have at least view permissions on this page. To reference field value use: [entry.field_name]. Must resolve into spaceKey:pageTitle or in pageId value. Leaving this parameter blank means current page';
