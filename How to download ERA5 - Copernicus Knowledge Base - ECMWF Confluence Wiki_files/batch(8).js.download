try {
/* module-key = 'com.adaptavist.confluence.formMailNG:user-picker-js', location = 'js/forms/rendering/user-picker-macro.js' */
// Select2 initialisation
var results = [];

function formatRepo(result) {
    if (result.emailAddress === "") {
        return '<span class="select2-result-child">' + result.displayName + " (" + result.name + ")" + '</span>';
    }

    return '<span class="select2-result-child">' + result.displayName + " (" + result.name + ")" + " - " + result.emailAddress + '</span>';
}

AJS.toInit(function ($) {

    var userPickers = $.find('.adaptavist-user-picker');

    $.each(userPickers, function (i) {
        var picker = $(this);
        var pickerId = "user-picker" + (i + 1);
        var multiple = picker.attr("multiple");
        var commaSeparetedList = picker.attr("selected-groups");
        var groups = fromCommaSeparetedToArray(commaSeparetedList);

        picker.attr("id", pickerId);

        AJS.$("#" + pickerId).auiSelect2({
            placeholder: 'Please enter username and select one or multiple from the list',
            maximumSelectionSize: function () {
                if (multiple == undefined) {
                    return 1;
                }
            },
            formatResult: formatRepo,
            tags: true,
            tokenSeparators: [','],
            ajax: {
                url: AJS.Meta.get("context-path") + '/rest/formservice/1.0/configs/formmail/searchUsers/?spaceKey=' + AJS.params.spaceKey,
                dataType: 'json',
                type: "GET",
                quietMillis: 250,
                data: function (term) {
                    return {
                        queryName: term,
                        groupNames: groups,
                        selectedUser: fromCommaSeparetedToArray(this.val())
                    };
                },
                results: function (data) {
                    return {
                        results: $.map(data, function (item) {
                            return {
                                id: item.idAsString,
                                name: item.name,
                                text: item.displayName,
                                displayName: item.displayName,
                                emailAddress: item.emailAddress
                            };
                        })
                    };
                }
            }
        });
    });

    function fromCommaSeparetedToArray(commaSeparetedList) {
        var data = [];
        if (commaSeparetedList !== "") {
            $.map(commaSeparetedList.split(","), function (item) {
                data.push(item);
            });
        }
        return data;
    }
});
}catch(e){WRMCB(e)};
;
try {
/* module-key = 'com.adaptavist.confluence.formMailNG:user-picker-config-resource', location = 'js/forms/config/user-picker-config.js' */
AJS.toInit(function ($) {

    function setGroupsFromSelect2Value(groups) {
        if (groups) {
            AJS.$("#macro-param-group-custom").val(groups).trigger("change");
        }
    }

    AJS.MacroBrowser.setMacroJsOverride("user-picker", {
        "fields": {
            "string": {
                "groups": function () {
                    var paramDiv = $(Confluence.Templates.MacroBrowser.macroParameter()),
                        $select = $('<input/>').appendTo(paramDiv);

                    $select.attr("id", "macro-param-group-custom").attr("multiple", true);

                    var $input = $('<input type="hidden"/>').appendTo(paramDiv);

                    $select.on("change", function () {
                        $input.val($(this).val());
                        $input.trigger("change");
                    });
                    return AJS.MacroBrowser.Field(paramDiv, $input, {});
                }
            }
        },
        "beforeParamsSet": function (selectedParams) {
            AJS.$("#macro-param-div-groups input").first().hide();
            AJS.$("#macro-param-group-custom").auiSelect2({
                multiple: true,

                initSelection: function (element, callback) {
                    var initData = [];
                    $.map(element.val().split(","), function (item) {
                        initData.push({
                            id: item,
                            text: item
                        });
                    });

                    callback(initData);
                },

                ajax: {
                    url: AJS.Meta.get("context-path") + '/rest/formservice/1.0/configs/formmail/groups',
                    dataType: 'json',
                    type: "GET",
                    multiple: true,
                    quietMillis: 250,
                    data: function (term) {
                        return {
                            queryName: term,
                            selectedGroups: this.val()
                        };
                    },
                    results: function (data) {
                        return {
                            results: $.map(data, function (item) {
                                return {
                                    id: item,
                                    text: item
                                };
                            })
                        };
                    }
                }
            });
            setGroupsFromSelect2Value(selectedParams.groups);
            return selectedParams;
        },
        "beforeParamsRetrieved": function (selectedParams) {

            $(".select2-search-choice-close").each(function () {
                var events = $(this).data("events");
                if (events) {
                    events.click.splice(1, 1);
                }
            });

            return selectedParams;
        }
    });
});
}catch(e){WRMCB(e)};
;
try {
/* module-key = 'com.adaptavist.confluence.formMailNG:max-selection-validator-resource', location = 'js/forms/validator/max-selection-validator.js' */
AJS.toInit(function ($) {
    var originalValue = "";
    AJS.MacroBrowser.setMacroJsOverride("forms-additional-recipients", {
        "beforeParamsSet": function (selectedParams) {
            var field = AJS.$("#macro-param-maxSelection");
            var regex = /^[1-9]+$/;

            field.change(function(event) {
                // Remove the error message if it already exists (we want to re-validate)
                $('#maxSelection-validation-err').remove();

                var inputVal = event.currentTarget.value;
                if (inputVal !== "" && !regex.test(inputVal)) {
                    field.val(originalValue);
                    field.after(
                        AJS.messages.error({
                            id: 'maxSelection-validation-err',
                            title: "Non-numeric Input Detected!",
                            body: '<p>' + "You can only enter numeric (whole number) values for the Maximum Selection Amount." + '</p>'
                        }));
                }
            });
            return selectedParams;
        },
        "beforeParamsRetrieved": function (selectedParams) {
            var orig = selectedParams["maxSelection"];
            originalValue = "";
            if (orig != null && typeof orig !== "undefined") {
                originalValue = orig;
            }
            return selectedParams;
        }
    });
});
}catch(e){WRMCB(e)};
;
