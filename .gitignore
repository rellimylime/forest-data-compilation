# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site (ignore docs/ in subdirs; keep root docs/ for repo-level documentation)
docs/
!/docs/
!/docs/**
!01_ids/docs
!02_terraclimate/docs
!05_fia/docs/
05_fia/docs/*
!05_fia/docs/dashboard/
!05_fia/docs/fiadb_dashboard.py
!05_fia/docs/fia_data_dashboard.py
!05_fia/docs/build_fiadb_user_guide_index.py
!05_fia/docs/fiadb_user_guide_index_v94.json
!06_species_niches/docs/
!06_species_niches/docs/**
!07_thermophilization/docs/
!07_thermophilization/docs/**
# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# Data folders: keep the directory skeleton via .gitkeep, but ignore bulk data.
**/data/**
!**/data/**/
!**/data/**/.gitkeep

# Dashboard static aggregates: small JSON/CSV that drive the deployed
# dashboard's interactive charts (no parquets, ~2 MB total).
!docs/dashboard/static/data/
!docs/dashboard/static/data/**

# FIA raw CSVs too large for GitHub (TREE tables are 100MB-840MB per state)
05_fia/data/raw/**/*_TREE.csv
05_fia/data/raw/**/*_TREE_GRM_COMPONENT.csv

# FIA processed outputs: keep directory skeletons, track selected review files.
05_fia/data/processed/**
!05_fia/data/processed/**/
!05_fia/data/processed/**/.gitkeep
!05_fia/data/processed/summaries/
!05_fia/data/processed/summaries/*.parquet
05_fia/data/processed/summaries/plot_tree_species.parquet
05_fia/data/processed/summaries/plot_seedling_species.parquet
!05_fia/data/processed/site_climate/
!05_fia/data/processed/site_climate/all_site_locations.csv
# site_climate.parquet and site_pixel_map.parquet are intentionally NOT un-ignored:
# the national extraction is 5.85 GB, well over GitHub's 100 MB hard limit.

# Root processed outputs are legacy/local-only. Active modules keep their own
# data directories and documented output locations.
processed/

# Archived or local-only material. Keep locally if useful, but do not publish
# in the polished repo.
archive/**
output/**
logs/**
tree.txt
site_climate_extract.log

# Species niche smoke-test outputs: useful local history, not commit material.
06_species_niches/qa/smoke/**
!06_species_niches/qa/smoke/
!06_species_niches/qa/smoke/.gitkeep
06_species_niches/data/smoke/**
!06_species_niches/data/smoke/
!06_species_niches/data/smoke/.gitkeep

